    "/api/v2/StatutoryInstrument": {
      "get": {
        "tags": [
          "v2"
        ],
        "summary": "Search through statutory instruments and proposed negatives",
        "operationId": "ListSIsV2",
        "parameters": [
          {
            "name": "Name",
            "in": "query",
            "description": "Statutory instruments with the name specified",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Procedure",
            "in": "query",
            "description": "Statutory instruments made under the specified procedure",
            "schema": {
              "pattern": "^[a-zA-Z0-9]{8}$",
              "type": "string"
            }
          },
          {
            "name": "ScheduledDebate",
            "in": "query",
            "description": "Statutory instrument which contains a scheduled debate",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "MotionToStop",
            "in": "query",
            "description": "Statutory instruments which contains a motion to stop",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "ConcernsRaisedByCommittee",
            "in": "query",
            "description": "Statutory instruments which contains concerns raised by committee",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "ParliamentaryProcessConcluded",
            "in": "query",
            "description": "Statutory instruments where the parliamentary process is concluded or notconcluded",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "DepartmentId",
            "in": "query",
            "description": "Statutory instruments with the department ID specified",
            "schema": {
              "maximum": 2147483647,
              "minimum": 1,
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "LayingBodyId",
            "in": "query",
            "description": "Statutory instruments with the laying body ID specified",
            "schema": {
              "pattern": "^[a-zA-Z0-9]{8}$",
              "type": "string"
            }
          },
          {
            "name": "RecommendedForProcedureChange",
            "in": "query",
            "description": "Statutory instruments recommended for procedure change",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "ActOfParliamentId",
            "in": "query",
            "description": "Statutory instruments with the Act of Parliament ID specified",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "House",
            "in": "query",
            "description": "Statutory instruments laid in the house specified",
            "schema": {
              "$ref": "#/components/schemas/StatutoryInstruments.Services.Domain.Enums.House"
            }
          },
          {
            "name": "Skip",
            "in": "query",
            "description": "The number of records to skip from the first, default is 0",
            "schema": {
              "maximum": 2147483647,
              "minimum": 0,
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "Take",
            "in": "query",
            "description": "The number of records to return, default is 20",
            "schema": {
              "maximum": 2147483647,
              "minimum": 0,
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
