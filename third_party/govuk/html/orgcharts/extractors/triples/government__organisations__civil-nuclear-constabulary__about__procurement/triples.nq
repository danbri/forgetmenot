_:Nfefc260580bd4b7abee33fb0cdccd816 <http://schema.org/articleBody> "<div class=\"govspeak\"><h2 id=\"doing-business-with-the-cnc\">Doing business with the <abbr title=\"Civil Nuclear Constabulary\">CNC</abbr>\n</h2>\n\n<p>Our contracts and procurement team prepares tenders, drafts terms and evaluates offers.</p>\n\n<p>We may post tender notices through:</p>\n\n<ul>\n  <li><a rel=\"external\" href=\"https://www.blpd.gov.uk/logon.aspx?ReturnUrl=%2fdefault.aspx\" class=\"govuk-link\">the Bluelight ProContract website</a></li>\n  <li>\n<a rel=\"external\" href=\"http://www.ojec.com/\" class=\"govuk-link\">the Official Journal of the European Union</a>, where required by the European Union Procurement Directive</li>\n  <li><a href=\"https://www.gov.uk/contracts-finder\" class=\"govuk-link\">Contracts Finder</a></li>\n</ul>\n\n<p>There are a number of opportunities coming up as follows</p>\n\n<ul>\n  <li>Radio Equipment for the Site Security Control Rooms</li>\n  <li>Employee Assistance Programme</li>\n  <li>MOE Shotguns</li>\n  <li>Survey Software</li>\n</ul>\n\n<p>If you’re interested in either of these procurement opportunities send an email to <a href=\"mailto:procurement@cnc.pnn.police.uk\" class=\"govuk-link\">procurement@cnc.pnn.police.uk</a> with the specific procurement opportunity referenced in the subject line.</p>\n\n<h2 id=\"standard-supplier-terms-and-conditions\">Standard supplier terms and conditions</h2>\n\n<p>Purchases we make are subject to our terms and conditions, but some purchases may be subject to a special set of terms and conditions.</p>\n\n<section data-module=\"ga4-link-tracker\" class=\"gem-c-attachment govuk-!-margin-bottom-6\">\n  <div class=\"gem-c-attachment__thumbnail govuk-!-display-none-print\">\n    <a class=\"govuk-link\" target=\"_self\" tabindex=\"-1\" aria-hidden=\"true\" data-ga4-link='{\"event_name\":\"file_download\",\"type\":\"attachment\"}' href=\"https://assets.publishing.service.gov.uk/media/618298398fa8f5297a62a340/Shortform_Terms_and_Conditions_Goods_FINAL.pdf\">\n        <svg class=\"gem-c-attachment__thumbnail-image gem-c-attachment__thumbnail-image--pdf\" version=\"1.1\" viewbox=\"0 0 99 140\">\n  <path d=\"M12,59h9v9h-9v-9ZM30,77v9h39v-9H30ZM30,104h57v-9H30v9ZM30,122h48v-9H30v9ZM12,86h9v-9h-9v9ZM12,122h9v-9h-9v9ZM12,104h9v-9h-9v9ZM30,68h57v-9H30v9ZM35.2,21c-.3-.2-.6-.4-1-.5s-.8-.2-1.3-.2h-2.6v5.5h2.6c.5,0,1,0,1.3-.2s.7-.3,1-.5c.3-.2.5-.5.7-.8s.2-.7.2-1.1h0c0-.5,0-.9-.2-1.2-.2-.3-.4-.6-.7-.8h0ZM52.4,21.9c-.4-.5-1-.9-1.6-1.1-.7-.3-1.5-.4-2.4-.4h-2.7v11.5h2.7c.9,0,1.7-.1,2.4-.4s1.2-.7,1.6-1.1c.4-.5.7-1.1.9-1.7.2-.7.3-1.4.3-2.1v-.7c0-.8,0-1.5-.3-2.1-.2-.6-.5-1.2-.9-1.7h0ZM87,12v27H12V12h75ZM39.8,23c0-.9-.1-1.6-.4-2.4-.3-.7-.7-1.4-1.2-1.9-.5-.5-1.2-1-1.9-1.2-.8-.3-1.6-.5-2.5-.5h-7.2v17.9h3.6v-6h3.2c.9,0,1.8-.1,2.6-.5.8-.3,1.4-.7,2-1.2.5-.5,1-1.2,1.3-1.9.3-.7.5-1.5.5-2.4h0ZM57.4,26c0-1.3-.2-2.6-.5-3.7s-.9-2-1.6-2.8c-.7-.8-1.6-1.4-2.7-1.8-1.1-.4-2.3-.6-3.8-.6h-6.6v17.9h6.6c1.5,0,2.7-.2,3.8-.6,1.1-.4,2-1,2.7-1.8.7-.8,1.3-1.7,1.6-2.8.4-1.1.5-2.3.5-3.7h0ZM72.4,17.1h-12.1v17.9h3.6v-7.5h7.8v-3.3h-7.8v-3.8h8.4s0-3.3,0-3.3Z\"></path>\n</svg>\n\n</a>\n</div>\n  <div class=\"gem-c-attachment__details\">\n    <h2 class=\"gem-c-attachment__title\">\n      <a class=\"govuk-link\" target=\"_self\" data-ga4-link='{\"event_name\":\"file_download\",\"type\":\"attachment\"}' href=\"https://assets.publishing.service.gov.uk/media/618298398fa8f5297a62a340/Shortform_Terms_and_Conditions_Goods_FINAL.pdf\">Short form terms and conditions - goods</a>\n</h2>\n\n\n      <p class=\"gem-c-attachment__metadata\"><span class=\"gem-c-attachment__attribute\"><abbr title=\"Portable Document Format\" class=\"gem-c-attachment__abbr\">PDF</abbr></span>, <span class=\"gem-c-attachment__attribute\">201 KB</span>, <span class=\"gem-c-attachment__attribute\">14 pages</span></p>\n\n\n\n\n      <p class=\"gem-c-attachment__metadata\">This file may not be suitable for users of assistive technology.</p>\n      <details data-module=\"ga4-event-tracker\" data-ga4-event='{\"event_name\":\"select_content\",\"type\":\"detail\",\"text\":\"Request an accessible format.\",\"section\":\"Request an accessible format.\",\"index_section\":1}' class=\"gem-c-details govuk-details govuk-!-margin-bottom-0\" title=\"Request an accessible format.\">\n  <summary class=\"govuk-details__summary\">\n    <span class=\"govuk-details__summary-text\" data-ga4-expandable>\n      Request an accessible format.\n    </span>\n</summary>  <div class=\"govuk-details__text\">\n    \n        If you use assistive technology (such as a screen reader) and need a version of this document in a more accessible format, please email <a href=\"mailto:press.office@cnc.pnn.police.uk\" target=\"_blank\" class=\"govuk-link\">press.office@cnc.pnn.police.uk</a>. Please tell us what format you need. It will help us if you say what assistive technology you use.\n\n  </div>\n</details>\n</div></section>\n\n<section data-module=\"ga4-link-tracker\" class=\"gem-c-attachment govuk-!-margin-bottom-6\">\n  <div class=\"gem-c-attachment__thumbnail govuk-!-display-none-print\">\n    <a class=\"govuk-link\" target=\"_self\" tabindex=\"-1\" aria-hidden=\"true\" data-ga4-link='{\"event_name\":\"file_download\",\"type\":\"attachment\"}' href=\"https://assets.publishing.service.gov.uk/media/6182984dd3bf7f56020e5061/Shortform_Terms_and_Conditions_Services_FINAL.pdf\">\n        <svg class=\"gem-c-attachment__thumbnail-image gem-c-attachment__thumbnail-image--pdf\" version=\"1.1\" viewbox=\"0 0 99 140\">\n  <path d=\"M12,59h9v9h-9v-9ZM30,77v9h39v-9H30ZM30,104h57v-9H30v9ZM30,122h48v-9H30v9ZM12,86h9v-9h-9v9ZM12,122h9v-9h-9v9ZM12,104h9v-9h-9v9ZM30,68h57v-9H30v9ZM35.2,21c-.3-.2-.6-.4-1-.5s-.8-.2-1.3-.2h-2.6v5.5h2.6c.5,0,1,0,1.3-.2s.7-.3,1-.5c.3-.2.5-.5.7-.8s.2-.7.2-1.1h0c0-.5,0-.9-.2-1.2-.2-.3-.4-.6-.7-.8h0ZM52.4,21.9c-.4-.5-1-.9-1.6-1.1-.7-.3-1.5-.4-2.4-.4h-2.7v11.5h2.7c.9,0,1.7-.1,2.4-.4s1.2-.7,1.6-1.1c.4-.5.7-1.1.9-1.7.2-.7.3-1.4.3-2.1v-.7c0-.8,0-1.5-.3-2.1-.2-.6-.5-1.2-.9-1.7h0ZM87,12v27H12V12h75ZM39.8,23c0-.9-.1-1.6-.4-2.4-.3-.7-.7-1.4-1.2-1.9-.5-.5-1.2-1-1.9-1.2-.8-.3-1.6-.5-2.5-.5h-7.2v17.9h3.6v-6h3.2c.9,0,1.8-.1,2.6-.5.8-.3,1.4-.7,2-1.2.5-.5,1-1.2,1.3-1.9.3-.7.5-1.5.5-2.4h0ZM57.4,26c0-1.3-.2-2.6-.5-3.7s-.9-2-1.6-2.8c-.7-.8-1.6-1.4-2.7-1.8-1.1-.4-2.3-.6-3.8-.6h-6.6v17.9h6.6c1.5,0,2.7-.2,3.8-.6,1.1-.4,2-1,2.7-1.8.7-.8,1.3-1.7,1.6-2.8.4-1.1.5-2.3.5-3.7h0ZM72.4,17.1h-12.1v17.9h3.6v-7.5h7.8v-3.3h-7.8v-3.8h8.4s0-3.3,0-3.3Z\"></path>\n</svg>\n\n</a>\n</div>\n  <div class=\"gem-c-attachment__details\">\n    <h2 class=\"gem-c-attachment__title\">\n      <a class=\"govuk-link\" target=\"_self\" data-ga4-link='{\"event_name\":\"file_download\",\"type\":\"attachment\"}' href=\"https://assets.publishing.service.gov.uk/media/6182984dd3bf7f56020e5061/Shortform_Terms_and_Conditions_Services_FINAL.pdf\">Short form terms and conditions - services</a>\n</h2>\n\n\n      <p class=\"gem-c-attachment__metadata\"><span class=\"gem-c-attachment__attribute\"><abbr title=\"Portable Document Format\" class=\"gem-c-attachment__abbr\">PDF</abbr></span>, <span class=\"gem-c-attachment__attribute\">213 KB</span>, <span class=\"gem-c-attachment__attribute\">18 pages</span></p>\n\n\n\n\n      <p class=\"gem-c-attachment__metadata\">This file may not be suitable for users of assistive technology.</p>\n      <details data-module=\"ga4-event-tracker\" data-ga4-event='{\"event_name\":\"select_content\",\"type\":\"detail\",\"text\":\"Request an accessible format.\",\"section\":\"Request an accessible format.\",\"index_section\":1}' class=\"gem-c-details govuk-details govuk-!-margin-bottom-0\" title=\"Request an accessible format.\">\n  <summary class=\"govuk-details__summary\">\n    <span class=\"govuk-details__summary-text\" data-ga4-expandable>\n      Request an accessible format.\n    </span>\n</summary>  <div class=\"govuk-details__text\">\n    \n        If you use assistive technology (such as a screen reader) and need a version of this document in a more accessible format, please email <a href=\"mailto:press.office@cnc.pnn.police.uk\" target=\"_blank\" class=\"govuk-link\">press.office@cnc.pnn.police.uk</a>. Please tell us what format you need. It will help us if you say what assistive technology you use.\n\n  </div>\n</details>\n</div></section>\n\n</div>" <https://forgetmenot.local/extractor/jsonld> .
