<https://www.gov.uk/government/organisations/industrial-strategy-advisory-council> govuk:hasMinister <https://www.gov.uk/government/people/aislinn-rice> .

<https://www.gov.uk/government/people/aislinn-rice> a schema1:Person ;
    dcterms:isPartOf <https://www.gov.uk/government> ;
    schema1:description "Dr Aislinn Rice has over 25 years’ experience in leadership positions across small and medium-sized enterprises (SMEs) and global organisations in the technology sector. She was appointed to the Board of QUBIS from 2012 to 2018, the commercialisation arm of Queen’s University Belfast ( QUB ). Aislinn is currently Director of Software NI and Non-Executive Director at Analytics Engines. She holds a PhD in Chemistry from QUB ."@en ;
    schema1:name "Dr Aislinn Rice"@en ;
    schema1:url <https://www.gov.uk/government/people/aislinn-rice> ;
    govuk:affiliatedWith <https://www.gov.uk/government/organisations/industrial-strategy-advisory-council> ;
    govuk:currentRoleTitle "Industrial Strategy Advisory Council member"@en .

