    dcterms:isPartOf <https://www.gov.uk/government> ;
    schema1:description "Andrew Mitchell was a Minister of State in the Foreign, Commonwealth & Development Office (FCDO) between 25 October 2022 and 5 July 2024. On 12 April 2024 he was given the honorific title of Deputy Foreign Secretary."@en ;
    schema1:name "The Rt Hon Andrew Mitchell MP"@en ;
