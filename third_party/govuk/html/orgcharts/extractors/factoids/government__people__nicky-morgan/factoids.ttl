<https://www.gov.uk/government/organisations/government-digital-service> govuk:hasMinister <https://www.gov.uk/government/people/nicky-morgan> .

<https://www.gov.uk/government/people/nicky-morgan> a schema1:Person ;
    dcterms:isPartOf <https://www.gov.uk/government> ;
    schema1:description "The Rt Hon Baroness Morgan of Cotes was Secretary of State for Digital, Culture, Media and Sport from 24 July 2019 to 13 February 2020. She served as Education Secretary and Minister for Women and Equalities from July 2014 to July 2016. She served as an Assistant Whip in the coalition government until her appointment as Economic Secretary to the Treasury in October 2013. Nicky served as Financial Secretary to the Treasury and Minister for Women from April until July 2014. She was elected Conservative MP for Loughborough in 2010."@en ;
    schema1:name "The Rt Hon Baroness Nicky Morgan"@en ;
    schema1:url <https://www.gov.uk/government/people/nicky-morgan> ;
    govuk:affiliatedWith <https://www.gov.uk/government/organisations/government-digital-service> .

