<https://www.gov.uk/government/organisations/nuclear-waste-services> govuk:hasMinister <https://www.gov.uk/government/people/mike-pigott> .

<https://www.gov.uk/government/people/mike-pigott> a schema1:Person ;
    dcterms:isPartOf <https://www.gov.uk/government> ;
    schema1:description "Mike is duty holder for the Low Level Waste Repository nuclear licensed site, responsible for operating safely, securely, with environmental compliance, and retaining its social license to operate. He holds key leadership roles in environmental and nuclear safety; security governance; and strategic waste management. He also represents NWS in regional and local stakeholder groups."@en ;
    schema1:name "Mike Pigott"@en ;
    schema1:url <https://www.gov.uk/government/people/mike-pigott> ;
    govuk:affiliatedWith <https://www.gov.uk/government/organisations/nuclear-waste-services> ;
    govuk:currentRoleTitle "Director of Sites and Operations"@en .

