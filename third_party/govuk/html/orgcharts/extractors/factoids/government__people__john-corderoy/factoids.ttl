<https://www.gov.uk/government/organisations/nuclear-waste-services> govuk:hasMinister <https://www.gov.uk/government/people/john-corderoy> .

<https://www.gov.uk/government/people/john-corderoy> a schema1:Person ;
    dcterms:isPartOf <https://www.gov.uk/government> ;
    schema1:description "John has been an integral part of our Geological Disposal Facility (GDF) programme since 2016. Before joining the programme, John was in the Royal Navy with a 30 year nuclear engineering career as a submariner. In his last Defence role he was the UK’s Director of Nuclear Propulsion; responsible for all aspects of designing, delivering and supporting a fleet of submarine reactor plants."@en ;
    schema1:name "John Corderoy"@en ;
    schema1:url <https://www.gov.uk/government/people/john-corderoy> ;
    govuk:affiliatedWith <https://www.gov.uk/government/organisations/nuclear-waste-services> ;
    govuk:currentRoleTitle "Chief Technical Officer"@en .

