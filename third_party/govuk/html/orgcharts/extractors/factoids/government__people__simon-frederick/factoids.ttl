<https://www.gov.uk/government/people/simon-frederick> a schema1:Person ;
    dcterms:isPartOf <https://www.gov.uk/government> ;
    schema1:description "Self-taught artist, photographer, filmmaker and broadcaster Simon Frederick was born in London to Grenadian parents. His photographs made history when his collection entitled ‘Black Is The New Black’ became the largest acquisition of African-Caribbean sitters by the National Portrait Gallery, becoming part of the Gallery’s prestigious permanent collection."@en ;
    schema1:name "Simon Frederick"@en ;
    schema1:url <https://www.gov.uk/government/people/simon-frederick> ;
