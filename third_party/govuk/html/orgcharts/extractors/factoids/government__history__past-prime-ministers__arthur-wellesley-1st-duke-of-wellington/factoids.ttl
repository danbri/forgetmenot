<https://www.gov.uk/government/history/past-prime-ministers/arthur-wellesley-1st-duke-of-wellington> a schema1:Person,
        govuk:PastPrimeMinister ;
    dcterms:isPartOf <https://www.gov.uk/government> ;
    schema1:description "Arthur Wellesley 1st Duke of Wellington is today more famous as a soldier than as a politician. In fact, as the Prime Minister, he was known for his measures to repress reform, and his popularity sank a little during his time in office."@en ;
    schema1:name "Arthur Wellesley, 1st Duke of Wellington"@en ;
    schema1:url <https://www.gov.uk/government/history/past-prime-ministers/arthur-wellesley-1st-duke-of-wellington> .

