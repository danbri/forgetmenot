<https://www.gov.uk/government/people/charlotte-valeur> a schema1:Person ;
    dcterms:isPartOf <https://www.gov.uk/government> ;
    schema1:description "Charlotte is an Investment Banker and experienced FTSE Chair and Non-Executive Director. Her long board-level experience spans a host of sectors and industries and covers IPOs, M&A and restructuring. She is a recognised international authority and professor in corporate governance and leadership, and author of Effective Directors, Questions to Ask."@en ;
