<https://www.gov.uk/government/people/dowden> a schema1:Person ;
    dcterms:isPartOf <https://www.gov.uk/government> ;
    schema1:description "Oliver Dowden CBE was Chancellor of the Duchy of Lancaster from 25 October 2022 to 5 July 2024. He was Secretary of State in the Cabinet Office from 9 February 2023 to 5 July 2024 and Deputy Prime Minister from 21 April 2023 to 5 July 2024."@en ;
    schema1:name "The Rt Hon Oliver Dowden CBE MP"@en ;
