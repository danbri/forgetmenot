<https://www.gov.uk/government/ministers/attorney-general> a govuk:MinisterialRole ;
    dcterms:isPartOf <https://www.gov.uk/government> ;
    dcterms:modified "2024-07-31T15:08:40+01:00" ;
    schema1:name "Attorney General"@en ;
    schema1:url <https://www.gov.uk/government/ministers/attorney-general> ;
    govuk:contentId "845e6aa7-c0f1-11e4-8223-005056011aef" ;
    govuk:partOf <https://www.gov.uk/government/organisations/attorney-generals-office> ;
    govuk:previouslyHeldBy <https://www.gov.uk/government/people/braverman>,
        <https://www.gov.uk/government/people/dominic-grieve>,
        <https://www.gov.uk/government/people/geoffrey-cox>,
        <https://www.gov.uk/government/people/jeremy-wright>,
        <https://www.gov.uk/government/people/michael-ellis>,
        <https://www.gov.uk/government/people/victoria-prentis> ;
    govuk:publishingApp "whitehall" ;
    govuk:responsibility "Government’s principal legal adviser dealing with (amongst others) questions of public law, international law, human rights and devolution"@en,
        "Non-statutory general oversight of the Government Legal Department, the Services Prosecuting Authority, and government prosecuting departments"@en,
        "Overall responsibility for the work of the Attorney General’s Office and superintended departments (the Government Legal Department, the Crown Prosecution Service, the Serious Fraud Office and HM Crown Prosecution Service Inspectorate)"@en,
        "Oversight of all major international and domestic litigation involving the Government"@en,
        "Promoting the rule of law at home and internationally"@en,
        "Public interest functions, for example, reference of unduly lenient sentences to the Court of Appeal, bringing proceedings for contempt of court and intervention in certain proceedings to protect charities"@en,
        "Questions of law arising on Bills and with issues of legal policy"@en,
        "Specific statutory duty to superintend the discharge of duties by the Director of Public Prosecutions (who heads the Crown Prosecution Service) and the Director of the Serious Fraud Office"@en ;
    govuk:roleHolder <https://www.gov.uk/government/people/richard-hermer> ;
    govuk:schemaName "role" .

