@prefix schema1: <http://schema.org/> .

<https://www.gov.uk/government/history/past-prime-ministers/john-stuart-3rd-earl-of-bute> a schema1:Person,
        govuk:PastPrimeMinister ;
    dcterms:isPartOf <https://www.gov.uk/government> ;
    schema1:description "John Stuart, Earl of Bute, was a favourite of George III. He was the King’s tutor in the 1750s and rose quickly to high political office after George’s accession in 1760. Bute faced the difficult task of negotiating peace at the end of the Seven Years War."@en ;
    schema1:name "John Stuart, 3rd Earl of Bute"@en ;
    schema1:url <https://www.gov.uk/government/history/past-prime-ministers/john-stuart-3rd-earl-of-bute> .

