<https://www.gov.uk/government/organisations/government-digital-service> govuk:hasMinister <https://www.gov.uk/government/people/barbara-woodward> .

<https://www.gov.uk/government/people/barbara-woodward> a schema1:Person ;
    dcterms:isPartOf <https://www.gov.uk/government> ;
    schema1:description "Dame Barbara Woodward, took up the role of Deputy National Security Adviser (International) at the Cabinet Office on 01 December 2025. Dame Barbara was the UK’s Permanent Representative to the United Nations in New York from 2020 to 2025. She led the UK Mission’s work at the UN to protect and advance UK security and prosperity, and drive progress on global peace and development."@en ;
    schema1:name "Dame Barbara Woodward GCMG OBE"@en ;
    schema1:url <https://www.gov.uk/government/people/barbara-woodward> ;
    govuk:affiliatedWith <https://www.gov.uk/government/organisations/government-digital-service> .

