<https://www.gov.uk/government/people/alan-campbell> a schema1:Person ;
    dcterms:isPartOf <https://www.gov.uk/government> ;
    schema1:description "Sir Alan Campbell was appointed Lord President of the Council, and Leader of the House of Commons on 5 September 2025. He was previously Parliamentary Secretary to the Treasury (Chief Whip) between 5 July 2024 and 5 September 2025. He was elected as the MP for Tynemouth in May 1997."@en ;
    schema1:name "The Rt Hon Sir Alan Campbell MP"@en ;
    schema1:url <https://www.gov.uk/government/people/alan-campbell> ;
