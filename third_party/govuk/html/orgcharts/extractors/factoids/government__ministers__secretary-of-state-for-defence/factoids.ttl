<https://www.gov.uk/government/ministers/secretary-of-state-for-defence> a govuk:MinisterialRole ;
    dcterms:isPartOf <https://www.gov.uk/government> ;
    schema1:name "Secretary of State for Defence"@en ;
    schema1:url <https://www.gov.uk/government/ministers/secretary-of-state-for-defence> ;
    govuk:partOf <https://www.gov.uk/government/organisations/ministry-of-defence> ;
    govuk:previouslyHeldBy <https://www.gov.uk/government/people/ben-wallace>,
        <https://www.gov.uk/government/people/gavin-williamson>,
        <https://www.gov.uk/government/people/grant-shapps>,
        <https://www.gov.uk/government/people/liam-fox>,
