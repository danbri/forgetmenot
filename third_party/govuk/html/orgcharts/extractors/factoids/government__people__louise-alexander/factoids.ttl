<https://www.gov.uk/government/people/louise-alexander> a schema1:Person ;
    dcterms:isPartOf <https://www.gov.uk/government> ;
    schema1:description "Louise joined HM Courts & Tribunals Service from the Insolvency Service where, in her role as People and Capability Director, she had responsibilities across the HR sphere including resourcing, reward, talent, learning & development, engagement, and internal communications. Prior to that, Louise was Deputy Director of HR at the Department of Health and before that took on the role of Head of HR for Royal Mail Operations."@en ;
    schema1:name "Louise Alexander"@en ;
