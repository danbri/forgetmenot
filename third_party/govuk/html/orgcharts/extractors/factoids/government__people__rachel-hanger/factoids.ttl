<https://www.gov.uk/government/organisations/dormant-assets-commission> govuk:hasMinister <https://www.gov.uk/government/people/rachel-hanger> .

<https://www.gov.uk/government/people/rachel-hanger> a schema1:Person ;
    dcterms:isPartOf <https://www.gov.uk/government> ;
    schema1:description "Rachel Hanger is a Partner and UK Head of Investment Management & Funds Tax at KPMG London. Rachel advises traditional, hedge fund managers and pension funds on corporate/partnership, product and operational tax issues. Prior to joining KPMG Rachel was Head of Tax at M&G for over 10 years. She was responsible for providing pro-active tax advice to all parts of M&G’s business particularly focusing on product development, risk and operational tax matters."@en ;
    schema1:name "Rachel Hanger"@en ;
    schema1:url <https://www.gov.uk/government/people/rachel-hanger> ;
    govuk:affiliatedWith <https://www.gov.uk/government/organisations/dormant-assets-commission> ;
    govuk:currentRoleTitle "Dormant Assets Commissioner"@en .

