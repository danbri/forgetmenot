<https://www.gov.uk/government/history/past-prime-ministers/robert-peel-2nd-baronet> a schema1:Person,
        govuk:PastPrimeMinister ;
    dcterms:isPartOf <https://www.gov.uk/government> ;
    schema1:description "Sir Robert Peel’s period in government – as prime minister and in other offices – was a milestone for social reform. Landmark legislation cut working hours for women and children, created cheap and regular rail services, and reorganised the policing of London, radically changing society."@en ;
    schema1:name "Sir Robert Peel 2nd Baronet"@en ;
    schema1:url <https://www.gov.uk/government/history/past-prime-ministers/robert-peel-2nd-baronet> .

