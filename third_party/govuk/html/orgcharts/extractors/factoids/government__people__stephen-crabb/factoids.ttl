<https://www.gov.uk/government/people/stephen-crabb> a schema1:Person ;
    dcterms:isPartOf <https://www.gov.uk/government> ;
    schema1:description "Stephen Crabb served as Secretary of State for Work and Pensions from 19 March 2016 until 14 July 2016. He previously served as Secretary of State for Wales from July 2014 until March 2016 and as Parliamentary Under Secretary of State in the Wales Office from 2012 to 2014. He was elected as Conservative MP for Preseli Pembrokeshire in 2005."@en ;
    schema1:name "The Rt Hon Stephen Crabb"@en ;
    schema1:url <https://www.gov.uk/government/people/stephen-crabb> ;
