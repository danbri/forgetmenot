edIn"},{"href":"https://giaa.blog.gov.uk/","service_type":"blog","title":"GIAA blog"},{"href":"https://www.youtube.com/@governmentinternalauditage1825/featured","service_type":"youtube","title":"GIAA YouTube"}]},"document_type":"organisation","first_published_at":"2014-09-30T16:42:28+01:00","links":{"available_translations":[{"analytics_identifier":"EA1084","api_path":"/api/content/government/organisations/government-internal-audit-agency","api_url":"https://www.gov.uk/api/content/government/organisations/government-internal-audit-agency","base_path":"/government/organisations/government-internal-audit-agency","content_id":"bad7475f-f594-4c59-8e69-e1865d778678","document_type":"organisation","links":{},"locale":"en","public_updated_at":"2023-05-26T13:56:34Z","schema_name":"organisation","title":"Government Internal Audit Agency","web_url":"https://www.gov.uk/government/organisations/government-internal-audit-agency","withdrawn":false}],"ordered_board_members":[{"api_path":"/api/content/government/people/harriet-aldridge","api_url":"https://www.gov.uk/api/content/government/people/harriet-aldridge","base_path":"/government/people/harriet-aldridge","content_id":"1bc54f8f-1fab-448f-8900-2a2cb6ff586c","details":{"image":{"alt_text":"Harriet Aldridge","url":"https://assets.publishing.service.gov.uk/media/65ba2c4f4ec51d0014c9f1f8/s465_Harriet_Aldridge03.jpg"},"privy_counsellor":false},"document_type":"person","links":{"role_appointments":[{"content_id":"0e716070-7218-473d-a95f-ab534e0d5e4b","details":{"current":true,"ended_on":null,"person_appointment_order":1,"started_on":"2023-12-04T00:00:00+00:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"8477d6fb-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Chief Executive is the Government Internal Audit Agency’s (GIAA) Accounting Officer. She is responsible to the relevant Minister and, as the GIAA is an Arm’s Length Body of HM Treasury, the Principal Accounting Officer of HMT for the GIAA’s performance.</p>\n\n<p>The Chief Executive is responsible for setting the strategic direction of the GIAA, in consultation with the advisory Board.</p>\n\n<p>Providing a service to the Accounting Officers of most of the major Whitehall Departments and over 100 other customers, the Chief Executive has stewardship of the vision for the Agency to deliver better insights for better outcomes. This is given effect through the Strategy 2023 and the annual Corporate Plan.</p>\n\n<p>The Chief Executive is also Head of the Government Internal Audit Function.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2025-03-19T12:14:07Z","schema_name":"role","title":"Chief Executive of the GIAA, Head of Government Internal Audit, and Board Member","withdrawn":false}]},"locale":"en","public_updated_at":"2023-12-18T10:24:11Z","schema_name":"role_appointment","title":"Harriet Aldridge - Chief Executive of the GIAA, Head of Government Internal Audit, and Board Member","withdrawn":false}]},"locale":"en","public_updated_at":"2025-03-26T16:08:58Z","schema_name":"person","title":"Harriet Aldridge","web_url":"https://www.gov.uk/government/people/harriet-aldridge","withdrawn":false},{"api_path":"/api/content/government/people/isobel-everett","api_url":"https://www.gov.uk/api/content/government/people/isobel-everett","base_path":"/government/people/isobel-everett","content_id":"88640a07-6c34-432f-9a3e-4b0b7419e7b6","details":{"image":{"alt_text":"Isobel Everett","url":"https://assets.publishing.service.gov.uk/media/64783f12103ca6000c039784/s465_Everett.jpg"},"privy_counsellor":false},"document_type":"person","links":{"role_appointments":[{"content_id":"b7ec12fe-9f56-407b-83ca-530fa89ede7a","details":{"current":false,"ended_on":"2021-10-01T00:00:00+01:00","person_appointment_order":6647,"started_on":"2021-02-01T00:00:00+00:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"f1835f39-c414-43a5-8c73-66ef500fec87","detai