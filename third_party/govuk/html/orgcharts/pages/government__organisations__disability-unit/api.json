{"analytics_identifier":"OT1309","base_path":"/government/organisations/disability-unit","content_id":"0f97b85f-190d-42c9-8e3a-716f7a7033ff","description":"Our aim is to break down the barriers faced by disabled people in the UK and to work across government to improve disabled people’s lives. Disability Unit is part of the Cabinet Office .","details":{"acronym":"","alternative_format_contact_email":"dupublications@cabinetoffice.gov.uk","body":"<div class=\"govspeak\"><p>Our aim is to break down the barriers faced by disabled people in the UK and to work across government to improve disabled people’s lives.</p>\n\n<p>Disability Unit is part of the <a class=\"brand__color\" href=\"/government/organisations/cabinet-office\">Cabinet Office</a>.</p>\n</div>","brand":"cabinet-office","foi_exempt":false,"logo":{"crest":"single-identity","formatted_title":"Disability Unit"},"ordered_corporate_information_pages":[{"href":"/government/organisations/disability-unit/about/accessible-documents-policy","title":"Accessible documents policy"},{"href":"/government/organisations/disability-unit/about/media-enquiries","title":"Media enquiries"}],"ordered_featured_documents":[{"document_type":"News story","href":"/government/news/disability-minister-pays-tribute-to-paralympicsgb-athletes-for-inspiring-the-next-generation-in-paris","image":{"alt_text":"The Minister for Social Security and Disability, Sir Stephen Timms MP, speaking with gold medal Para taekwondo athlete, Matt Bush.","high_resolution_url":"https://assets.publishing.service.gov.uk/media/66df16d6b1a8879e4432822a/s712_Paralympics_2024_PN_-_960_x_640.png","medium_resolution_url":"https://assets.publishing.service.gov.uk/media/66df16d661f4a22cad32822e/s465_Paralympics_2024_PN_-_960_x_640.png","url":"https://assets.publishing.service.gov.uk/media/66df16d645cb18e102ebabcf/Paralympics_2024_PN_-_960_x_640.png"},"public_updated_at":"2024-09-09T16:32:59.000+01:00","summary":"<div class=\"govspeak\"><p>The Minister for Social Security and Disability, Sir Stephen Timms highlighted the importance of disability inclusion and accessibility as he met with ParalympicsGB athletes at the 17th Summer Paralympic Games in Paris.</p>\n</div>","title":"Disability Minister pays tribute to ParalympicsGB athletes for ‘inspiring the next generation in Paris’"},{"document_type":"Press release","href":"/government/news/uk-government-celebrates-extension-of-un-disability-convention-to-bermuda","image":{"alt_text":"","high_resolution_url":"https://assets.publishing.service.gov.uk/media/67091cc93b919067bb483050/s712_s300_UNCRPD_Extension_PN_-_960_x_640__FINAL_.png","medium_resolution_url":"https://assets.publishing.service.gov.uk/media/67091cc9366f494ab2e7b741/s465_s300_UNCRPD_Extension_PN_-_960_x_640__FINAL_.png","url":"https://assets.publishing.service.gov.uk/media/67091cc9e84ae1fd8592f210/s300_UNCRPD_Extension_PN_-_960_x_640__FINAL_.png"},"public_updated_at":"2024-10-10T14:00:03.000+01:00","summary":"<div class=\"govspeak\"><p>The extension of the UN Disability Convention will protect the rights of over three thousand disabled people living in Bermuda.</p>\n</div>","title":"UK Government celebrates extension of UN Disability Convention to Bermuda"}],"ordered_featured_links":[{"href":"https://www.gov.uk/browse/disabilities/rights","title":"Disability rights"},{"href":"https://www.gov.uk/equality-act-2010-guidance","title":"Equality Act guidance"},{"href":"https://www.gov.uk/financial-help-disabled","title":"Financial help if you're disabled"},{"href":"https://www.google.com/url?q=https://www.gov.uk/government/groups/lead-ministers-for-disability&sa=D&source=calendar&ust=1734782686676093&usg=AOvVaw0vmfsvq35uk7nENYzXY4ZD","title":"Lead Ministers for Disability"}],"ordered_promotional_features":[],"organisation_featuring_priority":"news","organisation_govuk_status":{"status":"live","updated_at":null,"url":null},"organisation_political":false,"organisation_type":"sub_organisation","secondary_corporate_information_pag