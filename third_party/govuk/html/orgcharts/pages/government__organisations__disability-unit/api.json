inet-office","base_path":"/government/organisations/cabinet-office","content_id":"96ae61d6-c2a1-48cb-8e67-da9d105ae381","details":{"acronym":"","brand":"cabinet-office","default_news_image":{"high_resolution_url":"https://assets.publishing.service.gov.uk/media/5a37da9d40f0b649cfaf7b27/s960_cabinet-office.jpg","url":"https://assets.publishing.service.gov.uk/media/5a37da9ded915d5a5f965f9c/s300_cabinet-office.jpg"},"logo":{"crest":"single-identity","formatted_title":"Cabinet Office"},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"Cabinet Office","web_url":"https://www.gov.uk/government/organisations/cabinet-office","withdrawn":false}],"ordered_roles":[{"content_id":"4abd561e-7401-4823-9630-8b3c307a4f08","details":{"body":"\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2020-03-24T15:52:03Z","schema_name":"role","title":"Deputy Director","withdrawn":false},{"content_id":"b5a8864e-4326-40b7-ab06-c1178957f5d2","details":{"body":"\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2021-05-18T15:55:38Z","schema_name":"role","title":"Director, Disability Unit","withdrawn":false},{"content_id":"b5738a14-52f2-4a85-82db-4d10750aae7b","details":{"body":"\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2022-07-21T15:51:27Z","schema_name":"role","title":"Deputy Director","withdrawn":false},{"api_path":"/api/content/government/ministers/parliamentary-under-secretary-of-state-minister-for-disabled-people-health-and-work","api_url":"https://www.gov.uk/api/content/government/ministers/parliamentary-under-secretary-of-state-minister-for-disabled-people-health-and-work","base_path":"/government/ministers/parliamentary-under-secretary-of-state-minister-for-disabled-people-health-and-work","content_id":"80c2101b-999b-4080-a85a-aba257da8942","details":{"body":"<div class=\"call-to-action\">\n  <p>In April 2024  the role of Parliamentary Under Secretary of State (Minister for Disabled People, Health and Work) was replaced by the role of <a href=\"https://www.gov.uk/government/ministers/minister-of-state-disabled-people\">Minister of State (Minister for Disabled People, Health and Work)</a>.</p>\n</div>\n\n<p>Responsibilities include:</p>\n\n<ul>\n  <li>disability policy and cross-government responsibility for disabled people</li>\n  <li>oversight of Disability Unit, and convenor of Disability Champions</li>\n  <li>work and health strategy, including sponsorship of the joint Department for Work and Pensions / Department for Health and Social Care Work and Health Unit, and disability benefit reform</li>\n  <li>disability employment, and disability employment programmes</li>\n  <li>financial support for those at risk of falling out of work, and disabled claimants including, Disability Living Allowance (<abbr title=\"Disability Living Allowance\">DLA</abbr>), Personal Independence Payment (<abbr title=\"Personal Independence Payment\">PIP</abbr>), Employment and Support Allowance (<abbr title=\"Employment and Support Allowance\">ESA</abbr>) and Carer’s Allowance (<abbr title=\"Carer's Allowance\">CA</abbr>)</li>\n  <li>Social Mobility</li>\n  <li>Support for disadvantaged groups</li>\n  <li>Youth Offer</li>\n  <li>Government Equalities Office (<abbr title=\"Government Equalities Office\">GEO</abbr>) lead, Women and the Menopause</li>\n  <li>Military Covenant</li>\n  <li>Housing Benefit strategy and delivery, including Support for Mortgage Interest and supported accommodation</li>\n</ul>\n\n","role_payment_type":null,"seniority":100,"whip_organisation":{}},"document_type":"ministerial_role","links":{},"locale":"en","public_updated_at":"2024-07-26T08:56:54Z","schema_name":"role","title":"Parliamentary Under Secretary of State (Minister for Disabled People, Health and Work)","web_url":"https://www.gov.uk/government/ministers/parliamentary-under-secretary-of-state-minister-for-disabled-people-health-and-work","withdrawn":false},{"api_path":"/api/content/government/ministers/minister-of-state-disabled-people","api_url":"https://www.gov.uk/api/content/government/ministers/minister-of-state-disabled-people","base_path":"/government/ministers/minister-of-state-disabled-people","content_id":"61e0d9bf-9325-44dc-85ba-a71a4603c4d6","details":{"body":"<p>Responsibilities include:</p>\n\n<ul>\n  <li>disability policy and cross-government responsibility for disabled people</li>\n  <li>oversight of Disability Unit, and convenor of Disability Champions</li>\n  <li>work and health strategy, including sponsorship of the joint Department for Work and Pensions / Department for Health and Social Care Work and Health Unit, and disability benefit reform</li>\n  <li>disability employment, and disability employment programmes</li>\n  <li>financial support for those at risk of falling out of work, and disabled claimants including, Disability Living Allowance (<abbr title=\"Disability Living Allowance\">DLA</abbr>), Personal Independence Payment (<abbr title=\"Personal Independence Payment\">PIP</abbr>), Employment and Support Allowance (<abbr title=\"Employment and Support Allowance\">ESA</abbr>) and Carer’s Allowance (<abbr title=\"Carer's Allowance\">CA</abbr>)</li>\n  <li>Support for disadvantaged groups</li>\n  <li>Youth Offer</li>\n  <li>Government Equalities Office (<abbr title=\"Government Equalities Office\">GEO</abbr>) lead, Women and the Menopause</li>\n  <li>Military Covenant</li>\n  <li>Housing Benefit strategy and delivery, including Support for Mortgage Interest and supported accommodation</li>\n</ul>\n\n<div class=\"call-to-action\">\n  <p>Between December 2023 and April 2024 this role was carried out by the <a href=\"https://www.gov.uk/government/ministers/parliamentary-under-secretary-of-state-minister-for-disabled-people-health-and-work\">Parliamentary Under Secretary of State (Minister for Disabled People, Health and Work)</a>.</p>\n</div>\n\n","role_payment_type":null,"seniority":100,"whip_organisation":{}},"document_type":"ministerial_role","links":{},"locale":"en","public_updated_at":"2024-07-26T09:00:49Z","schema_name":"role","title":"Minister of State (Minister for Disabled People, Health and Work)","web_url":"https://www.gov.uk/government/ministers/minister-of-state-disabled-people","withdrawn":false},{"api_path":"/api/content/government/ministers/minister-of-state--192","api_url":"https://www.gov.uk/api/content/government/ministers/minister-of-state--192","base_path":"/government/ministers/minister-of-state--192","content_id":"86a981fd-00c3-487b-bf8c-fbf0205ce966","details":{"body":"<ul>\n  <li>\n    <p>Disability policy and x-Gov responsibility for disabled people </p>\n  </li>\n  <li>\n    <p>Health and disability reform </p>\n  </li>\n  <li>\n    <p>Universal Credit and Legacy Benefits Delivery </p>\n  </li>\n  <li>\n    <p>Contributory Benefits, Personal Independence Payment (PIP), Disability Living Allowance (DLA), and Employment and Support Allowance (ESA) </p>\n  </li>\n  <li>\n    <p>Carer’s Allowance (CA) </p>\n  </li>\n  <li>\n    <p>Housing </p>\n  </li>\n  <li>\n    <p>Access to Work </p>\n  </li>\n  <li>\n    <p>ALB: Health and Safety Executive </p>\n  </li>\n  <li>\n    <p>Serious Case Panel </p>\n  </li>\n  <li>\n    <p>Uprating and Benefit Cap </p>\n  </li>\n  <li>\n    <p>Oversight of Disability Unit (DU)</p>\n  </li>\n</ul>\n","role_payment_type":null,"seniority":100,"whip_organisation":{}},"document_type":"ministerial_role","links":{},"locale":"en","public_updated_at":"2025-11-18T10:18:27Z","schema_name":"role","title":"Minister of State (Minister for Social Security and Disability)","web_url":"https://www.gov.uk/government/ministers/minister-of-state--192","withdrawn":false}],"organisations":[{"analytics_identifier":"OT1309","api_path":"/api/content/gove