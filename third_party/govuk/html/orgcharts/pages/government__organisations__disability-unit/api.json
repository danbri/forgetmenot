ontact\r\n* on their helpline – 0300 123 1100\r\n\r\n<strong>Legal advice:</strong>\r\n\r\nYou can get independent legal advice by contacting:\r\n\r\n* Citizens Advice – http://www.citizensadvice.org.uk/\r\n* your local Law Centre – https://www.lawcentres.org.uk/get-help","email_addresses":null,"phone_numbers":null,"post_addresses":[],"title":"Discrimination and employment advice and support"},"document_type":"contact","links":{},"locale":"en","public_updated_at":"2024-10-17T10:56:41Z","schema_name":"contact","title":"Discrimination and employment advice and support","withdrawn":false}],"ordered_foi_contacts":[{"content_id":"63e4debe-7305-42d3-9691-a4737aa48c24","details":{"contact_form_links":null,"description":null,"email_addresses":[{"email":"foi-team@cabinetoffice.gov.uk","title":"Correspondence Team"}],"phone_numbers":null,"post_addresses":[{"iso2_country_code":"gb","locality":"London","postal_code":"SW1A 2AS","street_address":"Cabinet Office\r\n70 Whitehall","title":"Correspondence Team","world_location":"United Kingdom"}],"title":"Freedom of Information (FoI) requests"},"document_type":"contact","links":{},"locale":"en","public_updated_at":"2022-03-04T10:54:09Z","schema_name":"contact","title":"Freedom of Information (FoI) requests","withdrawn":false}],"ordered_ministers":[{"api_path":"/api/content/government/people/stephen-timms","api_url":"https://www.gov.uk/api/content/government/people/stephen-timms","base_path":"/government/people/stephen-timms","content_id":"4a73d6f8-fbab-48e1-b67b-cdf2dcb2292f","details":{"image":{"alt_text":"The Rt Hon Sir Stephen Timms MP","url":"https://assets.publishing.service.gov.uk/media/6773ddda02c3076590308cbd/s465_Stephen_Timms.jpg"},"privy_counsellor":true},"document_type":"person","links":{"role_appointments":[{"content_id":"82cac2f7-2d49-4dd3-80b8-98aaa832435f","details":{"current":true,"ended_on":null,"person_appointment_order":1,"started_on":"2024-07-08T00:00:00+01:00"},"document_type":"role_appointment","links":{"role":