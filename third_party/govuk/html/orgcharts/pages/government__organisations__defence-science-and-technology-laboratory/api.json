y","postal_code":"Wiltshire","street_address":"Dstl Headquarters\r\nPorton Down \r\n \r\n","title":"Freedom of Information and Environmental Regulations","world_location":"United Kingdom"}],"title":"Freedom of Information Requests"},"document_type":"contact","links":{},"locale":"en","public_updated_at":"2014-07-02T13:47:36Z","schema_name":"contact","title":"Freedom of Information Requests","withdrawn":false}],"ordered_high_profile_groups":[{"analytics_identifier":"OT1064","api_path":"/api/content/government/organisations/centre-for-defence-enterprise","api_url":"https://www.gov.uk/api/content/government/organisations/centre-for-defence-enterprise","base_path":"/government/organisations/centre-for-defence-enterprise","content_id":"1ec706bb-34b5-4abd-99c2-f111aa1b46e5","details":{"acronym":"CDE","brand":"ministry-of-defence","default_news_image":{"high_resolution_url":"https://assets.publishing.service.gov.uk/media/5a37db3140f0b649cfaf7c35/s960_DSTL_news.jpg","url":"https://assets.publishing.service.gov.uk/media/5a37db31ed915d5a62fdc77f/s300_DSTL_news.jpg"},"logo":{"crest":"single-identity","formatted_title":"Centre for Defence Enterprise"},"organisation_govuk_status":{"status":"replaced","updated_at":null,"url":"http://www.science.mod.uk/engagement/enterprise.aspx"}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"Centre for Defence Enterprise","web_url":"https://www.gov.uk/government/organisations/centre-for-defence-enterprise","withdrawn":false},{"analytics_identifier":"OT1349","api_path":"/api/content/government/organisations/national-cyber-force","api_url":"https://www.gov.uk/api/content/government/organisations/national-cyber-force","base_path":"/government/organisations/national-cyber-force","content_id":"4cf7deb2-1179-4211-aab8-0009176daa56","details":{"acronym":"NCF","brand":"ministry-of-justice","default_news_image":null,"logo":{"crest":"custom","formatted_title":"National <br/>Cyber Force","image":{"alt_text":"National Cyber Force","url":"https://assets.publishing.service.gov.uk/media/61ba22cfd3bf7f055d72d837/NCF_2592_MASTER_STRAPLINE_AW__1__copy_cubic.png"}},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"National Cyber Force","web_url":"https://www.gov.uk/government/organisations/national-cyber-force","withdrawn":false}],"ordered_parent_organisations":[{"analytics_identifier":"D17","api_path":"/api/content/government/organisations/ministry-of-defence","api_url":"https://www.gov.uk/api/content/government/organisations/ministry-of-defence","base_path":"/government/organisations/ministry-of-defence","content_id":"d994e55c-48c9-4795-b872-58d8ec98af12","details":{"acronym":"MOD","brand":"ministry-of-defence","default_news_image":{"high_resolution_url":"https://assets.publishing.service.gov.uk/media/63495d46d3bf7f618eda94d2/s960_ministry-of-defence-building.jpg","url":"https://assets.publishing.service.gov.uk/media/63495d468fa8f5346732690e/s300_ministry-of-defence-building.jpg"},"logo":{"crest":"mod","formatted_title":"Ministry<br/>of Defence"},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"Ministry of Defence","web_url":"https://www.gov.uk/government/organisations/ministry-of-defence","withdrawn":false}],"ordered_roles":[{"content_id":"8475256c-c0f1-11e4-8223-005056011aef","details":{"body":"<p>With direct line responsibility for members of the Executive team, the CE leads <abbr title=\"Defence Science Technology Laboratory\">Dstl</abbr> as an Executive Agency, delivering value-for-money science and technology-based support and advice to customers. This includes getting the best out of suppliers and partners, and balancing short-term delivery with long-term capability.</p>\n\n<p>The CE role is ultimately responsible for ensuring:</p>\n\n<ul>\n  <li>the financial viability of <abbr title=\"Defence Science Technology Laboratory\">Dstl</abbr>\n</li>\n  <li>that customers are satisfied</li>\n  <li>that <abbr title=\"Defence Science Technology Laboratory\">Dstl</abbr>’s staff are suitably engaged and rewarded for their contributions</li>\n</ul>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2019-01-07T13:27:07Z","schema_name":"role","title":"Chief Executive","withdrawn":false},{"content_id":"847525bc-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Capability and Delivery Director:</p>\n\n<ul>\n  <li>delivers science and technology outputs to customers, ensuring that individual products and programmes deliver benefits and quality outputs to cost and time</li>\n  <li>exploits S&amp;T investment</li>\n  <li>develops critical defence and security capabilities, drawing on internal capability and facilities, partners in other Government laboratories in the UK and overseas, and in industry and academia</li>\n</ul>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2016-05-18T10:39:30Z","schema_name":"role","title":"Capability and Delivery Director, Dstl","withdrawn":false},{"content_id":"8475260f-c0f1-11e4-8223-005056011aef","details":{"body":"<p>Technical Director:</p>\n\n<ul>\n  <li>establishes and maintains appropriate relationships across the stakeholder community to develop a sound understanding of both the S&amp;T landscape and the defence and security context to inform and define <abbr title=\"Defence Science Technology Laboratory\">Dstl</abbr> Technical Strategy</li>\n  <li>co-ordinates input from other Executive members to produce the Corporate Plan and Business Plan</li>\n</ul>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2018-05-23T11:20:24Z","schema_name":"role","title":"Technical Director, Dstl","withdrawn":false},{"content_id":"8475265f-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Finance Director:</p>\n\n<ul>\n  <li>provides strategic financial advice to underpin strategic aims and policies</li>\n  <li>defines robust, rigorous controls for effective financial management which provides return on investment</li>\n</ul>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2015-05-19T14:38:57Z","schema_name":"role","title":"Finance Director, Dstl","withdrawn":false},{"content_id":"847526af-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Chair leads the <abbr title=\"Defence Science and Technology Laboratory\">Dstl</abbr> Board. The Board’s role is to support and constructively challenge the <abbr title=\"Defence Science and Technology Laboratory\">Dstl</abbr> executive in the development of business strategies, plans, business cases and targets, and to monitor <abbr title=\"Defence Science and Technology Laboratory\">Dstl</abbr>’s business performance against the approved corporate plan.</p>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2020-12-21T16:33:11Z","schema_name":"role","title":"Chair","withdrawn":false},{"content_id":"e9ad6609-3f04-414d-b0c8-3da14d5e1992","details":{"body":"<p>The Infrastructure Director:</p>\n\n<ul>\n  <li>provides the core infrastructure and enabling services required to deliver Dstl’s strategic aims and policies</li>\n  <li>defines and provides systems and processes to achieve the Knowledge, Information and Data Management requirements</li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2017-03-31T14:44:01Z","schema_name":"role","title":"Infrastructure Director, Dstl","withdrawn":false},{"content_id":"4ea11c19-d9fb-4cd8-9c8d-7f12d36d43c3","details":{"body":"<p>The Chief People Officer provides strategic ‘people’ advice to underpin strategic aims and policies, and defines leadership and people management required to ensure effective delivery of <abbr title=\"Defence Science and Technology Laboratory\">Dstl</abbr>’s strategic aims.</p>\n\n<p>The Chief People Office leads <abbr title=\"Defence Science and Technology Laboratory\">Dstl</abbr> People, which includes talent acquisition and planning, science and technology careers, employee relations, organisational development, HR business partnering and employee experience. It also includes <abbr title=\"Defence Science and Technology Laboratory\">Dstl</abbr>’s communications function, which enables <abbr title=\"Defence Science and Technology Laboratory\">Dstl</abbr> to create maximum impact through connecting with our key audiences.</p>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2024-04-22T14:34:16Z","schema_name":"role","title":"Chief People Officer","withdrawn":false},{"content_id":"bf8af840-d2f0-4b01-aca3-e62e642de50b","details":{"body":"<p>The Transformation Director:</p>\n\n<ul>\n  <li>champions transformation and co-ordinates <abbr title=\"Defence Science and Technology Laboratory\">Dstl</abbr>’s portfolio of change</li>\n  <li>acts as the focus for <abbr title=\"Defence Science and Technology Laboratory\">Dstl</abbr>’s suite of transformation activities, defining a cohesive policy and methods for achieving business transformation</li>\n  <li>plans appropriate interventions and projects to achieve the changes set out in the Corporate and Business plans</li>\n</ul>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2017-03-31T14:44:01Z","schema_name":"role","title":"Transformation Director, Dstl","withdrawn":false},{"content_id":"c8a812eb-7eff-4186-9649-35dfd7526175","details":{"body":"<p>The Transformation Director:</p>\n\n<ul>\n  <li>champions transformation and co-ordinates <abbr title=\"Defence Science and Technology Laboratory\">Dstl</abbr>’s portfolio of change</li>\n  <li>acts as the focus for <abbr title=\"Defence Science and Technology Laboratory\">Dstl</abbr>’s suite of transformation activities, defining a cohesive policy and methods for achieving business transformation</li>\n  <li>plans appropriate interventions and projects to achieve the changes set out in the Corporate and Business plans</li>\n</ul>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2017-03-31T14:44:01Z","schema_name":"role","title":"Transformation Director, Dstl","withdrawn":false},{"content_id":"21400abf-5399-4e8b-970b-1e798ba0f611","details":{"body":"<p>With direct line responsibility for members of the Executive team, the Chief Executive leads <abbr title=\"Defence Science Technology Laboratory\">Dstl</abbr> as an Executive Agency, delivering value-for-money science and technology-based support and advice to customers. This includes getting the best out of suppliers and partners, and balancing short-term delivery with long-term capability.</p>\n\n<p>The Chief Executive is ultimately responsible for ensuring:</p>\n\n<ul>\n  <li>the financial viability of <abbr title=\"Defence Science Technology Laboratory\">Dstl</abbr>\n</li>\n  <li>that customers are satisfied</li>\n  <li>that <abbr title=\"Defence Science Technology Laboratory\">Dstl</abbr>’s staff are suitably engaged and rewarded for their contributions</li>\n</ul>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2022-02-14T09:45:31Z","schema_name":"role","title":"Interim Chief Executive","withdrawn":false},{"content_id":"36cf541d-bd92-41ff-9420-73c2917e0d86","details":{"body":"<p>The Chief Finance Officer is responsible for Dstl’s Finance, Strategy and Governance Division.</p>\n\n<p>The purpose of this Division is to manage and oversee all aspects of financial management within Dstl, to develop Dstl’s corporate strategies and plans, to maintain and operate the governance framework within Dstl, including Dstl’s approach to risk management, to oversee Dstl’s corporate performance regime, and to deliver a complete intellectual property management service for Dstl.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2018-07-30T14:51:13Z","schema_name":"role","title":"Chief Finance Officer","withdrawn":false},{"content_id":"59e79e8e-bdc4-4e9e-9452-16b0392a66a7","details":{"body":"<p>The Chief Operating Officer is responsible for leading a range of Dstl’s core business enabling operations which include health, safety and environmental protection, facilities and infrastructure (including the National Biosecurity Centre Programme), technical services, data and digital services, security and resilience.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2026-02-17T11:46:35Z","schema_name":"role","title":"Chief Operating Officer","withdrawn":false},{"content_id":"f64b6e38-d8e8-4dae-b0f4-f3ea600de1e5","details":{"body":"<p>The Chief Science and Technology Officer is responsible for effective leadership of coherent, enterprise-level science and technology portfolio delivery and capability stewardship, through provision of constructive challenge, support and direction to delivery business units.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2024-12-02T10:33:43Z","schema_name":"role","title":"Chief Science and Technology Officer","withdrawn":false},{"content_id":"4bb34c9d-a478-4d87-871a-c157f2367365","details":{"body":"<p>A member of <abbr title=\"Defence Science and Technology Laboratory\">Dstl</abbr>’s Executive team, the Head of <abbr title=\"Counter-Terrorism and Security\">CTS</abbr> Division is responsible for leading the delivery of science and technology to support the UK government in the fight against crime and terrorism.</p>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2021-02-15T16:46:27Z","schema_name":"role","title":"Head, Counter-Terrorism and Security (CTS)","withdrawn":false},{"content_id":"cf74bb36-0ca1-4434-bd92-32fd5df6e861","details":{"body":"<p>A member of <abbr title=\"Defence Science and Technology Laboratory\">Dstl</abbr>’s Executive team, the Head of <abbr title=\"Defence and Security Analysis\">DSA</abbr> Division leads a team which shapes Defence, Security and national resilience through analysis and evidence; identifies, develops and exploits game-changing technology; and maximises human capability.</p>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2021-02-15T17:02:30Z","schema_name":"role","title":"Head, Defence and Security Analysis (DSA)","withdrawn":false},{"content_id":"9be6bd72-5d1f-490a-a960-93bdc26c3b9a","details":{"body":"<p>A member of Dstl’s Executive team, the Head of <abbr title=\"Cyber and Information Systems\">CIS</abbr> Division leads a team which maintains and develops a range of capabilities needed to support Defence in data, cyber, <abbr title=\"Command, Control, Communication and Computers, Intelligence, Surveillance and Reconnaissance\">C4ISR</abbr> and space related areas, both now and in the future.</p>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2021-02-16T09:29:28Z","schema_name":"role","title":"Head, Cyber and Information Systems (CIS)","withdrawn":false},{"content_id":"48b1fcd4-7ccd-4372-91e9-39f62cbc539e","details":{"body":"<p>A member of <abbr title=\"Defence Science and Technology Laboratory\">Dstl</abbr>’s Executive team, the Head of Platform Systems Division is responsible for leading and directing all aspects of <abbr title=\"science and technology\">S&amp;T</abbr> that develop the <abbr title=\"United Kingdom\">UK</abbr>’s battle-winning edge. The Division leads on the development of all new military Platforms and all types of Mission and Weapons systems. It identifies where common Defence problems or gaps are found across an entire system or across Front Line Commands and then solving them once, in a way that can be applied as widely as possible.</p>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2021-02-16T09:31:41Z","schema_name":"role","title":"Head, Platform Systems","withdrawn":false},{"content_id":"eb72a9ef-6b27-4d66-8ffa-8d75fb0c4cdf","details":{"body":"<p>A member of <abbr title=\"Defence Science and Technology Laboratory\">Dstl</abbr>’s Executive team, the Head of <abbr title=\"Chemical, Biological and Radiological Sciences\">CBR</abbr> Division is responsible for leading and directing teams covering an integrated Chemistry, Biology, Radiation and Medical Sciences capability. The Division delivers longer term research as well as short term advice and consultancy, and supports both the Front Line Commands and wider Government.</p>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2021-02-15T17:08:29Z","schema_name":"role","title":"Head, Chemical, Biological and Radiological Sciences (CBR)","withdrawn":false},{"content_id":"1cf9ae01-81e6-499c-90f1-70ca48af4501","details":{"body":"<p>A member of Dstl’s Executive team, the Head of Exploration Division leads a team that identifies and accelerates transformative technologies, systems, concepts and strategies for defence and security.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2021-05-04T16:13:46Z","schema_name":"role","title":"Head, Exploration Division","withdrawn":false},{"content_id":"f434f8b6-2190-4f60-b0ea-7d2e0a41efa5","details":{"body":"<p>The Chief Delivery Officer (<abbr title=\"Chief Delivery Officer\">CDO</abbr>) is accountable to the <abbr title=\"Defence Science and Technology Laboratory\">Dstl</abbr> Chief Executive for the delivery of the billion-pound science and technology portfolio, delivering an agreed portfolio of work to provide high impact, innovative and cost effective capability solutions in support of defence and security’s highest priority requirements. Heading up the Delivery Directorate, the <abbr title=\"Chief Delivery Officer\">CDO</abbr> ensures the correct triage, planning and prioritisation takes place, engaging with customers and the supply chain to shape and deliver future demand through the most appropriate routes.</p>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2024-04-15T12:24:37Z","schema_name":"role","title":"Chief Delivery Officer","withdrawn":false}],"organisations":[{"analytics_identifier":"EA42","api_path":"/api/content/government/organisations/defence-science-and-technology-laboratory","api_url":"https://www.gov.uk/api/content/government/organisations/defence-science-and-technology-laboratory","base_path":"/government/organisations/defence-science-and-technology-laboratory","content_id":"43b6c342-c6b7-4ef1-93d2-98f0a9130ccc","details":{"acronym":"Dstl","brand":"ministry-of-defence","default_news_image":{"high_resolution_url":"https://assets.publishing.service.gov.uk/media/67910211cf977e4bf9a2f176/s960_Dstl_delivering_mission_success_960x640.png","url":"https://assets.publishing.service.gov.uk/media/67910211b1e4f5cbd3a34ded/s300_Dstl_delivering_mission_success_960x640.png"},"logo":{"crest":"custom","formatted_title":"Defence Science and Technology Laboratory","image":{"alt_text":"Defence Science and Technology Laboratory","url":"https://assets.publishing.service.gov.uk/media/6791021120bce57216a2f17a/Dstl_delivering_mission_success_960x640.png"}},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"