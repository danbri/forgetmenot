ice.gov.uk/media/5a37da9ded915d5a5f965f9c/s300_cabinet-office.jpg"},"logo":{"crest":"single-identity","formatted_title":"Cabinet Office"},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"Cabinet Office","web_url":"https://www.gov.uk/government/organisations/cabinet-office","withdrawn":false}]},"locale":"en","public_updated_at":"2024-07-12T09:15:13Z","schema_name":"role","title":"Paymaster General","web_url":"https://www.gov.uk/government/ministers/paymaster-general","withdrawn":false}]},"locale":"en","public_updated_at":"2024-07-08T10:21:04Z","schema_name":"role_appointment","title":"The Rt Hon Nick Thomas–Symonds MP - Paymaster General","withdrawn":false},{"content_id":"130f0d23-a0e0-4865-953f-610855efad52","details":{"current":false,"ended_on":"2024-07-05T00:00:00+01:00","person_appointment_order":5,"started_on":"2023-11-13T00:00:00+00:00"},"document_type":"role_appointment","links":{"person":[{"api_path":"/api/content/government/people/john-glen","api_url":"https://www.gov.uk/api/content/government/people/john-glen","base_path":"/government/people/john-glen","content_id":"bd1b94ef-9392-4ca4-aed8-0135bcd9ec46","details":{"body":"<p>John Glen was Paymaster General and Minister for the Cabinet Office between 13 November 2023 and 5 July 2024.</p>\n\n<p>He was previously Chief Secretary to the Treasury between 25 October 2022 and 13 November 2023.</p>\n\n<p>He was also Minister of State (Economic Secretary) to the Treasury between 17 September 2021 and 6 July 2022.</p>\n\n<p>He was City Minister between 9 January 2018 and 6 July 2022.</p>\n\n<p>He was Economic Secretary to the Treasury between 9 January 2018 and 16 September 2021.</p>\n\n<p>He was Parliamentary Under Secretary of State for the Department for Culture, Media and Sport from 14 June 2017 to 8 January 2018.</p>\n\n<p>He was Parliamentary Private Secretary to Philip Hammond from July 2016 until June 2017.</p>\n\n<h2 id=\"political-career\">Political career</h2>\n\n<p>John Glen was first elected to Parliament as the Conservative MP for Salisbury in 2010.</p>\n\n<p>He previously worked for the Eric Pickles and Sajid Javid as a Parliamentary Private Secretary.</p>\n","image":{"alt_text":"The Rt Hon John Glen MP","url":"https://assets.publishing.service.gov.uk/media/5a4f6a2040f0b648c7221bdc/s465_John_Glen_GOVUK.jpg"}},"document_type":"person","links":{},"locale":"en","public_updated_at":"2024-07-18T10:14:10Z","schema_name":"person","title":"The Rt Hon John Glen MP","web_url":"https://www.gov.uk/government/people/john-glen","withdrawn":false}],"role":[{"api_path":"/api/content/government/ministers/paymaster-general","api_url":"https://www.gov.uk/api/content/government/ministers/paymaster-general","base_path":"/government/ministers/paymaster-general","content_id":"1647e073-8e16-4944-85f4-cf665ce21cba","details":{"body":"\n","role_payment_type":null,"seniority":5,"whip_organisation":{}},"document_type":"ministerial_role","links":{"ordered_parent_organisations":[{"analytics_identifier":"D2","api_path":"/api/content/government/organisations/cabinet-office","api_url":"https://www.gov.uk/api/content/government/organisations/cabinet-office","base_path":"/government/organisations/cabinet-office","content_id":"96ae61d6-c2a1-48cb-8e67-da9d105ae381","details":{"acronym":"","brand":"cabinet-office","default_news_image":{"high_resolution_url":"https://assets.publishing.service.gov.uk/media/5a37da9d40f0b649cfaf7b27/s960_cabinet-office.jpg","url":"https://assets.publishing.service.gov.uk/media/5a37da9ded915d5a5f965f9c/s300_cabinet-office.jpg"},"logo":{"crest":"single-identity","formatted_title":"Cabinet Office"},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"Cabinet Office","web_url":"https://www.gov.uk/government/organisations/cabinet-office","withdrawn":false}]},"locale":"en","public_updated_at":"2024-07-12T09:15:13Z","schema_name":"role","title":"Paymaster General","web_url":"https://www.gov.uk/government/ministers/paymaster-general","withdrawn":false}]},"locale":"en","public_updated_at":"2024-07-05T11:42:35Z","schema_name":"role_appointment","title":"The Rt Hon John Glen - Paymaster General","withdrawn":false},{"content_id":"fc7e6aaa-8c20-47db-8f98-1c65d21bb955","details":{"current":false,"ended_on":"2023-11-13T00:00:00+00:00","person_appointment_order":7,"started_on":"2022-10-25T00:00:00+01:00"},"document_type":"role_appointment","links":{"person":[{"api_path":"/api/content/government/people/jeremy-quin","api_url":"https://www.gov.uk/api/content/government/people/jeremy-quin","base_path":"/government/people/jeremy-quin","content_id":"35581511-38d0-46bf-ac08-a4ccc7ab8528","details":{"body":"<p>Jeremy Quin was previously Paymaster General and Minister for the Cabinet Office between 25 October 2022 and 13 November 2023.</p>\n\n<p>He was Minister of State (Minister for Crime, Policing and Fire) at the Home Office between 7 September 2022 and 25 October 2022.</p>\n\n<p>He was Minister of State (Minister for Defence Procurement) at the Ministry of Defence between 13 February 2020 and 7 September 2022.</p>\n\n<p>In December 2019, Jeremy became Parliamentary Secretary in the Cabinet Office with responsibilities for the Government Commercial Function and other cross-government programmes.</p>\n\n<p>In July 2018, Jeremy accepted a role in the Government as a member of the Whips’ Office and was promoted to serve as a senior Whip (as “Comptroller of Her Majesty’s Household”) in July 2019.</p>\n\n<p>In 2008 to 2009, he served on secondment as senior corporate finance adviser to HM Treasury, assisting them on the UK’s response to the financial crisis.</p>\n\n<p>Before entering politics, Jeremy worked in corporate finance for 25 years latterly as Managing Director of Deutsche Bank.</p>\n\n","image":{"alt_text":"The Rt Hon Jeremy Quin","url":"https://assets.publishing.service.gov.uk/media/635b97908fa8f5653ba074dc/s465_Untitled.jpg"}},"document_type":"person","links":{},"locale":"en","public_updated_at":"2024-05-30T12:06:58Z","schema_name":"person","title":"The Rt Hon Jeremy Quin","web_url":"https://www.gov.uk/government/people/jeremy-quin","withdrawn":false}],"role":[{"api_path":"/api/content/government/ministers/paymaster-general","api_url":"https://www.gov.uk/api/content/government/ministers/paymaster-general","base_path":"/government/ministers/paymaster-general","content_id":"1647e073-8e16-4944-85f4-cf665ce21cba","details":{"body":"\n","role_payment_type":null,"seniority":5,"whip_organisation":{}},"document_type":"ministerial_role","links":{"ordered_parent_organisations":[{"analytics_identifier":"D2","api_path":"/api/content/government/organisations/cabinet-office","api_url":"https://www.gov.uk/api/content/government/organisations/cabinet-office","base_path":"/government/organisations/cabinet-office","content_id":"96ae61d6-c2a1-48cb-8e67-da9d105ae381","details":{"acronym":"","brand":"cabinet-office","default_news_image":{"high_resolution_url":"https://assets.publishing.service.gov.uk/media/5a37da9d40f0b649cfaf7b27/s960_cabinet-office.jpg","url":"https://assets.publishing.service.gov.uk/media/5a37da9ded915d5a5f965f9c/s300_cabinet-office.jpg"},"logo":{"crest":"single-identity","formatted_title":"Cabinet Office"},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"Cabinet Office","web_url":"https://www.gov.uk/government/organisations/cabinet-office","withdrawn":false}]},"locale":"en","public_updated_at":"2024-07-12T09:15:13Z","schema_name":"role","title":"Paymaster General","web_url":"https://www.gov.uk/government/ministers/paymaster-general","withdrawn":false}]},"locale":"en","public_updated_at":"2023-11-13T16:16:38Z","schema_name":"role_appointment","title":"The Rt Hon Jeremy Quin MP - Paymaster General","withdrawn":false},{"content_id":"3a37fb24-6dbc-41dc-bf52-b6cf942eb933","details":{"current":false,"ended_on":"2022-10-25T00:00:00+01:00","person_appointment_order":8130,"started_on":"2022-10-14T00:00:00+01:00"},"document_type":"role_appointment","links":{"person":[{"api_path":"/api/content/government/people/chris-philp-mp","api_url":"https://www.gov.uk/api/content/government/people/chris-philp-mp","base_path":"/government/people/chris-philp-mp","content_id":"c994572d-c140-41b2-b692-16f429455a76","details":{"body":"<p>Chris Philp was Minister of State in the Home Office between 26 October 2022 and 5 July 2024.</p>\n\n<p>He was Paymaster General and Minister for the Cabinet Office between 14 October 2022 and 25 October 2022.</p>\n\n<p>He was previously appointed Chief Secretary to the Treasury from 6 September 2022 to 14 October 2022.</p>\n\n<p>He was previously Parliamentary Under Secretary of State at the Department for Digital, Culture, Media and Sport between 17 September 2021 and 7 July 2022.</p>\n\n<p>He was Parliamentary Under Secretary of State at the Home Office and Ministry of Justice from 13 February 2020 to 16 September 2021.</p>\n\n<p>Before that, he was Parliamentary Under Secretary of State at the Ministry of Justice from 10 September 2019 to 18 December 2019 and Minister for London at the Ministry of Housing, Communities and Local Government from 18 December 2019 to 13 February 2020.</p>\n","image":{"alt_text":"The Rt Hon Chris Philp MP","url":"https://assets.publishing.service.gov.uk/media/5d78b28d40f0b61cfe01b502/s465_Chris-Philp.png"}},"document_type":"person","links":{},"locale":"en","public_updated_at":"2024-07-18T10:23:58Z","schema_name":"person","title":"The Rt Hon Chris Philp MP","web_url":"https://www.gov.uk/government/people/chris-philp-mp","withdrawn":false}],"role":[{"api_path":"/api/content/government/ministers/paymaster-general","api_url":"https://www.gov.uk/api/content/government/ministers/paymaster-general","base_path":"/government/ministers/paymaster-general","content_id":"1647e073-8e16-4944-85f4-cf665ce21cba","details":{"body":"\n","role_payment_type":null,"seniority":5,"whip_organisation":{}},"document_type":"ministerial_role","links":{"ordered_parent_organisations":[{"analytics_identifier":"D2","api_path":"/api/content/government/organisations/cabinet-office","api_url":"https://www.gov.uk/api/content/government/organisations/cabinet-office","base_path":"/government/organisations/cabinet-office","content_id":"96ae61d6-c2a1-48cb-8e67-da9d105ae381","details":{"acronym":"","brand":"cabinet-office","default_news_image":{"high_resolution_url":"https://assets.publishing.service.gov.uk/media/5a37da9d40f0b649cfaf7b27/s960_cabinet-office.jpg","url":"https://assets.publishing.service.gov.uk/media/5a37da9ded915d5a5f965f9c/s300_cabinet-office.jpg"},"logo":{"crest":"single-identity","formatted_title":"Cabinet Office"},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"Cabinet Office","web_url":"https://www.gov.uk/government/organisations/cabinet-office","withdrawn":false}]},"locale":"en","public_updated_at":"2024-07-12T09:15:13Z","schema_name":"role","title":"Paymaster General","web_url":"https://www.gov.uk/government/ministers/paymaster-general","withdrawn":false}]},"locale":"en","public_updated_at":"2022-10-25T18:42:09Z","schema_name":"role_appointment","title":"The Rt Hon Chris Philp MP - Paymaster General","withdrawn":false},{"content_id":"b7a907c1-1b05-45ab-9d1c-2a6e561d70c5","details":{"current":false,"ended_on":"2022-10-14T00:00:00+01:00","person_appointment_order":7972,"started_on":"2022-09-06T00:00:00+01:00"},"document_type":"role_appointment","links":{"person":[{"api_path":"/api/content/government/people/edward-argar","api_url":"https://www.gov.uk/api/content/government/people/edward-argar","base_path":"/government/people/edward-argar","content_id":"d2e96f52-b32f-4d1d-bc97-afe1e1e6ffae","details":{"body":"<p>Edward Argar was Minister of State at the Ministry of Justice between 27 October 2022 and 5 July 2024.</p>\n\n<p>He was previously Chief Secretary to the Treasury between 14 October 2022 and 27 October 2022 and was Paymaster General and Minister for the Cabinet Office between 6 September 2022 and 14 October 2022.</p>\n\n<p>He was Minister of State at the Department of Health and Social Care between 10 September 2019 and 6 July 2022.</p>\n\n<p>He was previously Parliamentary Under Secretary of State at the Ministry of Justice between 14 June 2018 and 10 September 2019.</p>\n\n<p>He was elected as Conservative MP for Charnwood in 2015.</p>\n","image":{"alt_text":"The Rt Hon Edward Argar MP","url":"https://assets.publishing.service.gov.uk/media/5b22a68940f0b634d557b009/s465_edward-argar-960x640.jpg"}},"document_type":"person","links":{},"locale":"en","public_updated_at":"2024-07-18T10:27:37Z","schema_name":"person","title":"The Rt Hon Edward Argar MP","web_url":"https://www.gov.uk/government/people/edward-argar","withdrawn":false}],"role":[{"api_path":"/api/content/government/ministers/paymaster-general","api_url":"https://www.gov.uk/api/content/government/ministers/paymaster-general","base_path":"/government/ministers/paymaster-general","content_id":"1647e073-8e16-4944-85f4-cf665ce21cba","details":{"body":"\n","role_payment_type":null,"seniority":5,"whip_organisation":{}},"document_type":"ministerial_role","links":{"ordered_parent_organisations":[{"analytics_identifier":"D2","api_path":"/api/content/government/organisations/cabinet-office","api_url":"https://www.gov.uk/api/content/government/organisations/cabinet-office","base_path":"/government/organisations/cabinet-office","content_id":"96ae61d6-c2a1-48cb-8e67-da9d105ae381","details":{"acronym":"","brand":"cabinet-office","default_news_image":{"high_resolution_url":"https://assets.publishing.service.gov.uk/media/5a37da9d40f0b649cfaf7b27/s960_cabinet-office.jpg","url":"https://assets.publishing.service.gov.uk/media/5a37da9ded915d5a5f965f9c/s300_cabinet-office.jpg"},"logo":{"crest":"single-identity","formatted_title":"Cabinet Office"},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"Cabinet Office","web_url":"https://www.gov.uk/government/organisations/cabinet-office","withdrawn":false}]},"locale":"en","public_updated_at":"2024-07-12T09:15:13Z","schema_name":"role","title":"Paymaster General","web_url":"https://www.gov.uk/government/ministers/paymaster-general","withdrawn":false}]},"locale":"en","public_updated_at":"2022-10-14T13:05:34Z","schema_name":"role_appointment","title":"The Rt Hon Edward Argar MP - Paymaster General","withdrawn":false},{"content_id":"acbcf438-1ca7-492b-bfd0-95ff77c893f7","details":{"current":false,"ended_on":"2022-09-06T00:00:00+01:00","person_appointment_order":7131,"started_on":"2021-09-16T00:00:00+01:00"},"document_type":"role_appointment","links":{"person":[{"api_path":"/api/content/government/people/michael-ellis","api_url":"https://www.gov.uk/api/content/government/people/michael-ellis","base_path":"/government/people/michael-ellis","content_id":"5f0540df-1651-44b8-9032-54eee7692867","details":{"body":"<p>The Rt Hon Michael Ellis KC was Attorney General between 6 September and 25 October 2022.</p>\n\n<p>He was previously Paymaster General from 16 September 2021 to 6 September 2022. He was also Minister for the Cabinet Office from 8 February 2022 to 6 September 2022.</p>\n\n<p>He was Solicitor General from 26 July 2019 to 2 March 2021, and re-appointed to that role from 10 September 2021 to 15 September 2021. He was Attorney General from 2 March 2021 to 10 September 2021 while Suella Braverman was designated as a Minister on Leave.</p>\n\n<p>He was previously Minister of State at the Department for Transport from 23 May 2019 to 25 July 2019. He was Parliamentary Under Secretary of State at the Department for Digital, Culture, Media and Sport from January 2018 to May 2019.</p>\n\n<p>He was Deputy Leader of the House of Commons from 17 July 2016 to 8 January 2018.</p>\n\n<p>He was elected Conservative MP for Northampton North in May 2010.</p>\n","image":{"alt_text":"The Rt Hon Michael Ellis KC","url":"https://assets.publishing.service.gov.uk/media/5ce6a39840f0b6209b04c3ce/s465_Michael_Ellis_MP_960x640.jpg"}},"document_type":"person","links":{},"locale":"en","public_updated_at":"2024-05-30T13:04:24Z","schema_name":"person","title":"The Rt Hon Michael Ellis KC","web_url":"https://www.gov.uk/government/people/michael-ellis","withdrawn":false}],"role":[{"api_path":"/api/content/government/ministers/paymaster-general","api_url":"https://www.gov.uk/api/content/government/ministers/paymaster-general","base_path":"/government/ministers/paymaster-general","content_id":"1647e073-8e16-4944-85f4-cf665ce21cba","details":{"body":"\n","role_payment_type":null,"seniority":5,"whip_organisation":{}},"document_type":"ministerial_role","links":{"ordered_parent_organisations":[{"analytics_identifier":"D2","api_path":"/api/content/government/organisations/cabinet-office","api_url":"https://www.gov.uk/api/content/government/organisations/cabinet-office","base_path":"/government/organisations/cabinet-office","content_id":"96ae61d6-c2a1-48cb-8e67-da9d105ae381","details":{"acronym":"","brand":"cabinet-office","default_news_image":{"high_resolution_url":"https://assets.publishing.service.gov.uk/media/5a37da9d40f0b649cfaf7b27/s960_cabinet-office.jpg","url":"https://assets.publishing.service.gov.uk/media/5a37da9ded915d5a5f965f9c/s300_cabinet-office.jpg"},"logo":{"crest":"single-identity","formatted_title":"Cabinet Office"},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"Cabinet Office","web_url":"https://www.gov.uk/government/organisations/cabinet-office","withdrawn":false}]},"locale":"en","public_updated_at":"2024-07-12T09:15:13Z","schema_name":"role","title":"Paymaster General","web_url":"https://www.gov.uk/government/ministers/paymaster-general","withdrawn":false}]},"locale":"en","public_updated_at":"2022-09-06T21:48:46Z","schema_name":"role_appointment","title":"The Rt Hon Michael Ellis QC MP - Paymaster General","withdrawn":false},{"content_id":"24109932-5ecb-4544-8636-81def7b6fc3d","details":{"current":false,"ended_on":"2021-09-15T00:00:00+01:00","person_appointment_order":6028,"started_on":"2020-02-13T00:00:00+00:00"},"document_type":"role_appointment","links":{"person":[{"api_path":"/api/content/government/people/penny-mordaunt","api_url":"https://www.gov.uk/api/content/government/people/penny-mordaunt","base_path":"/government/people/penny-mordaunt","content_id":"85401413-c0f1-11e4-8223-005056011aef","details":{"body":"<p>Penny Mordaunt was Lord President of the Council and Leader of the House of Commons between 6 September 2022 and 5 July 2024.</p>\n\n<p>Previously she was Minister of State at the Department for International Trade from 16 September 2021 to 6 September 2022. She was the department’s ministerial disability champion.</p>\n\n<p>Penny was an MP from 2010 to 2024.</p>\n\n<p>Her previous positions include:</p>\n\n<ul>\n  <li>Paymaster General (2020), leading resilience work overhauling how the UK prepares and responds to threats and has bolstered the UKs defensive cyber security</li>\n  <li>Secretary of State for Defence (2019), the first woman to hold the post</li>\n  <li>Secretary of State for International Development (2017)</li>\n  <li>Minister for Disabled People, Health and Work (2016)</li>\n  <li>Minister for the Armed Forces (2015), the first woman to hold this position</li>\n  <li>Minister of Local Government (2014)</li>\n</ul>\n\n<p>She is also a former Governor at the World Bank.</p>\n","image":{"alt_text":"The Rt Hon Penny Mordaunt","url":"https://assets.publishing.service.gov.uk/media/5cd1904ee5274a34e5be581c/s465_Penny_Gov.uk_image.jpg"}},"document_type":"person","links":{},"locale":"en","public_updated_at":"2024-07-18T09:48:35Z","schema_name":"person","title":"The Rt Hon Penny Mordaunt","web_url":"https://www.gov.uk/government/people/penny-mordaunt","withdrawn":false}],"role":[{"api_path":"/api/content/government/ministers/paymaster-general","api_url":"https://www.gov.uk/api/content/government/ministers/paymaster-general","base_path":"/government/ministers/paymaster-general","content_id":"1647e073-8e16-4944-85f4-cf665ce21cba","details":{"body":"\n","role_payment_type":null,"seniority":5,"whip_organisation":{}},"document_type":"ministerial_role","links":{"ordered_parent_organisations":[{"analytics_identifier":"D2","api_path":"/api/content/government/organisations/cabinet-office","api_url":"https://www.gov.uk/api/content/government/organisations/cabinet-office","base_path":"/government/organisations/cabinet-office","content_id":"96ae61d6-c2a1-48cb-8e67-da9d105ae381","details":{"acronym":"","brand":"cabinet-office","default_news_image":{"high_resolution_url":"https://assets.publishing.service.gov.uk/media/5a37da9d40f0b649cfaf7b27/s960_cabinet-office.jpg","url":"https://assets.publishing.service.gov.uk/media/5a37da9ded915d5a5f965f9c/s300_cabinet-office.jpg"},"logo":{"crest":"single-identity","formatted_title":"Cabinet Office"},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"Cabinet Office","web_url":"https://www.gov.uk/government/organisations/cabinet-office","withdrawn":false}]},"locale":"en","public_updated_at":"2024-07-12T09:15:13Z","schema_name":"role","title":"Paymaster General","web_url":"https://www.gov.uk/government/ministers/paymaster-general","withdrawn":false}]},"locale":"en","public_updated_at":"2021-09-16T08:42:53Z","schema_name":"role_appointment","title":"The Rt Hon Penny Mordaunt MP - Paymaster General","withdrawn":false},{"content_id":"3d2d8bd2-68ba-4e38-80c9-a223fdc75cb2","details":{"current":false,"ended_on":"2020-02-13T00:00:00+00:00","person_appointment_order":6119,"started_on":"2019-07-24T00:00:00+01:00"},"document_type":"role_appointment","links":{"person":[{"api_path":"/api/content/government/people/dowden","api_url":"https://www.gov.uk/api/content/government/people/dowden","base_path":"/government/people/dowden","content_id":"b31832cf-d095-49d4-955b-749e46248593","details":{"body":"<p>Oliver Dowden CBE was Chancellor of the Duchy of Lancaster from 25 October 2022 to 5 July 2024. He was Secretary of State in the Cabinet Office from 9 February 2023 to 5 July 2024 and Deputy Prime Minister from 21 April 2023 to 5 July 2024.</p>\n\n<p>He was previously Minister without Portfolio, Cabinet Office between 15 September 2021 and June 2022, Secretary of State for Digital, Culture, Media and Sport between 13 February 2020 and 15 September 2021, Paymaster General and Minister for the Cabinet Office from 24 July 2019 to 13 February 2020, and Parliamentary Secretary at the Cabinet Office from 9 January 2018 to 24 July 2019.</p>\n\n<p>He was elected Conservative MP for Hertsmere in May 2015.</p>\n","image":{"alt_text":"The Rt Hon Oliver Dowden CBE MP","url":"https://assets.publishing.service.gov.uk/media/5a5cb53eed915d140f028e68/s465_Oliver_Dowden_1.jpg"}},"document_type":"person","links":{},"locale":"en","public_updated_at":"2024-07-18T09:23:45Z","schema_name":"person","title":"The Rt Hon Oliver Dowden CBE MP","web_url":"https://www.gov.uk/government/people/dowden","withdrawn":false}],"role":[{"api_path":"/api/content/government/ministers/paymaster-general","api_url":"https://www.gov.uk/api/content/government/ministers/paymaster-general","base_path":"/government/ministers/paymaster-general","content_id":"1647e073-8e16-4944-85f4-cf665ce21cba","details":{"body":"\n","role_payment_type":null,"seniority":5,"whip_organisation":{}},"document_type":"ministerial_role","links":{"ordered_parent_organisations":[{"analytics_identifier":"D2","api_path":"/api/content/government/organisations/cabinet-office","api_url":"https://www.gov.uk/api/content/government/organisations/cabinet-office","base_path":"/government/organisations/cabinet-office","content_id":"96ae61d6-c2a1-48cb-8e67-da9d105ae381","details":{"acronym":"","brand":"cabinet-office","default_news_image":{"high_resolution_url":"https://assets.publishing.service.gov.uk/media/5a37da9d40f0b649cfaf7b27/s960_cabinet-office.jpg","url":"https://assets.publishing.service.gov.uk/media/5a37da9ded915d5a5f965f9c/s300_cabinet-office.jpg"},"logo":{"crest":"single-identity","formatted_title":"Cabinet Office"},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"Cabinet Office","web_url":"https://www.gov.uk/government/organisations/cabinet-office","withdrawn":false}]},"locale":"en","public_updated_at":"2024-07-12T09:15:13Z","schema_name":"role","title":"Paymaster General","web_url":"https://www.gov.uk/government/ministers/paymaster-general","withdrawn":false}]},"locale":"en","public_updated_at":"2020-03-04T13:45:59Z","schema_name":"role_appointment","title":"The Rt Hon Oliver Dowden CBE MP - Paymaster General","withdrawn":false},{"content_id":"fb323ff5-56b0-4d23-9425-32a84035dfc4","details":{"current":false,"ended_on":"2019-07-24T00:00:00+01:00","person_appointment_order":5471,"started_on":"2019-05-23T00:00:00+01:00"},"document_type":"role_appointment","links":{"person":[{"api_path":"/api/content/government/people/jesse-norman","api_url":"https://www.gov.uk/api/content/government/people/jesse-norman","base_path":"/government/people/jesse-norman","content_id":"4f980ba2-436f-44fa-ad6f-15e6ac4d6c4b","details":{"body":"<p>Jesse Norman was Minister of State in the Department for Transport between 26 October 2022 and 13 November 2023.</p>\n\n<p>He was previously Minister of State at the Foreign, Commonwealth &amp; Development Office from 7 September 2022 to 26 October 2022. Before that, he was Financial Secretary to the Treasury from 2019 to 2021, where he managed the COVID-19 furlough scheme and set up the UK Infrastructure Bank.</p>\n\n<p>Jesse was elected the <abbr title=\"Member of Parliament\">MP</abbr> for Hereford and South Herefordshire in 2010.</p>\n\n<p>Jesse was previously Paymaster General, and held ministerial roles in the Department for Transport, and the Department of Business, Energy and Industrial Strategy. As a backbencher, he was a member of the Treasury Select Committee 2010 to 2015, and Chair of the Culture, Media and Sport Committee in 2016 to 2017. Jesse was made a Privy Councillor in 2019.</p>\n\n<p>Before entering politics Jesse was a Director at Barclays. He also researched and taught philosophy at University College London, and ran a charitable project in Communist Eastern Europe.</p>\n\n<p>Jesse is the author of numerous books and pamphlets, including ‘Compassionate Conservatism’, ‘Edmund Burke: Politician, Philosopher, Prophet’ and ‘Adam Smith: What He Thought, and Why It Matters’, which won a Parliamentary Book Award in 2018. Jesse was Spectator Parliamentarian of the Year and The House Backbencher of the Year in 2012.</p>\n\n<p>Jesse has degrees in Classics (Oxford University: MA) and philosophy (University College London: <abbr title=\"Master of Philosophy\">MPhil</abbr>, <abbr title=\"Doctor of Philosophy\">PhD</abbr>). He has held various academic research fellowships, and was elected as a Two-year Fellow at All Souls College, Oxford in 2022. Jesse is an enthusiastic cyclist, hill-walker and amateur jazz musician.</p>\n\n<div role=\"note\" aria-label=\"Information\" class=\"application-notice info-notice\">\n  <p>Follow Jesse Norman on Twitter: <a rel=\"external\" href=\"https://twitter.com/Jesse_Norman\">@Jesse_Norman</a>.</p>\n</div>\n\n","image":{"alt_text":"The Rt Hon Jesse Norman MP","url":"https://assets.publishing.service.gov.uk/media/635feffcd3bf7f04e4fd9823/s465_jesse-norman-960.jpg"}},"document_type":"person","links":{},"locale":"en","public_updated_at":"2024-07-15T15:41:21Z","schema_name":"person","title":"The Rt Hon Jesse Norman MP","web_url":"https://www.gov.uk/government/people/jesse-norman","withdrawn":false}],"role":[{"api_path":"/api/content/government/ministers/paymaster-general","api_url":"https://www.gov.uk/api/content/government/ministers/paymaster-general","base_path":"/government/ministers/paymaster-general","content_id":"1647e073-8e16-4944-85f4-cf665ce21cba","details":{"body":"\n","role_payment_type":null,"seniority":5,"whip_organisation":{}},"document_type":"ministerial_role","links":{"ordered_parent_organisations":[{"analytics_identifier":"D2","api_path":"/api/content/government/organisations/cabinet-office","api_url":"https://www.gov.uk/api/content/government/organisations/cabinet-office","base_path":"/government/organisations/cabinet-office","content_id":"96ae61d6-c2a1-48cb-8e67-da9d105ae381","details":{"acronym":"","brand":"cabinet-office","default_news_image":{"high_resolution_url":"https://assets.publishing.service.gov.uk/media/5a37da9d40f0b649cfaf7b27/s960_cabinet-office.jpg","url":"https://assets.publishing.service.gov.uk/media/5a37da9ded915d5a5f965f9c/s300_cabinet-office.jpg"},"logo":{"crest":"single-identity","formatted_title":"Cabinet Office"},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"Cabinet Office","web_url":"https://www.gov.uk/government/organisations/cabinet-office","withdrawn":false}]},"locale":"en","public_updated_at":"2024-07-12T09:15:13Z","schema_name":"role","title":"Paymaster General","web_url":"https://www.gov.uk/government/ministers/paymaster-general","withdrawn":false}]},"locale":"en","public_updated_at":"2019-11-07T11:37:18Z","schema_name":"role_appointment","title":"The Rt Hon Jesse Norman - Paymaster General","withdrawn":false},{"content_id":"d2f4653f-298a-42b4-8403-afec93784704","details":{"current":false,"ended_on":"2019-05-23T00:00:00+01:00","person_appointment_order":4124,"started_on":"2017-06-13T00:00:00+01:00"},"document_type":"role_appointment","links":{"person":[{"api_path":"/api/content/government/people/mel-stride","api_url":"https://www.gov.uk/api/content/government/people/mel-stride","base_path":"/government/people/mel-stride","content_id":"8540200b-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Rt Hon Mel Stride was Secretary of State for Work and Pensions between 25 October 2022 and 5 July 2024.</p>\n\n<p>He was previously Lord President of the Council and Leader of the House of Commons from 23 May 2019 to 24 July 2019, and Financial Secretary to the Treasury and Paymaster General from June 2017 to May 2019.</p>\n\n<p>He was elected the Conservative MP for Central Devon in 2010.</p>\n\n<h2 id=\"education\">Education</h2>\n\n<p>Mel was educated at Portsmouth Grammar School and Oxford University, where he was elected President of the Oxford Union.</p>\n\n<h2 id=\"political-career\">Political career</h2>\n\n<p>In October 2011 Mel was appointed Parliamentary Private Secretary to the Minister of State for Further Education, Skills and Lifelong Learning, John Hayes. He later served as an Assistant Government Whip from July 2014 until May 2015 and as Government Whip (Lord Commissioner of HM Treasury) from May 2015 until July 2016.</p>\n","image":{"alt_text":"The Rt Hon Mel Stride MP","url":"https://assets.publishing.service.gov.uk/media/5a4f6ea4ed915d595171e9ea/s465_Mel_Stride_GovernmentWhips-13Jul2015_5183.jpg"}},"document_type":"person","links":{},"locale":"en","public_updated_at":"2024-07-18T09:57:41Z","schema_name":"person","title":"The Rt Hon Mel Stride MP","web_url":"https://www.gov.uk/government/people/mel-stride","withdrawn":false}],"role":[{"api_path":"/api/content/government/ministers/paymaster-general","api_url":"https://www.gov.uk/api/content/government/ministers/paymaster-general","base_path":"/government/ministers/paymaster-general","content_id":"1647e073-8e16-4944-85f4-cf665ce21cba","details":{"body":"\n","role_payment_type":null,"seniority":5,"whip_organisation":{}},"document_type":"ministerial_role","links":{"ordered_parent_organisations":[{"analytics_identifier":"D2","api_path":"/api/content/government/organisations/cabinet-office","api_url":"https://www.gov.uk/api/content/government/organisations/cabinet-office","base_path":"/government/organisations/cabinet-office","content_id":"96ae61d6-c2a1-48cb-8e67-da9d105ae381","details":{"acronym":"","brand":"cabinet-office","default_news_image":{"high_resolution_url":"https://assets.publishing.service.gov.uk/media/5a37da9d40f0b649cfaf7b27/s960_cabinet-office.jpg","url":"https://assets.publishing.service.gov.uk/media/5a37da9ded915d5a5f965f9c/s300_cabinet-office.jpg"},"logo":{"crest":"single-identity","formatted_title":"Cabinet Office"},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"Cabinet Office","web_url":"https://www.gov.uk/government/organisations/cabinet-office","withdrawn":false}]},"locale":"en","public_updated_at":"2024-07-12T09:15:13Z","schema_name":"role","title":"Paymaster General","web_url":"https://www.gov.uk/government/ministers/paymaster-general","withdrawn":false}]},"locale":"en","public_updated_at":"2019-11-06T16:21:51Z","schema_name":"role_appointment","title":"The Rt Hon Mel Stride - Paymaster General","withdrawn":false},{"content_id":"5552bee3-2e59-4264-99f3-8a937e2c22ba","details":{"current":false,"ended_on":"2017-06-09T00:00:00+01:00","person_appointment_order":4106,"started_on":"2016-07-14T00:00:00+01:00"},"document_type":"role_appointment","links":{"person":[{"api_path":"/api/content/government/people/ben-gummer","api_url":"https://www.gov.uk/api/content/government/people/ben-gummer","base_path":"/government/people/ben-gummer","content_id":"82470e96-b8a6-4d3c-83ba-95594d0805a1","details":{"body":"<p>Ben Gummer served as Minister for the Cabinet Office and Paymaster General from July 2016 until June 2017.</p>\n\n<p>He was elected Conservative MP for Ipswich in 2010.</p>\n\n<h2 id=\"education\">Education</h2>\n\n<p>Ben was educated at Tonbridge School in Kent, and studied History at Peterhouse, Cambridge.</p>\n\n<h2 id=\"political-career\">Political career</h2>\n\n<ul>\n  <li>Parliamentary Advisor to Lord Feldman from May 2012 to September 2012</li>\n  <li>Parliamentary Private Secretary to Minister of State for International Development</li>\n  <li>Parliamentary Private Secretary to the Secretary of State for Education, October 2013 to May 2015</li>\n  <li>Parliamentary Under Secretary of State for Quality at Department of Health from May 2015 to July 2016</li>\n</ul>\n\n<h2 id=\"career-outside-politics\">Career outside politics</h2>\n\n<p>After studying at Cambridge University, Ben ran a small engineering firm before becoming managing director of a consultancy business. He is also the author of a book on the Black Death - The Scourging Angel.</p>\n\n<p>Ben is an associate governor of Ravenswood Primary School, Patron of Home Start South Suffolk and a trustee of the Foundation Years Trust.</p>\n","image":{"alt_text":"The Rt Hon Ben Gummer","url":"https://assets.publishing.service.gov.uk/media/5a4f6f3fe5274a6bf054ef28/s465_TME_3874TME_3874_960_ben_gummer.JPG"}},"document_type":"person","links":{},"locale":"en","public_updated_at":"2017-06-09T17:05:13Z","schema_name":"person","title":"The Rt Hon Ben Gummer","web_url":"https://www.gov.uk/government/people/ben-gummer","withdrawn":false}],"role":[{"api_path":"/api/content/government/ministers/paymaster-general","api_url":"https://www.gov.uk/api/content/government/ministers/paymaster-general","base_path":"/government/ministers/paymaster-general","content_id":"1647e073-8e16-4944-85f4-cf665ce21cba","details":{"body":"\n","role_payment_type":null,"seniority":5,"whip_organisation":{}},"document_type":"ministerial_role","links":{"ordered_parent_organisations":[{"analytics_identifier":"D2","api_path":"/api/content/government/organisations/cabinet-office","api_url":"https://www.gov.uk/api/content/government/organisations/cabinet-office","base_path":"/government/organisations/cabinet-office","content_id":"96ae61d6-c2a1-48cb-8e67-da9d105ae381","details":{"acronym":"","brand":"cabinet-office","default_news_image":{"high_resolution_url":"https://assets.publishing.service.gov.uk/media/5a37da9d40f0b649cfaf7b27/s960_cabinet-office.jpg","url":"https://assets.publishing.service.gov.uk/media/5a37da9ded915d5a5f965f9c/s300_cabinet-office.jpg"},"logo":{"crest":"single-identity","formatted_title":"Cabinet Office"},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"Cabinet Office","web_url":"https://www.gov.uk/government/organisations/cabinet-office","withdrawn":false}]},"locale":"en","public_updated_at":"2024-07-12T09:15:13Z","schema_name":"role","title":"Paymaster General","web_url":"https://www.gov.uk/government/ministers/paymaster-general","withdrawn":false}]},"locale":"en","public_updated_at":"2019-10-17T07:42:53Z","schema_name":"role_appointment","title":"The Rt Hon Ben Gummer - Paymaster General","withdrawn":false},{"content_id":"afce7d74-df04-4a9c-b546-215498d38056","details":{"current":false,"ended_on":"2016-07-14T00:00:00+01:00","person_appointment_order":4105,"started_on":"2015-05-11T00:00:00+01:00"},"document_type":"role_appointment","links":{"person":[{"api_path":"/api/content/government/people/matthew-hancock","api_url":"https://www.gov.uk/api/content/government/people/matthew-hancock","base_path":"/government/people/matthew-hancock","content_id":"852c2f06-c0f1-11e4-8223-005056011aef","details":{"body":"<p>Matt Hancock served as Secretary of State for Health and Social Care from 9 July 2018 to 26 June 2021.</p>\n\n<p>He was Secretary of State for Digital, Culture, Media and Sport from 8 January 2018 to 9 July 2018. He was previously Minister of State for Digital from July 2016 to January 2018.</p>\n\n<p>Matt was elected Conservative MP for West Suffolk in May 2010. From 2010 Matt served as a backbencher on the Public Accounts Committee and the Standards &amp; Privileges Committee. Matt entered government in September 2012 and has served in a number of Ministerial Roles, including for skills and business, and as Paymaster General. He oversaw the expansion of apprenticeships, and championed the digital transformation of government.</p>\n\n<p>From July 2016 he served at DCMS as Minister of State for Digital and was responsible for broadband, broadcasting, creative industries, cyber and the tech industry.</p>\n\n<p>Before entering politics, Matt worked for his family business, as an economist at the Bank of England, and as Chief of Staff to the Shadow Chancellor of the Exchequer. He holds degrees from Oxford and Cambridge Universities.</p>\n\n<p>Matt is married to Martha and has three young children. He is the first MP in modern times to win a horse race, having raced to victory at the Newmarket July Course in August 2012. He is an avid cricketer and plays for the Lords &amp; Commons Cricket team. Matthew once played the most northerly game of cricket on record, and succumbed to frostbite en route to the Pole. He retains all his fingers.</p>\n","image":{"alt_text":"The Rt Hon Matt Hancock","url":"https://assets.publishing.service.gov.uk/media/5a4f6bf8e5274a6bf054eb60/s465_Matt_Hancock_May2015_GOVUK.jpg"}},"document_type":"person","links":{},"locale":"en","public_updated_at":"2024-05-29T23:00:59Z","schema_name":"person","title":"The Rt Hon Matt Hancock","web_url":"https://www.gov.uk/government/people/matthew-hancock","withdrawn":false}],"role":[{"api_path":"/api/content/government/ministers/paymaster-general","api_url":"https://www.gov.uk/api/content/government/ministers/paymaster-general","base_path":"/government/ministers/paymaster-general","content_id":"1647e073-8e16-4944-85f4-cf665ce21cba","details":{"body":"\n","role_payment_type":null,"seniority":5,"whip_organisation":{}},"document_type":"ministerial_role","links":{"ordered_parent_organisations":[{"analytics_identifier":"D2","api_path":"/api/content/government/organisations/cabinet-office","api_url":"https://www.gov.uk/api/content/government/organisations/cabinet-office","base_path":"/government/organisations/cabinet-office","content_id":"96ae61d6-c2a1-48cb-8e67-da9d105ae381","details":{"acronym":"","brand":"cabinet-office","default_news_image":{"high_resolution_url":"https://assets.publishing.service.gov.uk/media/5a37da9d40f0b649cfaf7b27/s960_cabinet-office.jpg","url":"https://assets.publishing.service.gov.uk/media/5a37da9ded915d5a5f965f9c/s300_cabinet-office.jpg"},"logo":{"crest":"single-identity","formatted_title":"Cabinet Office"},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"Cabinet Office","web_url":"https://www.gov.uk/government/organisations/cabinet-office","withdrawn":false}]},"locale":"en","public_updated_at":"2024-07-12T09:15:13Z","schema_name":"role","title":"Paymaster General","web_url":"https://www.gov.uk/government/ministers/paymaster-general","withdrawn":false}]},"locale":"en","public_updated_at":"2019-11-06T16:14:24Z","schema_name":"role_appointment","title":"The Rt Hon Matt Hancock - Paymaster General","withdrawn":false},{"content_id":"6f668eef-cb3e-495e-9ba9-747319c67308","details":{"current":false,"ended_on":"2015-05-11T00:00:00+01:00","person_appointment_order":4104,"started_on":"2010-05-12T00:00:00+01:00"},"document_type":"role_appointment","links":{"person":[{"api_path":"/api/content/government/people/francis-maude","api_url":"https://www.gov.uk/api/content/government/people/francis-maude","base_path":"/government/people/francis-maude","content_id":"85292952-c0f1-11e4-8223-005056011aef","details":{"body":"<p>Francis Maude was Minister of State for Trade and Investment from 11 May 2015 to 11 April 2016. Francis was previously Minister for the Cabinet Office and Paymaster General from May 2010 to May 2015.</p>\n\n<h2 id=\"education\">Education</h2>\n\n<p>Francis studied at the University of Cambridge and The College of Law, specialising in criminal law.</p>\n\n<h2 id=\"political-career\">Political career</h2>\n\n<p>Francis was the Conservative MP for Horsham, West Sussex, from 1997 to 2015. He has held several government posts, including Financial Secretary to the Treasury from 1990 to 1992 and Minister of State at the Foreign and Commonwealth Office from 1989 to 1990.</p>\n\n<p>He was Chairman of the Conservative Party from 2005 to 2007. Among other roles, he was Shadow Minister for the Cabinet Office from 2007 to 2010 and Shadow Foreign Secretary from 2000 to 2001.</p>\n\n<h2 id=\"career-outside-politics\">Career outside politics</h2>\n\n<p>After a career at the criminal bar between 1977 and 1985, he served as a councillor for the City of Westminster for 6 years. His other jobs outside politics have included being a non-executive director of ASDA Group, director at Salomon Brothers and managing director of Morgan Stanley.</p>\n","image":{"alt_text":"The Rt Hon Lord Maude of Horsham","url":"https://assets.publishing.service.gov.uk/media/5a4f6dbfe5274a6bf054ed6e/s465_Francis_Maude_May2015_GOVUK.jpg"}},"document_type":"person","links":{},"locale":"en","public_updated_at":"2016-04-21T10:50:08Z","schema_name":"person","title":"The Rt Hon Lord Maude of Horsham","web_url":"https://www.gov.uk/government/people/francis-maude","withdrawn":false}],"role":[{"api_path":"/api/content/government/ministers/paymaster-general","api_url":"https://www.gov.uk/api/content/government/ministers/paymaster-general","base_path":"/government/ministers/paymaster-general","con