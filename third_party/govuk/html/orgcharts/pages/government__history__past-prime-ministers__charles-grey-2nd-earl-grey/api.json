/frederick-robinson-viscount-goderich","content_id":"4064fc77-0321-4151-8497-a1abb518dacc","details":{"dates_in_office":[{"end_year":1828,"start_year":1827}],"political_party":"Tory"},"document_type":"historic_appointment","links":{},"locale":"en","public_updated_at":"2023-01-19T17:38:32Z","schema_name":"historic_appointment","title":"Frederick Robinson, Viscount Goderich","web_url":"https://www.gov.uk/government/history/past-prime-ministers/frederick-robinson-viscount-goderich","withdrawn":false}],"parent":[{"api_path":"/api/content/government/history","api_url":"https://www.gov.uk/api/content/government/history","base_path":"/government/history","content_id":"db95a864-874f-4f50-a483-352a5bc7ba18","document_type":"special_route","links":{},"locale":"en","public_updated_at":"2025-09-11T06:19:56Z","schema_name":"special_route","title":"History of the UK government","web_url":"https://www.gov.uk/government/history","withdrawn":false}],"person":[{"api_path":"/api/content/government/people/charles-grey-2nd-earl-grey","api_url":"https://www.gov.uk/api/content/government/people/charles-grey-2nd-earl-grey","base_path":"/government/people/charles-grey-2nd-earl-grey","content_id":"85373b8e-c0f1-11e4-8223-005056011aef","details":{"body":"<p>Charles Grey  2nd Earl Grey served as Prime Minister between 1830 to 1834. Read more about the life and achievements of Charles Grey  2nd Earl Grey in our <a href=\"/government/history/past-prime-ministers/charles-grey-2nd-earl-grey\">past Prime Ministers</a> section.</p>\n","image":{"alt_text":"Charles Grey, 2nd Earl Grey","url":"https://assets.publishing.service.gov.uk/media/5dc42bf5ed915d393b4a2e4f/s465_Earl-Grey.jpg"}},"document_type":"person","links":{},"locale":"en","public_updated_at":"2019-11-07T14:31:54Z","schema_name":"person","title":"Charles Grey, 2nd Earl Grey","web_url":"https://www.gov.uk/government/people/charles-grey-2nd-earl-grey","withdrawn":false}]},"locale":"en","phase":"live","public_updated_at":"2023-01-19T17:38:32+0