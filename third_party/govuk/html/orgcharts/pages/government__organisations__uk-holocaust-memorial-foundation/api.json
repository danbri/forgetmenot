e are"},{"href":"https://www.gov.uk/government/organisations/uk-holocaust-memorial-foundation/about#our-mission-statement","title":"Our mission statement"},{"href":"https://www.gov.uk/government/organisations/uk-holocaust-memorial-foundation/about#how-we-will-deepen-understanding-of-the-holocaust-and-britains-response","title":"The Holocaust and Britain’s response"},{"href":"https://www.gov.uk/government/organisations/uk-holocaust-memorial-foundation/about#exhibition","title":"Exhibition"},{"href":"https://www.gov.uk/government/groups/ukhmf-academic-advisory-board","title":"UKHMF Academic Advisory Board"},{"href":"https://www.gov.uk/government/organisations/uk-holocaust-memorial-foundation/about#ukhmf-testimonies","title":"UKHMF Testimonies"},{"href":"https://www.gov.uk/guidance/ukhmf-testimony-participants-privacy-notice","title":"Privacy notice for UKHMF Testimony participants "}],"ordered_promotional_features":[],"organisation_featuring_priority":"service","organisation_govuk_status":{"status":"live","updated_at":null,"url":null},"organisation_political":false,"organisation_type":"other","secondary_corporate_information_pages":"","social_media_links":[{"href":"https://twitter.com/ukhmf","service_type":"twitter","title":"UKHMF on Twitter"}]},"document_type":"organisation","first_published_at":"2016-01-12T17:57:33+00:00","links":{"available_translations":[{"analytics_identifier":"PB1171","api_path":"/api/content/government/organisations/uk-holocaust-memorial-foundation","api_url":"https://www.gov.uk/api/content/government/organisations/uk-holocaust-memorial-foundation","base_path":"/government/organisations/uk-holocaust-memorial-foundation","content_id":"0183a2d3-ce7b-47cf-966d-1323b74865bc","document_type":"organisation","links":{},"locale":"en","public_updated_at":"2024-07-16T13:00:11Z","schema_name":"organisation","title":"UK Holocaust Memorial Foundation","web_url":"https://www.gov.uk/government/organisations/uk-holocaust-memorial-foundation","withdrawn":false}],"ordered_board_members":[{"api_path":"/api/content/government/people/eric-pickles","api_url":"https://www.gov.uk/api/content/government/people/eric-pickles","base_path":"/government/people/eric-pickles","content_id":"852925f7-c0f1-11e4-8223-005056011aef","details":{"image":{"alt_text":"The Rt Hon Lord Pickles","url":"https://assets.publishing.service.gov.uk/media/5a4f7134e5274a6bf054f0b8/s465_Eric_Pickles.jpg"},"privy_counsellor":true},"document_type":"person","links":{"role_appointments":[{"content_id":"ee367b87-987a-4170-a1dc-53ac66f6824c","details":{"current":false,"ended_on":"2025-03-03T00:00:00+00:00","person_appointment_order":3,"started_on":"2015-09-07T00:00:00+01:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"846172aa-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The special envoy will:  </p>\n\n<ul>\n  <li>promote His Majesty’s Government’s (HMG) policy on post-Holocaust issues internationally, including raising awareness of the importance of Holocaust remembrance, education and research, working with ministers and officials to deliver HMG’s international post-Holocaust issues policy objectives </li>\n  <li>work with international partners, other special envoys and experts on post-Holocaust issues including representing the UK in appropriate international fora including as Head of the UK Delegation to the International Holocaust Remembrance Alliance and at the Special Envoy’s meeting on Antisemitism</li>\n  <li>press for progress internationally on Holocaust-era property and art restitution issues. Drive forward implementation of the Terezin Declaration, including through the implementation of the Washington Principles on Nazi-Confiscated Art</li>\n  <li>raise awareness of HMG’s international action on post-Holocaust issues with domestic stakeholders, including the Jewish community</li>\n  <li>represent the UK at Holocaust commemoration events both in the UK and internationally as necessary, including Holocaust Memorial Day, observed annually on 27 January</li>\n</ul>\n\n<p>View the full <a href=\"https://www.gov.uk/government/publications/special-envoy-for-post-holocaust-issues-terms-of-reference\">terms of reference for the special envoy role</a>.</p>\n","role_payment_type":null},"document_type":"special_representative_role","links":{},"locale":"en","public_updated_at":"2026-02-24T08:48:33Z","schema_name":"role","title":"UK Special Envoy for Post-Holocaust Issues","withdrawn":false}]},"locale":"en","public_updated_at":"2025-05-16T06:56:26Z","schema_name":"role_appointment","title":"The Rt Hon Lord Pickles - United Kingdom Special Envoy for post-Holocaust issues","withdrawn":false},{"content_id":"e1fc9ea4-e5e8-48db-8646-3b07e57737fc","details":{"current":false,"ended_on":"2025-04-01T00:00:00+01:00","person_appointment_order":4,"started_on":"2020-04-01T00:00:00+01:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"84781d66-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The role of the Committee is to:</p>\n\n<ul>\n  <li>provide independent advice to the government on the application of the government’s Business Appointment Rules to the most senior members of the Civil Service, armed forces, diplomatic service, and intelligence agencies who wish to take up appointments within 2 years of leaving Crown service</li>\n  <li>provide independent advice directly to former ministers on appointments they wish to take up within 2 years of leaving government</li>\n</ul>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2025-04-01T16:44:04Z","schema_name":"role","title":"Interim Chair, ACOBA","withdrawn":false}]},"locale":"en","public_updated_at":"2025-04-01T16:43:28Z","schema_name":"role_appointment","title":"The Rt Hon Lord Pickles - Chair, ACOBA","withdrawn":false},{"content_id":"b1f1ed7b-9af5-4fbe-87e6-ceba9a4eeeab","details":{"current":true,"ended_on":null,"person_appointment_order":7005,"started_on":"2018-0