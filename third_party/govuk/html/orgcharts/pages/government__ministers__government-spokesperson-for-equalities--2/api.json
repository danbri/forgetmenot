{"analytics_identifier":null,"base_path":"/government/ministers/government-spokesperson-for-equalities--2","content_id":"f5718276-4aca-4ad8-8e7b-ac1985dbde25","description":"Lords spokesperson on equalities.","details":{"attends_cabinet_type":null,"body":"<p>Lords spokesperson on equalities.</p>\n","role_payment_type":null,"seniority":100,"supports_historical_accounts":false,"whip_organisation":{}},"document_type":"ministerial_role","first_published_at":"2024-10-08T20:17:19+01:00","links":{"available_translations":[{"api_path":"/api/content/government/ministers/government-spokesperson-for-equalities--2","api_url":"https://www.gov.uk/api/content/government/ministers/government-spokesperson-for-equalities--2","base_path":"/government/ministers/government-spokesperson-for-equalities--2","content_id":"f5718276-4aca-4ad8-8e7b-ac1985dbde25","document_type":"ministerial_role","links":{},"locale":"en","public_updated_at":"2024-10-31T17:43:44Z","schema_name":"role","title":"Government spokesperson for Equalities","web_url":"https://www.gov.uk/government/ministers/government-spokesperson-for-equalities--2","withdrawn":false}],"role_appointments":[{"content_id":"c920d765-72bc-4856-9951-d99115e9e04e","details":{"current":true,"ended_on":null,"person_appointment_order":4,"started_on":"2024-10-08T00:00:00+01:00"},"document_type":"role_appointment","links":{"person":[{"api_path":"/api/content/government/people/lord-collins-of-highbury","api_url":"https://www.gov.uk/api/content/government/people/lord-collins-of-highbury","base_path":"/government/people/lord-collins-of-highbury","content_id":"f902adbe-ed6a-453a-9095-5a135105c9aa","details":{"body":"<p>Lord Collins of Highbury was appointed as a Government spokesperson for Equalities on 8 October 2024, in addition to his roles as Deputy Leader of the House of Lords and Lord in Waiting (Government Whip).</p>\n\n<p>He was previously Parliamentary Under Secretary of State in the Foreign, Commonwealth and Development Office from 9 July 2024 to 7 September 2025.</p>\n\n<p>Lord Collins was <a href=\"https://www.gov.uk/government/news/lord-collins-appointed-special-representative-on-psvi\">appointed Prime Minister’s Special Representative on Preventing Sexual Violence in Conflict (PSVI)</a> on 15 November 2024.</p>\n\n<p>Lord Collins was an Assistant General Secretary of the Transport Union (1994 to 1999) and the General Workers Union, later Unite (1999 to 2008).</p>\n\n<p>Lord Collins served as General Secretary of the Labour Party (2008 to 2011) before joining the House of Lords in 2011.</p>\n\n<p>Before joining government, Lord Collins was Co-Chair All-Party Parliamentary Group (APPG) for Nutrition for Growth. He was also an officer of the APPG on Global LGBT Rights which advances LGBT rights around the world.</p>\n\n<p>Lord Collins is also Patron of Positive East, London’s largest HIV charity based in the East End.</p>\n\n<div role=\"note\" aria-label=\"Information\" class=\"application-notice info-notice\">\n  <p>Follow Lord Collins on X/Twitter: <a rel=\"external\" href=\"https://x.com/Lord_Collins\">@Lord_Collins</a></p>\n</div>\n","image":{"alt_text":"Lord Collins of Highbury","url":"https://assets.publishing.service.gov.uk/media/668eb1b1ab418ab055592357/s465_lord-collins.png"}},"document_type":"person","links":{},"locale":"en","public_updated_at":"2025-09-08T08:22:57Z","schema_name":"person","title":"Lord Collins of Highbury","web_url":"https://www.gov.uk/government/people/lord-collins-of-highbury","withdrawn":false}],"role":[{"api_path":"/api/content/government/ministers/government-spokesperson-for-equalities--2","api_url":"https://www.gov.uk/api/content/government/ministers/government-spokesperson-for-equalities--2","base_path":"/government/ministers/government-spokesperson-for-equalities--2","content_id":"f5718276-4aca-4ad8-8e7b-ac1985dbde25","details":{"body":"<p>Lords spokesperson on equalities.</p>\n","role_payment_type":null,"seniority":100,"whip_organisation":{}},"document_type":"ministerial_role","links":{},"locale":"en","public_updated_at":"2024-10-31T17:43:44Z","schema_name":"role","title":"Government spokesperson for Equalities","web_url":"https://www.gov.uk/government/ministers/government-spokesperson-for-equalities--2","withdrawn":false}]},"locale":"en","public_updated_at":"2024-10-08T19:17:50Z","schema_name":"role_appointment","title":"Lord Collins of Highbury - Government spokesperson for Equalities","withdrawn":false}]},"locale":"en","phase":"live","public_updated_at":"2024-10-31T17:43:44+00:00","publishing_app":"whitehall","publishing_request_id":"21-1749646476.196-10.13.20.90-2558","publishing_scheduled_at":null,"rendering_app":"collections","scheduled_publishing_delay_seconds":null,"schema_name":"role","title":"Government spokesperson for Equalities","updated_at":"2025-09-08T10:19:24+01:00","withdrawn_notice":{}}