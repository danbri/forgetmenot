{"analytics_identifier":"PB247","base_path":"/government/organisations/disabled-persons-transport-advisory-committee","content_id":"b969a617-7c4b-4d3b-97ef-41656ef688c9","description":"We are an independent expert committee established by the Transport Act 1985, providing advice to the government on the transport needs of disabled people. DPTAC works with the Department for Transport .","details":{"acronym":"DPTAC","alternative_format_contact_email":"dptac.enquiries@dft.gov.uk","body":"<div class=\"govspeak\"><p>We are an independent expert committee established by the Transport Act 1985, providing advice to the government on the transport needs of disabled people.</p>\n\n<p><abbr title=\"Disabled Persons Transport Advisory Committee\">DPTAC</abbr> works with the <a class=\"brand__color\" href=\"/government/organisations/department-for-transport\">Department for Transport</a>.</p>\n</div>","brand":"department-for-transport","foi_exempt":false,"logo":{"crest":"custom","formatted_title":"Disabled Persons <br/>Transport Advisory Committee (DPTAC)","image":{"alt_text":"Disabled Persons Transport Advisory Committee","url":"https://assets.publishing.service.gov.uk/media/5d67bb0c40f0b607bfcf3e24/dptac-small.jpg"}},"ordered_corporate_information_pages":[{"href":"/government/organisations/disabled-persons-transport-advisory-committee/about/membership","title":"Membership"},{"href":"/government/organisations/disabled-persons-transport-advisory-committee/about/terms-of-reference","title":"Terms of reference"}],"ordered_featured_documents":[],"ordered_featured_links":[],"ordered_promotional_features":[],"organisation_featuring_priority":"news","organisation_govuk_status":{"status":"live","updated_at":null,"url":null},"organisation_political":false,"organisation_type":"other","secondary_corporate_information_pages":"Read about the types of information we routinely publish in our <a class=\"govuk-link brand__color\" href=\"/government/organisations/disabled-persons-transport-advisory-committee/about/publication-scheme\">Publication scheme</a>. Our <a class=\"govuk-link brand__color\" href=\"/government/organisations/disabled-persons-transport-advisory-committee/about/personal-information-charter\">Personal information charter</a> explains how we treat your personal information.","social_media_links":[]},"document_type":"organisation","first_published_at":"2012-02-08T16:36:25+00:00","links":{"available_translations":[{"analytics_identifier":"PB247","api_path":"/api/content/government/organisations/disabled-persons-transport-advisory-committee","api_url":"https://www.gov.uk/api/content/government/organisations/disabled-persons-transport-advisory-committee","base_path":"/government/organisations/disabled-persons-transport-advisory-committee","content_id":"b969a617-7c4b-4d3b-97ef-41656ef688c9","document_type":"organisation","links":{},"locale":"en","public_updated_at":"2021-04-15T09:00:02Z","schema_name":"organisation","title":"Disabled Persons Transport Advisory Committee","web_url":"https://www.gov.uk/government/organisations/disabled-persons-transport-advisory-committee","withdrawn":false}],"ordered_contacts":[{"content_id":"fb33ed5d-f876-43aa-a441-272c9592d288","details":{"contact_form_links":null,"description":"DPTAC is an expert committee that advises the government. DPTAC doesn't advise members of the public. If you are a member of the public with a query about transport, please contact the Department for Transport.","email_addresses":[{"email":"dptac.enquiries@dft.gov.uk"}],"phone_numbers":null,"post_addresses":[{"iso2_country_code":"gb","postal_code":"B4 6AT","street_address":"Disabled Persons Transport Advisory Committee <br />C/O DPTAC Secretariat <br />Public Transport and Local Group<br />Fourth Floor, The Colmore Building<br />20 Colmore Circus Queensway Birmingham","world_location":"United Kingdom"}],"title":"General enquiries"},"document_type":"contact","links":{},"locale":"en","public_updated_at":"2024-10-10T12:23:53Z","schema_name":"contact","title":"General enquiries","withdrawn":false}],"ordered_foi_contacts":[{"content_id":"4a60200f-ef3e-42d0-8049-f01e6425af00","details":{"contact_form_links":null,"description":null,"email_addresses":[{"email":"dptac.enquiries@dft.gov.uk"}],"phone_numbers":null,"post_addresses":[],"title":"Freedom of Information requests"},"document_type":"contact","links":{},"locale":"en","public_updated_at":"2018-08-08T13:13:58Z","schema_name":"contact","title":"Freedom of Information requests","withdrawn":false}],"ordered_parent_organisations":[{"analytics_identifier":"D9","api_path":"/api/content/government/organisations/department-for-transport","api_url":"https://www.gov.uk/api/content/government/organisations/department-for-transport","base_path":"/government/organisations/department-for-transport","content_id":"4c717efc-f47b-478e-a76d-ce1ae0af1946","details":{"acronym":"DfT","brand":"department-for-transport","default_news_image":{"high_resolution_url":"https://assets.publishing.service.gov.uk/media/654bbccfe2e16a000d42abe1/s960_dft-gmh-960.jpg","url":"https://assets.publishing.service.gov.uk/media/654bbccfe70413000dfc4a51/s300_dft-gmh-960.jpg"},"logo":{"crest":"single-identity","formatted_title":"Department<br/>for Transport"},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"Department for Transport","web_url":"https://www.gov.uk/government/organisations/department-for-transport","withdrawn":false}],"ordered_roles":[{"content_id":"84704969-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The chair is responsible for:</p>\n\n<ul>\n  <li>advising the government on how to help disabled people to travel more freely, independently and in safety and comfort making sure DPTAC meets its statutory roles as set out in the Transport Act 1985</li>\n  <li>highlighting the transportation needs of disabled people developing a committee-wide understanding of the needs of disabled people</li>\n  <li>publicising the transportation needs of disabled people through engagement with stakeholders:\n    <ul>\n      <li>within the wider transport sector, including bus, rail and taxi operators community transport</li>\n      <li>within organisations involved in personal transport for disabled people, motoring, mobility scooters and street design organisations</li>\n      <li>representing the interests of disabled people generally</li>\n      <li>representing people with particular types of impairment central government, mainly the Department for Transport ( DfT ) but also Department for Work and Pensions ( DWP )</li>\n    </ul>\n  </li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2023-06-22T11:18:06Z","schema_name":"role","title":"Chair – DPTAC","withdrawn":false},{"content_id":"847049c0-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Deputy Chair is responsible for:</p>\n\n<ul>\n  <li>helping disabled people to travel more freely, independently and in safety and comfort</li>\n  <li>representing <abbr title=\"Disabled Persons Transport Advisory Committee\">DPTAC</abbr> at public events</li>\n  <li>drawing together and leading upon particular work streams</li>\n  <li>publicising within <abbr title=\"Disabled Persons Transport Advisory Committee\">DPTAC</abbr> a greater sense of unity and one-team working</li>\n</ul>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2023-03-17T07:20:49Z","schema_name":"role","title":"Deputy Chair – DPTAC","withdrawn":false},{"content_id":"84704a17-c0f1-11e4-8223-005056011aef","details":{"body":"<p>Responsibilities are:</p>\n\n<ul>\n  <li>working together to meet the statutory expectations of <abbr title=\"Disabled Persons Transport Advisory Committee\">DPTAC</abbr>\n</li>\n  <li>developing a deep and broad understanding of the transport needs of disabled people</li>\n  <li>publicising the interests of all disabled people in relation to transport</li>\n  <li>working with the Chair, Deputy Chairs and other members to promote <abbr title=\"Disabled Persons Transport Advisory Committee\">DPTAC</abbr>’s interests within <abbr title=\"Department for Transport\">DfT</abbr> and with transport operators</li>\n</ul>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2023-03-17T07:22:01Z","schema_name":"role","title":"Committee member – DPTAC","withdrawn":false},{"content_id":"84704b4a-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Deputy Chair is responsible for:</p>\n\n<ul>\n  <li>helping disabled people to travel more freely, independently and in safety and comfort</li>\n  <li>representing <abbr title=\"Disabled Persons Transport Advisory Committee\">DPTAC</abbr> at public events</li>\n  <li>drawing together and leading upon particular work streams</li>\n  <li>publicising within <abbr title=\"Disabled Persons Transport Advisory Committee\">DPTAC</abbr> a greater sense of unity and one-team working</li>\n</ul>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2023-03-17T07:20:40Z","schema_name":"role","title":"Deputy Chair – DPTAC","withdrawn":false}],"organisations":[{"analytics_identifier":"PB247","api_path":"/api/content/government/organisations/disabled-persons-transport-advisory-committee","api_url":"https://www.gov.uk/api/content/government/organisations/disabled-persons-transport-advisory-committee","base_path":"/government/organisations/disabled-persons-transport-advisory-committee","content_id":"b969a617-7c4b-4d3b-97ef-41656ef688c9","details":{"acronym":"DPTAC","brand":"department-for-transport","default_news_image":null,"logo":{"crest":"custom","formatted_title":"Disabled Persons <br/>Transport Advisory Committee (DPTAC)","image":{"alt_text":"Disabled Persons Transport Advisory Com