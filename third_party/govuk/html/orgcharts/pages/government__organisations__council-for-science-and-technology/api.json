cil-for-science-and-technology","api_url":"https://www.gov.uk/api/content/government/organisations/council-for-science-and-technology","base_path":"/government/organisations/council-for-science-and-technology","content_id":"fbc49af1-eb3a-4d17-9503-a3c249b8eee4","document_type":"organisation","links":{},"locale":"en","public_updated_at":"2025-12-09T10:24:26Z","schema_name":"organisation","title":"Council for Science and Technology","web_url":"https://www.gov.uk/government/organisations/council-for-science-and-technology","withdrawn":false}],"ordered_contacts":[{"content_id":"f6a31842-2571-4c71-a661-a45eaaa2ba6a","details":{"contact_form_links":null,"description":null,"email_addresses":[{"email":"cstsecretariat@go-science.gov.uk","title":"CST Secretariat"}],"phone_numbers":null,"post_addresses":[{"iso2_country_code":"gb","locality":"London","postal_code":"SW1A 2BQ","street_address":"100 Parliament Street","title":"CST Secretariat","world_location":"United Kingdom"}],"title":"General enquiries"},"document_type":"contact","links":{},"locale":"en","public_updated_at":"2025-12-19T14:17:10Z","schema_name":"contact","title":"General enquiries","withdrawn":false}],"ordered_foi_contacts":[{"content_id":"01e0db52-4c6f-45d7-85b7-402dba97df91","details":{"contact_form_links":[{"link":"https://www.gov.uk/guidance/make-a-freedom-of-information-foi-request-to-dsit"}],"description":null,"email_addresses":[{"email":"FOI-requests@dsit.gov.uk","title":"DSIT Information Rights Team"}],"phone_numbers":null,"post_addresses":[{"iso2_country_code":"gb","locality":"London","postal_code":"SW1A 2EG","street_address":"22-26 Whitehall","title":"DSIT Information Rights Team","world_location":"United Kingdom"}],"title":"Freedom of Information requests"},"document_type":"contact","links":{},"locale":"en","public_updated_at":"2026-04-16T13:08:13Z","schema_name":"contact","title":"Freedom of Information requests","withdrawn":false}],"ordered_roles":[{"content_id":"846dae23-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Independent Co-Chair works on raising the Council for Science and Technology’s (CST) profile inside and outside government, as well as being the outward spokesperson and advocate for CST. Other primary responsibilities are:</p>\n\n<ul>\n  <li>deciding what the CST will work on</li>\n  <li>working with government, the Government Chief Scientific Adviser (GCSA), Ministers and officials</li>\n  <li>agreeing agendas for meetings with the GCSA</li>\n  <li>guiding the Secretariat on CST’s business at and between meetings</li>\n</ul>\n\n<p>The Independent Co-Chair role requires a time commitment of 3 to 4 days a month.</p>\n","role_payment_type":"Unpaid"},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2013-07-25T16:29:18Z","schema_name":"role","title":"Independent Co-Chair of the Council for Science and Technology","withdrawn":false},{"content_id":"846daed7-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Government Chief Scientific Adviser Co-Chair works with the <abbr title=\"Council for Science and Technology\">CST</abbr> and Ministers, Department Chief Scientific Advisers and others. The role includes:</p>\n\n<ul>\n  <li>advising <abbr title=\"Council for Science and Technology\">CST</abbr> on likely government reaction to <abbr title=\"Council for Science and Technology\">CST</abbr>’s advice</li>\n  <li>chairing the meetings when the delivery of advice to government or the government’s reaction to the advice is discussed</li>\n  <li>helping <abbr title=\"Council for Science and Technology\">CST</abbr> access information from government</li>\n</ul>\n\n","role_payment_type":"Unpaid"},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2013-07-25T16:27:53Z","schema_name":"role","title":"Co-chair of the Council for Science and Technology","withdrawn":false}],"organisations":[{"analytics_identifier":"PB121","api_path":"/api/content/government/organisations/council-for-science-and-technology","api_url":"https://www.gov.uk/api/content/government/organisations/council-for-science-and-technology","base_path":"/government/organisations/council-for-science-and-technology","content_id":"fbc49af1-eb3a-4d17-9503-a3c249b8eee4","details":{"acronym":"CST","brand":"department-for-business-innovation-skills","default_news_image":{"high_resolution_url":"https://assets.publishing.service.gov.uk/media/5a37daa040f0b649cceb17b7/s960_microscope-960x640.jpg","url":"https://assets.publishing.service.gov.uk/media/5a37daa0e5274a79051c916f/s300_microscope-960x640.jpg"},"logo":{"crest":"custom","formatted_title":"Council for <br/>Science and <br/>Technology","image":{"alt_text":"Council for Science and Technology","url":"https://assets.publishing.service.gov.uk/media/59fa00e8ed915d7bfdf0a2a6/CST_Logo_01.png"}},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"Council for Science and Technology","web_url":"https://www.gov.uk/government/organisations/council-for-science-and-technology","withdrawn":false}],"primary_publishing_organisation":[{"analytics_identifier":"PB121","api_path":"/api/content/government/organisations/council-for-science-and-technology","api_url":"https://www.gov.uk/api/content/government/organisations/council-for-science-and-technology","base_path":"/government/organisations/council-for-science-and-technology","content_id":"fbc49af1-eb3a-4d17-9503-a3c249b8eee4","details":{"acronym":"CST","brand":"department-for-business-innovation-skills","default_news_image":{"high_resolution_url":"https://assets.publishing.service.gov.uk/media/5a37daa040f0b649cceb17b7/s960_microscope-960x640.jpg","url":"https://assets.publishing.service.gov.uk/media/5a37daa0e5274a79051c916f/s300_microscope-960x640.jpg"},"logo":{"crest":"custom","formatted_title":"Council for <br/>Science and <br/>Technology","image":{"alt_text":"Council for Science and Techn