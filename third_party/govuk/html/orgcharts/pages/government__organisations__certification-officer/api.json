ublication-scheme\">Publication scheme</a>. Our <a class=\"govuk-link brand__color\" href=\"/government/organisations/certification-officer/about/personal-information-charter\">Personal information charter</a> explains how we treat your personal information.","social_media_links":[]},"document_type":"organisation","first_published_at":"2012-02-08T16:33:00+00:00","links":{"available_translations":[{"analytics_identifier":"PB139","api_path":"/api/content/government/organisations/certification-officer","api_url":"https://www.gov.uk/api/content/government/organisations/certification-officer","base_path":"/government/organisations/certification-officer","content_id":"3c16fddc-350e-4b2f-abfe-1a7c1821bd28","document_type":"organisation","links":{},"locale":"en","public_updated_at":"2024-02-29T12:35:11Z","schema_name":"organisation","title":"Certification Officer","web_url":"https://www.gov.uk/government/organisations/certification-officer","withdrawn":false}],"ordered_board_members":[{"api_path":"/api/content/government/people/stephen-hardy","api_url":"https://www.gov.uk/api/content/government/people/stephen-hardy","base_path":"/government/people/stephen-hardy","content_id":"de43c0cf-e5a0-435d-b74d-f829ba61142c","details":{"image":{"alt_text":"Stephen Hardy","url":"https://assets.publishing.service.gov.uk/media/65c0d679704282000d7521fa/s465_stephen-hardy.png"},"privy_counsellor":false},"document_type":"person","links":{"role_appointments":[{"content_id":"18a822b7-3eed-43f8-88fe-afe7bf695b48","details":{"current":true,"ended_on":null,"person_appointment_order":2,"started_on":"2025-10-01T00:00:00+01:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"8477a184-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The functions of the Certification Officer are contained in the Trade Union and Labour Relations (Consolidation) Act 1992 (as amended). They include:</p>\n\n<ul>\n  <li>maintaining a list of trade unions and employers’ associations</li>\n  <li>receiving, ensuring compliance with statutory requirements and keeping available for public inspection annual returns from trade unions and employers’ associations</li>\n  <li>determining complaints concerning trade union elections, certain other ballots and certain breaches of trade union rules</li>\n  <li>ensuring observance of statutory requirements governing mergers between trade unions and between employers’ associations</li>\n  <li>overseeing the political funds and the finances of trade unions and employers’ associations</li>\n  <li>certifying the independence of trade unions</li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2025-06-26T14:59:39Z","schema_name":"role","title":"Certification Officer","withdrawn":false}]},"locale":"en","public_updated_at":"2025-10-01T11:17:16Z","schema_name":"role_appointment","title":"Professor Stephen Hardy - Certification Officer","withdrawn":false},{"content_id":"561e1cd0-a52c-487d-8a51-dc6035505b5c","details":{"current":true,"ended_on":null,"person_appointment_order":1,"started_on":"2024-01-29T00:00:00+00:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"e0f8121c-d07c-46a8-a23a-3fffeb28b43a","details":{"body":"<p>Social Security Advisory Committee (SSAC) members are appointed by the Secretary of State for Work and Pensions to:</p>\n\n<ul>\n  <li>give advice on social security issues as it sees fit</li>\n  <li>consider and report on social security regulations that have been referred to it</li>\n  <li>advise on matters referred to it by the Secretary of State or the Northern Ireland department responsible for social security</li>\n  <li>scrutinise the products produced by the Department for Work and Pensions</li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2024-02-05T14:07:48Z","schema_name":"role","title":"Committee member","withdrawn":false}]},"locale":"en","publ