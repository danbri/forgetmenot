customs elements</li>\n  <li>Taxation of charities, the voluntary sector and gift aid</li>\n  <li>Energy, environment and climate taxes (including transport taxes)</li>\n  <li>Energy profits Levy</li>\n</ul>\n\n<p>The Exchequer Secretary to the Treasury is the departmental Minister for HM Revenue and Customs (HMRC), the Valuation Office Agency, and the Government’s Actuary’s Department.</p>\n","role_payment_type":null,"seniority":100,"whip_organisation":{}},"document_type":"ministerial_role","links":{"ordered_parent_organisations":[{"analytics_identifier":"D15","api_path":"/api/content/government/organisations/hm-treasury","api_url":"https://www.gov.uk/api/content/government/organisations/hm-treasury","base_path":"/government/organisations/hm-treasury","content_id":"1994e0e4-bd19-4966-bbd7-f293d6e90a6b","details":{"acronym":"HMT","brand":"hm-treasury","default_news_image":{"high_resolution_url":"https://assets.publishing.service.gov.uk/media/5a37db09e5274a7908e352b4/s960_HMT_buiding_plaque.jpg","url":"https://assets.publishing.service.gov.uk/media/5a37db09e5274a79051c9235/s300_HMT_buiding_plaque.jpg"},"logo":{"crest":"single-identity","formatted_title":"HM Treasury"},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"HM Treasury","web_url":"https://www.gov.uk/government/organisations/hm-treasury","withdrawn":false}]},"locale":"en","public_updated_at":"2024-09-23T10:13:35Z","schema_name":"role","title":"Exchequer Secretary to the Treasury","web_url":"https://www.gov.uk/government/ministers/exchequer-secretary-to-the-treasury","withdrawn":false}]},"locale":"en","public_updated_at":"2023-04-21T13:43:53Z","schema_name":"role_appointment","title":"James Cartlidge MP - Exchequer Secretary to the Treasury","withdrawn":false},{"content_id":"1152f4c0-d9fd-449d-acf0-113c2878cdd5","details":{"current":false,"ended_on":"2022-07-07T00:00:00+01:00","person_appoin