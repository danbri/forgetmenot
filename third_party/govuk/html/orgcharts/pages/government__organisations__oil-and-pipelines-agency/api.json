isation","links":{},"locale":"en","schema_name":"organisation","title":"Ministry of Defence","web_url":"https://www.gov.uk/government/organisations/ministry-of-defence","withdrawn":false}],"ordered_roles":[{"content_id":"8470748e-c0f1-11e4-8223-005056011aef","details":{"body":"<p>Responsible for safe and efficient operation and management of the oil fuel depots and one petroleum storage depot.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2017-09-28T14:24:46Z","schema_name":"role","title":"Chief Executive","withdrawn":false},{"content_id":"84707534-c0f1-11e4-8223-005056011aef","details":{"body":"<p>These include:</p>\n\n<ul>\n  <li>technical authority for the Government Pipelines and Storage System (GPSS)</li>\n  <li>project engineering activities</li>\n  <li>operations and maintenance activities via a contract with Costain</li>\n  <li>the Computerised Maintenance Management System (CMMS)</li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2014-01-24T15:24:35Z","schema_name":"role","title":"Asset Technical Director","withdrawn":false},{"content_id":"847075e0-c0f1-11e4-8223-005056011aef","details":{"body":"<p>Responsibility for all the commercial activities of The Oil and Pipelines Agency. These include sales, business development, customer liaison, commercial contracts, procurement, legal and estates.</p>\n\n<p>There is currently no one in the OPA Commercial Director role.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2015-06-16T10:08:15Z","schema_name":"role","title":"Commercial Director","withdrawn":false},{"content_id":"8470767d-c0f1-11e4-8223-005056011aef","details":{"body":"<p>Responsible for finance and information technology.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2014-01-24T15:26:58Z","schema_name":"role","title":"Finance Director","withdrawn":false},{"content_id":"8470771c-c0f1-11e4-8223-005056011aef","details":{"body":"<p>Responsible for operations management.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2014-01-24T15:28:11Z","schema_name":"role","title":"Operations Director","withdrawn":false},{"content_id":"24e7a814-3fda-4044-acd8-14b3f0361f2a","details":{"body":"<p>Responsibilities include:</p>\n\n<ul>\n  <li>ensuring <abbr title=\"Oil and Pipelines Agency\">OPA</abbr> deliver the Capital Projects effectively and efficiently across the assets and driving the team to deliver against the agreed time and budget constraints</li>\n  <li>to hold ultimate accountability for the all aspects of the Capital Project Teams delivery of the Capital Projects and provide regular feedback to the <abbr title=\"Oil and Pipelines Agency\">OPA</abbr> Board and other Senior Leadership Team members</li>\n  <li>lead the Capital Projects Team to design, implement and deliver the objectives as defined in the <abbr title=\"Oil and Pipelines Agency\">OPA</abbr> Business Strategic Plan and as approved by the Board</li>\n  <li>to ensure new Capital Projects are COMAH compliant and safe for Operation</li>\n  <li>to ensure compliance of all aspects of the Capital Projects with all regulatory and statutory provisions for operation and future maintenance criteria</li>\n  <li>to ensure Capital Projects are delivered in line with <abbr title=\"Oil and Pipelines Agency\">OPA</abbr> policies, strategies, processes</li>\n</ul>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2018-03-16T13:48:41Z","schema_name":"role","title":"Capital Projects Director","withdrawn":false},{"content_id":"0369d9ff-33b2-4042-a0e9-9a4876c15428","details":{"body":"<p>Responsible for The Oil and Pipelines Agency human resources.</p>\n","role_payment_type":null},"do