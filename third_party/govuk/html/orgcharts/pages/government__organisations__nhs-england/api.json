, NHS Improvement will help the NHS to meet its short-term challenges and secure its future.</p>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2016-04-01T11:09:26Z","schema_name":"role","title":"Chief Executive, NHS Improvement","withdrawn":false}]},"locale":"en","public_updated_at":"2025-11-06T10:59:39Z","schema_name":"role_appointment","title":"Jim Mackey - Chief Executive, NHS Improvement","withdrawn":false}]},"locale":"en","public_updated_at":"2025-11-06T12:10:06Z","schema_name":"person","title":"Sir Jim Mackey","web_url":"https://www.gov.uk/government/people/jim-mackey","withdrawn":false}],"ordered_parent_organisations":[{"analytics_identifier":"D12","api_path":"/api/content/government/organisations/department-of-health-and-social-care","api_url":"https://www.gov.uk/api/content/government/organisations/department-of-health-and-social-care","base_path":"/government/organisations/department-of-health-and-social-care","content_id":"7cd6bf12-bbe9-4118-8523-f927b0442156","details":{"acronym":"DHSC","brand":"department-of-health","default_news_image":{"high_resolution_url":"https://assets.publishing.service.gov.uk/media/627508178fa8f520738d5474/s960_DHSC_plaque.jpg","url":"https://assets.publishing.service.gov.uk/media/62750817e90e070dbf5acad5/s300_DHSC_plaque.jpg"},"logo":{"crest":"single-identity","formatted_title":"Department<br/>of Health &amp;<br/>Social Care"},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"Department of Health and Social Care","web_url":"https://www.gov.uk/government/organisations/department-of-health-and-social-care","withdrawn":false}],"ordered_roles":[{"content_id":"6b2432ef-f9f0-4e45-b476-5434247ed10a","details":{"body":"\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2025-11-06T11:08:33Z","