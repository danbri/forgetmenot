{"analytics_identifier":null,"base_path":"/government/ministers/comptroller-of-hm-household-government-whip","content_id":"dd4e6468-e7a9-4259-8524-29599794c2b7","description":"","details":{"attends_cabinet_type":null,"body":"\n","role_payment_type":null,"seniority":4,"supports_historical_accounts":false,"whip_organisation":{"label":"House of Commons","sort_order":1}},"document_type":"ministerial_role","first_published_at":"2018-01-09T17:37:17+00:00","links":{"available_translations":[{"api_path":"/api/content/government/ministers/comptroller-of-hm-household-government-whip","api_url":"https://www.gov.uk/api/content/government/ministers/comptroller-of-hm-household-government-whip","base_path":"/government/ministers/comptroller-of-hm-household-government-whip","content_id":"dd4e6468-e7a9-4259-8524-29599794c2b7","document_type":"ministerial_role","links":{},"locale":"en","public_updated_at":"2026-05-12T20:45:41Z","schema_name":"role","title":"Comptroller of HM Household (Government Whip) ","web_url":"https://www.gov.uk/government/ministers/comptroller-of-hm-household-government-whip","withdrawn":false}],"role_appointments":[{"content_id":"dc1d5038-fe6c-4a88-803e-66131b7098f6","details":{"current":true,"ended_on":null,"person_appointment_order":3,"started_on":"2026-05-12T00:00:00+01:00"},"document_type":"role_appointment","links":{"person":[{"api_path":"/api/content/government/people/gen-kitchen","api_url":"https://www.gov.uk/api/content/government/people/gen-kitchen","base_path":"/government/people/gen-kitchen","content_id":"90b1f683-b368-4087-acf8-b6b8765b487e","details":{"body":"<p>Gen Kitchen was appointed Comptroller of HM Household (Government Whip) on 12 May 2026.</p>\n\n<p>She was previously Junior Lord of the Treasury (Government Whip) between 16 September 2025 and 12 May 2026 and Assistant Whip, House of Commons between 20 July 2024 and 16 September 2025.</p>\n\n<p>She was elected as the MP for Wellingborough and Rushden in July 2024.</p>\n","image":{"url":"ht