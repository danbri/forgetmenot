/www.gov.uk/government/people/caroline-harold","withdrawn":false},{"api_path":"/api/content/government/people/douglas-wilson","api_url":"https://www.gov.uk/api/content/government/people/douglas-wilson","base_path":"/government/people/douglas-wilson","content_id":"1986afe2-0e86-49a8-bbe5-7a522aeab09e","details":{"image":{"url":"https://assets.publishing.service.gov.uk/media/67a354a2b74b3d9dfe36ca82/s465_Doug_Portrait_GOVUK.png"},"privy_counsellor":false},"document_type":"person","links":{"role_appointments":[{"content_id":"f6d9ae5b-955d-49f5-90ac-86f62fe7ea3c","details":{"current":false,"ended_on":"2026-04-12T00:00:00+01:00","person_appointment_order":2,"started_on":"2021-07-12T00:00:00+01:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"8461ad63-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Director General of the Attorney General’s Office (<abbr title=\"Attorney General's Office\">AGO</abbr>) heads a team of 55-60 legal, policy and corporate professionals, who support the Attorney General and Solicitor General across the range of their functionss.</p>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2022-07-11T19:16:32Z","schema_name":"role","title":"Director General of the Attorney General's Office (AGO)","withdrawn":false}]},"locale":"en","public_updated_at":"2026-04-23T11:53:48Z","schema_name":"role_appointment","title":"Douglas Wilson KC (Hon) OBE - Director General of the Attorney General's Office (AGO)","withdrawn":false},{"content_id":"ae91a827-8e3f-48f0-a568-804eac6c4cbd","details":{"current":true,"ended_on":null,"person_appointment_order":4,"started_on":"2026-04-13T00:00:00+01:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"84704914-c0f1-11e4-8223-005056011aef","details":{"body":"\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2013-11-27T14:49:52Z","schema_name":"role","title":"Crown's Nominee","withdrawn":false}]},"locale":"en","public_updated_at":"2026-04-23T11:39:28Z","schema_name":"role_appointment","title":"Douglas Wilson KC (Hon) OBE - Crown's Nominee","withdrawn":false},{"content_id":"d0c865ff-bfd2-499c-9a93-ffd145638872","details":{"current":true,"ended_on":null,"person_appointment_order":3,"started_on":"2026-04-13T00:00:00+01:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"84704aec-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Treasury Solicitor is the government’s most senior legal official and Permanent Secretary of the Government Legal Department. The department provides the full range of legal services to government departments and other public bodies including:</p>\n\n<ul>\n  <li>expert advisory, litigation, commercial and employment law services</li>\n  <li>drafting statutory instruments and other subordinate legislation</li>\n  <li>advice on the development of new legislation, preparing instructions for bills to be drafted by Parliamentary counsel and assisting in the handling of bills in Parliament</li>\n  <li>advice on legal policy and practice</li>\n</ul>\n\n<p>The department is also responsible for collecting, managing and disposing of bona vacantia (ownerless property and other assets) in England, Wales and Northern Ireland.</p>\n\n<p>In addition the Treasury Solicitor acts as head of profession for the wider Government Legal Profession, which includes a number of government legal teams outside GLD.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2021-10-06T11:55:47Z","schema_name":"role","title":"HM Procurator General, Treasury Solicitor and Head of the Government Legal Profession ","withdrawn":false}]},"locale":"en","public_updated_at":"2026-04-23T10:00:17Z","schema_name":"role_appointment","title":"Douglas Wilson KC (Hon) OBE - HM Procurator General, Treasury Solicitor and Head of the Government Legal Profession ","withdrawn":false},{"content_id":"20ba1522-45f3-4513-8e63-e5b3fba9e65c","details":{"current":false,"ended_on":"2016-12-31T00:00:00+00:00","person_appointment_order":3750,"started_on":"2014-07-01T00:00:00+01:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"5087470b-7d9e-4000-9780-985c2c3f245e","details":{"body":"<p>The Legal Director is the deputy legal adviser, and oversees 4 teams responsible for a wide range of legal work including national security, foreign relations, international institutions and overseas territories and maritime affairs.</p>\n","role_payment_type":null},"document_type":"worldwide_office_staff_role","links":{},"locale":"en","public_updated_at":"2017-03-31T14:44:09Z","schema_name":"role","title":"Legal Director","withdrawn":false}]},"locale":"en","public_updated_at":"2018-06-07T14:29:14Z","schema_name":"role_appointment","title":"Douglas Wilson OBE - Legal Director","withdrawn":false}]},"locale":"en","public_updated_at":"2026-04-23T09:29:21Z","schema_name":"person","title":"Douglas Wilson KC (Hon) OBE","web_url":"https://www.gov.uk/government/people/douglas-wilson","withdrawn":false}],"ordered_contacts":[{"content_id":"bd1ffd2c-bf6c-4fae-af6e-5c744403079a","details":{"contact_form_links":null,"description":"Please use this email address for all enquiries relating to deceased person's estates.","email_addresses":[{"email":"bvestates@governmentlegal.gov.uk","title":"Government Legal Department (BVD)"}],"phone_numbers":[{"number":"020 7210 4700","title":"Switchboard"}],"post_addresses":[{"iso2_country_code":"gb","locality":"Croydon","postal_code":"CR0 2WF","street_address":"1 Ruskin Square","title":"Government Legal Department (BVD)","world_location":"United Kingdom"}],"title":"Bona Vacantia - Estates"},"document_type":"contact","links":{},"locale":"en","public_updated_at":"2024-03-21T10:07:04Z","schema_name":"contact","title":"Bona Vacantia - Estates","withdrawn":false},{"content_id":"ba7e39c1-b0f5-4e3f-af14-44e8fbaacfae","d