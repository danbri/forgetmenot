alse}],"ordered_parent_organisations":[{"analytics_identifier":"D1382","api_path":"/api/content/government/organisations/department-for-business-and-trade","api_url":"https://www.gov.uk/api/content/government/organisations/department-for-business-and-trade","base_path":"/government/organisations/department-for-business-and-trade","content_id":"aa750cdf-7925-429d-a2b3-0d9fa47d2c48","details":{"acronym":"DBT","brand":"department-for-business-trade","default_news_image":{"high_resolution_url":"https://assets.publishing.service.gov.uk/media/64539946faf4aa0012e132d1/s960_DBT_Plaque-2.jpg","url":"https://assets.publishing.service.gov.uk/media/64539946c33b46000cf5e655/s300_DBT_Plaque-2.jpg"},"logo":{"crest":"dbt","formatted_title":"Department for<br/>Business &amp; Trade"},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"Department for Business and Trade","web_url":"https://www.gov.uk/government/organisations/department-for-business-and-trade","withdrawn":false},{"analytics_identifier":"D241","api_path":"/api/content/government/organisations/uk-export-finance","api_url":"https://www.gov.uk/api/content/government/organisations/uk-export-finance","base_path":"/government/organisations/uk-export-finance","content_id":"c4e41647-ad69-4e96-843b-05fa7867bbc0","details":{"acronym":"UKEF","brand":"department-for-business-trade","default_news_image":{"high_resolution_url":"https://assets.publishing.service.gov.uk/media/65e72e717bc3290adab8c22e/s960_Main_UKEF_cover_image.png","url":"https://assets.publishing.service.gov.uk/media/65e72e713f6945a006036063/s300_Main_UKEF_cover_image.png"},"logo":{"crest":"dbt","formatted_title":"UK Export <br/>Finance"},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"UK Export Finance","web_url":"https://www.gov.uk/government/organisations/uk-export-finance","withdrawn":false}],"role_appointments":[{"content_id":"7fa02a8b-376a-469c-b06e-edd86fdebd3f","details":{"current":true,"ended_on":null,"person_appointment_order":3,"started_on":"2025-09-06T00:00:00+01:00"},"document_type":"role_appointment","links":{"person":[{"api_path":"/api/content/government/people/chris-bryant","api_url":"https://www.gov.uk/api/content/government/people/chris-bryant","base_path":"/government/people/chris-bryant","content_id":"701ce38d-c098-4090-bcef-23fe4000bdaf","details":{"body":"<p>Sir Chris Bryant was appointed Minister of State at the Department for Business and Trade on 6 September 2025.</p>\n\n<p>He was previously Minister of State at the Department for Science, Innovation and Technology and the Department for Culture, Media and Sport between 8 July 2024 and 6 September 2025.</p>\n\n<p>He was elected as the <abbr title=\"member of Parliament\">MP</abbr> for Rhondda and Ogmore (previously Rhondda) on 7 June 2001.  </p>\n\n<p>He studied English at Mansfield College, Oxford, and theology at (<abbr title=\"Instituto Superior Evangélico de Estudios Teológicos \">ISEDET</abbr>) in Buenos Aires and at Ripon College, Cuddeson, Oxford.</p>\n\n<h2 id=\"parliamentary-career\">Parliamentary career </h2>\n\n<p>Sir Chris Bryant was Chair of the House of Commons Committees of Standards and Privileges from 2020 to 2023 and a Member of the Foreign Affairs Committee from 2017 to 2023. </p>\n\n<p>He was Shadow Culture Secretary in 2015 and Shadow Leader of the House of Commons from 2015 to 2016. </p>\n\n<p>He was Parliamentary Under-Secretary of State for Europe and Asia from 2009 to 2010. </p>\n\n<p>He was Deputy Leader of the House of Commons from 2008 to 2009.  </p>\n\n<p>He was Parliamentary Private Secretary to the Deputy Leader of the House of Commons in 2008.</p>\n\n<h2 id=\"early-career\">Early career </h2>\n\n<p>Sir Chris Bryant was an ordained priest and served as a curate at the Church of All Saints, High Wycombe from 1986 to 1989, and Youth Chaplain to the Diocese of Peterborough from 1989 to 1991, when he left the ministry and started work as the election agent to the Holborn and St Pancras Constituency Labour Party.  </p>\n\n<p>He was elected to Hackney Borough Council in 1993, representing Leabridge ward, and served until 1998. </p>\n\n<p>From 1998 until his election to Parliament in 2001, Bryant was the Head of European Affairs for the BBC. </p>\n\n<p>He has published several books on British political and parliamentary history.  </p>\n\n","image":{"alt_text":"Sir Chris Bryant MP","url":"https://assets.publishing.service.gov.uk/media/66a0cba1ab418ab055592c17/s465_minister_bryant_govuk.jpg"}},"document_type":"person","links":{},"locale":"en","public_updated_at":"2025-09-06T16:04:44Z","schema_name":"person","title":"Sir Chris Bryant MP","web_url":"https://www.gov.uk/government/people/chris-bryant","withdrawn":false}],"role":[{"api_path":"/api/content/government/ministers/minister-of-state--206","api_url":"https://www.gov.uk/api/content/government/ministers/minister-of-state--206","base_path":"/government/ministers/minister-of-state--206","content_id":"2a57ee0f-2a15-4f12-bf79-3c14c9c9d021","details":{"body":"<p>His portfolio includes:</p>\n\n<ul>\n  <li>trade strategy implementation  </li>\n  <li>WTO and CPTPP  </li>\n  <li>Free Trade Agreements  </li>\n  <li>international industrial strategy  </li>\n  <li>export strategy and trade promotion  </li>\n  <li>EU, Windsor Framework, and UK Internal Market  </li>\n  <li>Ukraine reconstruction  </li>\n  <li>creative industries </li>\n  <li>economic and investment security </li>\n  <li>trade remedies </li>\n  <li>sanctions  </li>\n  <li>import / export controls </li>\n</ul>\n\n<p>Public bodies:  </p>\n\n<ul>\n  <li>Trade Remedies Authority  </li>\n  <li>UK Export Finance</li>\n</ul>\n","role_payment_type":null,"seniority":100,"whip_organisation":{}},"document_type":"ministerial_role","links":{"ordered_parent_organisa