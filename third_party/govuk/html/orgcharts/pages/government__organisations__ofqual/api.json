api/content/government/people/michael-hanton","base_path":"/government/people/michael-hanton","content_id":"8a1012b6-6ca9-4423-b2b9-d7d69c77cfc4","details":{"image":{"alt_text":"Michael Hanton","url":"https://assets.publishing.service.gov.uk/media/62b479a4d3bf7f0affd6560f/s465_MHanton_002_960x640.png"},"privy_counsellor":false},"document_type":"person","links":{"role_appointments":[{"content_id":"9d481201-9076-48ac-a2fe-b648ca125416","details":{"current":true,"ended_on":null,"person_appointment_order":2,"started_on":"2022-10-24T00:00:00+01:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"df1e84c1-0df1-4577-9fb8-5b2be83f934e","details":{"body":"<p>The deputy chief regulator is accountable for:</p>\n\n<ul>\n  <li>leadership of Ofqual’s regulation across general, vocational and technical qualifications, to ensure that Ofqual is effective in regulating on behalf of students and apprentices</li>\n  <li>effective use of Ofqual’s rule-making powers, regulatory tools and enforcement powers</li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2023-02-20T09:37:58Z","schema_name":"role","title":"Deputy Chief Regulator, Ofqual","withdrawn":false}]},"locale":"en","public_updated_at":"2023-02-20T09:41:05Z","schema_name":"role_appointment","title":"Michael Hanton - Deputy Chief Regulator, Ofqual","withdrawn":false},{"content_id":"1e8e7742-8975-4dc8-9372-eaeb7fe2172f","details":{"current":false,"ended_on":"2022-10-23T00:00:00+01:00","person_appointment_order":1,"started_on":"2022-03-28T00:00:00+01:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"5e3cfd86-d73f-4d68-857e-edcc53235ec2","details":{"body":"<p>The Executive Director, Strategy is responsible for:</p>\n\n<ul>\n  <li>leading Ofqual’s regulatory strategy, planning, insight, economics, and risk functions </li>\n  <li>leading Ofqual’s response to reform programmes and technological innovation </li>\n  <li>leading Ofqual’s external communications, media, production and content work</li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2024-02-14T08:49:20Z","schema_name":"role","title":"Executive Director, Strategy, Ofqual","withdrawn":false}]},"locale":"en","public_updated_at":"2022-12-19T16:54:01Z","schema_name":"role_appointment","title":"Michael Hanton - Executive Director, Strategy, Ofqual","withdrawn":false}]},"locale":"en","public_updated_at":"2023-02-20T09:42:40Z","schema_name":"person","title":"Michael Hanton","web_url":"https://www.gov.uk/government/people/michael-hanton","withdrawn":false},{"api_path":"/api/content/government/people/amanda-swann","api_url":"https://www.gov.uk/api/content/government/people/amanda-swann","base_path":"/government/people/amanda-swann","content_id":"809dfffc-e8fc-4eec-b341-028bda172993","details":{"image":{"alt_text":"Amanda Swann","url":"https://assets.publishing.service.gov.uk/media/65cc83cb39a8a7000c60d4f2/s465_Amanda_Swann_4.png"},"privy_counsellor":false},"document_type":"person","links":{"role_appointments":[{"content_id":"1e5cebaa-fc62-458f-a341-9333cfee7d9e","details":{"current":false,"ended_on":"2025-11-02T00:00:00+00:00","person_appointment_order":1,"started_on":"2023-10-10T00:00:00+01:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"8477fd4e-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Executive Director for General Qualifications is responsible for:</p>\n\n<ul>\n  <li>developing Ofqual’s strategies for reform and regulation of GCSEs, AS and A levels</li>\n  <li>maintaining relationships with major stakeholders for GCSEs, AS and A levels</li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2015-06-30T15:07:39Z","schema_name":"role","title":"Executive Director for General Qualifications, Ofqual","withdrawn":false}]},"locale":"en","public_updated_at":"2025-11-03T09:09:34Z","schema_name":"role_appointment","title":"Amanda Swann - Executive Director for General Qualifications, Ofqual","withdrawn":false},{"content_id":"d43c6a8d-c609-46f7-8f64-c1b837288baa","details":{"current":true,"ended_on":null,"person_appointment_order":2,"started_on":"2025-11-03T00:00:00+00:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"b04a4781-16b2-45f5-bc7c-516d8faaf643","details":{"body":"<p>The Executive Director of Delivery is responsible for:</p>\n\n<ul>\n  <li>effective regulation of qualifications taken by students in schools and colleges, apprenticeship assessments and national assessments in primary schools.</li>\n  <li>effective regulatory relationships with the responsible officers of awarding organisations</li>\n  <li>leading incident management to secure quality and fairness for students and public confidence in regulated qualifications</li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2025-11-07T09:20:40Z","schema_name":"role","title":"Executive Director of Delivery, Ofqual","withdrawn":false}]},"locale":"en","public_updated_at":"2025-11-03T09:07:52Z","schema_name":"role_appointment","title":"Amanda Swann - Exectuive Director of Delivery, Ofqual","withdrawn":false}]},"locale":"en","public_updated_at":"2025-11-03T09:08:26Z","schema_name":"person","title":"Amanda Swann","web_url":"https://www.gov.uk/government/people/amanda-swann","withdrawn":false},{"api_path":"/api/content/government/people/catherine-large","api_url":"https://www.gov.uk/api/content/government/people/catherine-large","base_path":"/government/people/catherine-large","content_id":"36fdf7d0-2348-4146-96b7-7b51bc663fbb","details":{"image":{"url":"https://assets.publishing.service.gov.uk/media/69de47bbb0b0b93055e04f7b/s465_Catherine_Large.JPG"},"privy_counsellor":false},"document_type":"person","links":{"role_appointments":[{"content_id":"df3a5acf-e068-4f4f-980a-f60c15af8f5d","d