Gutteridge_001_960x640.png"},"privy_counsellor":false},"document_type":"person","links":{"role_appointments":[{"content_id":"c32d6b20-f74e-4da9-a03a-b18866c88b0b","details":{"current":true,"ended_on":null,"person_appointment_order":1,"started_on":"2022-03-01T00:00:00+00:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"3e95adf4-a45b-40eb-a790-845d9bc762a8","details":{"body":"<p>The General Counsel’s responsibilities include:</p>\n\n<ul>\n  <li>to act as Ofqual’s senior legal adviser</li>\n  <li>to provide strategic legal advice to the Chief Regulator, the Board and its committees in respect of Ofqual’s statutory objectives, duties and functions</li>\n  <li>to direct and co-ordinate the provision of legal services, encompassing governance, enforcement, information rights, data protection, corporate and commercial advice</li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2026-03-19T15:39:35Z","schema_name":"role","title":"General Counsel, Ofqual","withdrawn":false}]},"locale":"en","public_updated_at":"2024-02-14T12:25:24Z","schema_name":"role_appointment","title":"Daniel Gutteridge - General Counsel, Ofqual","withdrawn":false}]},"locale":"en","public_updated_at":"2024-02-14T11:52:13Z","schema_name":"person","title":"Daniel Gutteridge","web_url":"https://www.gov.uk/government/people/daniel-gutteridge","withdrawn":false},{"api_path":"/api/content/government/people/tom-bramley","api_url":"https://www.gov.uk/api/content/government/people/tom-bramley","base_path":"/government/people/tom-bramley","content_id":"6054228a-2975-4611-9fb5-77e7f5579bf1","details":{"image":{"alt_text":"Tom Bramley","url":"https://assets.publishing.service.gov.uk/media/666315e0a8f98e4a64ca9502/s465_Tom_Bramley.jpg"},"privy_counsellor":false},"document_type":"person","links":{"role_appointments":[{"content_id":"e39a6fa3-ba27-4276-b4fa-431f9db445c3","details":{"current":true,"ended_on":null,"person_appointment_order":1,"started_on":"2024-05-06T00:00:00+01:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"f5db92db-767a-4359-992f-73bb8444e71a","details":{"body":"<p>The Executive Director, Research and Analysis is responsible for ensuring that research and data analysis are used to:</p>\n\n<ul>\n  <li>\n    <p>enable effective regulation of qualifications for quality and fairness</p>\n  </li>\n  <li>\n    <p>inform policy development in the advancement of Ofqual’s statutory objectives and in the interests of students and apprentices</p>\n  </li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2024-06-07T15:21:45Z","schema_name":"role","title":"Executive Director, Research and Analysis, Ofqual","withdrawn":false}]},"locale":"en","public_updated_at":"2024-06-07T14:28:09Z","schema_name":"role_appointment","title":"Tom Bramley - Executive Director, Research & Analysis, Ofqual","withdrawn":false}]},"locale":"en","public_updated_at":"2024-06-07T14:19:28Z","schema_name":"person","title":"Tom Bramley","web_url":"https://www.gov.uk/government/people/tom-bramley","withdrawn":false}],"ordered_contacts":[{"content_id":"65ee3d9f-ef24-4935-b276-da6d68122bfa","details":{"contact_form_links":[{"link":"https://www.gov.uk/guidance/contact-ofqual"}],"description":"You can get in touch with us if you have a question about the qualifications or awarding bodies we regulate.\r\n \r\nOur phone line is open from 9am to 5pm, Monday to Friday.\r\n\r\nWhen you contact Ofqual, a third-party may handle your call. We have arrangements with them to ensure the security of your information. They cannot do anything with your information without our instructions. You can find out more in our Personal Information Charter.\r\n \r\nWe aim to respond to emails as quickly as possible. Sometimes it may take us longer than usual to respond, for example, when we are experiencing higher volumes of emails than normal.","email_addresses":null,"phone_numbers":[{"number":"0300 303 3344","title":"Telephone"}],"post_addresses":[{"iso2_country_code":"gb","locality":"Station Square","postal_code":"CV1 2GN","region":"Coventry","street_address":"2nd floor, 1 Friargate","title":"Ofqual","world_location":"United Kingdom"}],"title":"Enquiries"},"document_type":"contact","links":{},"locale":"en","public_updated_at":"2025-03-06T12:30:45Z","schema_name":"contact","title":"Enquiries","withdrawn":false}],"ordered_foi_contacts":[{"content_id":"de994fe3-b76c-41bb-b99e-c30196cb0196","details":{"contact_form_links":[{"link":"https://contact.ofqual.gov.uk/freedom-of-information-request/start"}],"description":null,"email_addresses":null,"phone_numbers":null,"post_addresses":[],"title":"Freedom of Information"},"document_type":"contact","links":{},"locale":"en","public_updated_at":"2022-09-28T16:05:45Z","schema_name":"contact","title":"Freedom of Information","withdrawn":false}],"ordered_parent_organisations":[{"analytics_identifier":"D6","api_path":"/api/content/government/organisations/department-for-education","api_url":"https://www.gov.uk/api/content/government/organisations/department-for-education","base_path":"/government/organisations/department-for-education","content_id":"ebd15ade-73b2-4eaf-b1c3-43034a42eb37","details":{"acronym":"DfE","brand":"department-for-education","default_news_image":{"high_resolution_url":"https://assets.publishing.service.gov.uk/media/69de23bb9af91e9ee4b2c327/s960_DfE_Sanctuary_Building_London_office.jpeg","url":"https://assets.publishing.service.gov.uk/media/69de23bb3e81003ae042250c/s300_DfE_Sanctuary_Building_London_office.jpeg"},"logo":{"crest":"single-identity","formatted_title":"Department <br/>for Education"},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"Department for Education","web_url":"https://www.gov.uk/government/organisations/department-for-education","withdrawn":false}],"ordered_roles":[{"content_id":"8477c9f2-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Chief Regulator answers to Parliament and also serves as the Chief Executive and Accounting Officer. It’s their role to make sure that the organisation carries out the board’s strategy, and that Ofqual has the resources and structure it needs to do its work effectively. As Accounting Officer to Ofqual, the Chief Regulator is accountable for Ofqual’s deployment of public funds.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2021-09-20T08:32:12Z","schema_name":"role","title":"Chief Regulator, Ofqual","withdrawn":false},{"content_id":"8477f81b-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The chair of the board is responsible for leading the board and overseeing the governance of Ofqual.</p>\n\n<p>The chair makes sure that the:</p>\n\n<ul>\n  <li>board’s strategic direction is carried out by the organisation</li>\n  <li>organisation carries out its statutory duties and responsibilities</li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2014-11-04T17:53:15Z","schema_name":"role","title":"Chair, Ofqual","withdrawn":false},{"content_id":"8477f8b8-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Chief Operating Officer is responsible for:</p>\n\n<ul>\n  <li>directing, shaping and leading Ofqual’s regulatory operational activities</li>\n  <li>directing, shaping and leading Ofqual’s corporate and business services</li>\n  <li>contributing to Ofqual’s strategic leadership including the full range of their regulatory outcomes and statutory objectives</li>\n</ul>\n\n<p>They are also the executive director for the organisation’s support services, which are:</p>\n\n<ul>\n  <li>human resources</li>\n  <li>finance</li>\n  <li>information management and technology</li>\n  <li>communications</li>\n  <li>customer services</li>\n  <li>procurement</li>\n  <li>project and programme management</li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2018-10-02T08:53:27Z","schema_name":"role","title":"Chief Operating Officer, Ofqual","withdrawn":false},{"content_id":"8477f959-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Acting Executive Director for Strategy, Risk and Research is responsible for:</p>\n\n<ul>\n  <li>the organisation’s risk policy</li>\n  <li>programmes of research that inform the way Ofqual regulates</li>\n  <li>developing the organisation’s strategy</li>\n  <li>the legal team</li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2022-01-24T11:44:31Z","schema_name":"role","title":"Executive Director for Strategy, Risk and Research, Ofqual","withdrawn":false},{"content_id":"8477fc91-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Executive Director for Vocational and Technical Qualifications is responsible for:</p>\n\n<ul>\n  <li>developing Ofqual’s strategies for regulation of vocational qualifications</li>\n  <li>maintaining relationships with major stakeholders for vocational qualifications</li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2021-04-01T07:44:41Z","schema_name":"role","title":"Executive Director for Vocational and Technical Qualifications, Ofqual","withdrawn":false},{"content_id":"8477fd4e-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Executive Director for General Qualifications is responsible for:</p>\n\n<ul>\n  <li>developing Ofqual’s strategies for reform and regulation of GCSEs, AS and A levels</li>\n  <li>maintaining relationships with major stakeholders for GCSEs, AS and A levels</li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2015-06-30T15:07:39Z","schema_name":"role","title":"Executive Director for General Qualifications, Ofqual","withdrawn":false},{"content_id":"5e3cfd86-d73f-4d68-857e-edcc53235ec2","details":{"body":"<p>The Executive Director, Strategy is responsible for:</p>\n\n<ul>\n  <li>leading Ofqual’s regulatory strategy, planning, insight, economics, and risk functions </li>\n  <li>leading Ofqual’s response to reform programmes and technological innovation </li>\n  <li>leading Ofqual’s external communications, media, production and content work</li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2024-02-14T08:49:20Z","schema_name":"role","title":"Executive Director, Strategy, Ofqual","withdrawn":false},{"content_id":"df1e84c1-0df1-4577-9fb8-5b2be83f934e","details":{"body":"<p>The deputy chief regulator is accountable for:</p>\n\n<ul>\n  <li>leadership of Ofqual’s regulation across general, vocational and technical qualifications, to ensure that Ofqual is effective in regulating on behalf of students and apprentices</li>\n  <li>effective use of Ofqual’s rule-making powers, regulatory tools and enforcement powers</li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2023-02-20T09:37:58Z","schema_name":"role","title":"Deputy Chief Regulator, Ofqual","withdrawn":false},{"content_id":"65934cc3-8afa-41d5-937a-c1bdf0e8cde2","details":{"body":"<p>The Executive Director, Finance and Operations is responsible for:</p>\n\n<ul>\n  <li>Ofqual’s Finance, HR, and Digital, Data and Technology teams </li>\n  <li>overall co-ordination, planning and management of financial and non-financial resources to meet Ofqual’s regulatory objectives</li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2025-11-03T09:10:47Z","schema_name":"role","title":"Executive Director, Finance and Operations, Ofqual","withdrawn":false},{"content_id":"3e95adf4-a45b-40eb-a790-845d9bc762a8","details":{"body":"<p>The General Counsel’s responsibilities include:</p>\n\n<ul>\n  <li>to act as Ofqual’s senior legal adviser</li>\n  <li>to provide strategic legal advice to the Chief Regulator, the Board and its committees in respect of Ofqual’s statutory objectives, duties and functions</li>\n  <li>to direct and co-ordinate the provision of legal services, encompassing governance, enforcement, information rights, data protection, corporate and commercial advice</li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2026-03-19T15:39:35Z","schema_name":"role","title":"General Counsel, Ofqual","withdrawn":false},{"content_id":"f5db92db-767a-4359-992f-73bb8444e71a","details":{"body":"<p>The Executive Director, Research and Analysis is responsible for ensuring that research and data analysis are used to:</p>\n\n<ul>\n  <li>\n    <p>enable effective regulation of qualifications for quality and fairness</p>\n  </li>\n  <li>\n    <p>inform policy development in the advancement of Ofqual’s statutory objectives and in the interests of students and apprentices</p>\n  </li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2024-06-07T15:21:45Z","schema_name":"role","title":"Executive Director, Research and Analysis, Ofqual","withdrawn":false},{"content_id":"d340b8eb-8b23-4c02-9c78-90da21153a7d","details":{"body":"<p>The Executive Director for Standards is responsible for:</p>\n\n<ul>\n  <li>leading and securing, on behalf of Ofqual, that standards in regulated qualifications are set and maintained fairly</li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2024-06-07T14:39:35Z","schema_name":"role","title":"Executive Director for Standards, Ofqual","withdrawn":false},{"content_id":"27673e9c-c139-4653-b2bf-781e93a7408f","details":{"body":"<p>The Executive Director for Standards, Research and Analysis is responsible for:</p>\n\n<ul>\n  <li>leading and securing, on behalf of Ofqual, that standards in regulated qualifications are set and maintained fairly</li>\n  <li>research and data analysis (including official statistics) to support our regulation in the interests of students and apprentices</li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2022-01-24T11:40:40Z","schema_name":"role","title":"Executive Director, Standards, Research and Analysis, Ofqual","withdrawn":false},{"content_id":"b04a4781-16b2-45f5-bc7c-516d8faaf643","details":{"body":"<p>The Executive Director of Delivery is responsible for:</p>\n\n<ul>\n  <li>effective regulation of qualifications taken by students in schools and colleges, apprenticeship assessments and national assessments in primary schools.</li>\n  <li>effective regulatory relationships with the responsible officers of awarding organisations</li>\n  <li>leading incident management to secure quality and fairness for students and public confidence in regulated qualifications</li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2025-11-07T09:20:40Z","schema_name":"role","title":"Executive Director of Delivery, Ofqual","withdrawn":false},{"content_id":"5f37db0a-e763-416c-9de6-869e9cd4801b","details":{"body":"<p>The Executive Director of Policy is responsible for:</p>\n\n<ul>\n  <li>the development and maintenance of policy for GCSEs and A levels</li>\n  <li>developing and maintaining influential relationships with senior stakeholders throughout the education system</li>\n  <li>leading the development of Ofqual policy to support the effective regulation of qualifications</li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2025-11-06T12:48:50Z","schema_name":"role","title":"Executive Director of Policy, Ofqual","withdrawn":false}],"organisations":[{"analytics_identifier":"D109","api_path":"/api/content/government/organisations/ofqual","api_url":"https://www.gov.uk/api/content/government/organisations/ofqual","base_path":"/government/organisations/ofqual","content_id":"83f6e93f-bb2c-46ab-9b02-394f972b7030","details":{"acronym":"Ofqual","brand":"department-for-education","default_news_image":{"high_resolution_url":"https://assets.publishing.service.gov.uk/media/5bba558c40f0b664e26be324/s960_Default_News_Image.jpg","url":"https://assets.publishing.service.gov.uk/media/5bba558ce5274a2252092fcc/s300_Default_News_Image.jpg"},"logo":{"crest":"custom","formatted_title":"Ofqual","image":{"alt_text":"Ofqual","url":"https://assets.publishing.service.gov.uk/media/5bba55baed915d23b049e12f/ofqual_gov_uk_logo.png"}},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"Ofqual","web_url":"https://www.gov.uk/government/organisations/ofqual","withdrawn":false}],"primary_publishing_organisation":[{"analytics_identifier":"D109","api_path":"/api/content/government/organisations/ofqual","api_url":"https://www.gov.uk/api/content/government/organisations/ofqual","base_path":"/government/organisations/ofqual","content_id":"83f6e93f-bb2c-46ab-9b02-394f972b7030","details":{"acronym":"Ofqual","brand":"department-for-education","default_news_image":{"high_resolution_url":"https://assets.publishing.service.gov.uk/media/5bba558c40f0b664e26be324/s960_Default_News_Image.jpg","url":"https://assets.publishing.service.gov.uk/media/5bba558ce5274a2252092fcc/s300_Default_News_Image.jpg"},"logo":{"crest":"custom","formatted_title":"Ofqual","image":{"alt_text":"Ofqual","url":"https://assets.publishing.service.gov.uk/media/5bba55baed915d23b049e12f/ofqual_gov_uk_logo.png"}},"organisation_govuk_status":{"status":"live","upda