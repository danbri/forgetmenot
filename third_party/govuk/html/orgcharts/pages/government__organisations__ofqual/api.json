n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2021-09-20T08:32:12Z","schema_name":"role","title":"Chief Regulator, Ofqual","withdrawn":false}]},"locale":"en","public_updated_at":"2024-01-02T09:04:49Z","schema_name":"role_appointment","title":"Sir Ian Bauckham CBE - Chief Regulator, Ofqual","withdrawn":false},{"content_id":"c6380bfe-0b46-4edd-b00d-4da439e086e8","details":{"current":false,"ended_on":"2023-12-31T00:00:00+00:00","person_appointment_order":1,"started_on":"2021-01-01T00:00:00+00:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"8477f81b-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The chair of the board is responsible for leading the board and overseeing the governance of Ofqual.</p>\n\n<p>The chair makes sure that the:</p>\n\n<ul>\n  <li>board’s strategic direction is carried out by the organisation</li>\n  <li>organisation carries out its statutory duties and responsibilities</li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2014-11-04T17:53:15Z","schema_name":"role","title":"Chair, Ofqual","withdrawn":false}]},"locale":"en","public_updated_at":"2024-01-02T09:03:33Z","schema_name":"role_appointment","title":"Sir Ian Bauckham CBE - Chair, Ofqual","withdrawn":false}]},"locale":"en","public_updated_at":"2024-01-02T13:28:07Z","schema_name":"person","title":"Sir Ian Bauckham CBE","web_url":"https://www.gov.uk/government/people/ian-bauckham","withdrawn":false},{"api_path":"/api/content/government/people/susan-tranter","api_url":"https://www.gov.uk/api/content/government/people/susan-tranter","base_path":"/government/people/susan-tranter","content_id":"590477ee-e0ae-4fbd-a8f0-215afabe4a72","details":{"image":{"alt_text":"Dr Susan Tranter","url":"https://assets.publishing.service.gov.uk/media/677bf1d56f01ae28ab5c040f/s465_STranter_Ofqual.jpg"},"privy_counsellor":false},"document_type":"person","lin