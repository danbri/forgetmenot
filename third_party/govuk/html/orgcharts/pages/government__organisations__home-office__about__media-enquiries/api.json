{"analytics_identifier":null,"base_path":"/government/organisations/home-office/about/media-enquiries","content_id":"5f5cf211-7631-11e4-a3cb-005056011aef","description":"","details":{"attachments":[],"body":"<div class=\"govspeak\"><h2 id=\"home-office-press-office\">Home Office press office</h2>\n\n<p>Journalists with enquiries can call the Home Office news desk on 0300 123 3535.</p>\n\n<p>The desk operates from 7am to 7pm, Monday to Friday.</p>\n\n<div class=\"call-to-action\">\n  <p>The Home Office press office is unable to answer calls from members of the public. If you are not a member of the media, <a href=\"https://www.gov.uk/guidance/contact-the-home-office\">find the right part of the Home Office to contact</a>.</p>\n</div>\n\n<h3 id=\"out-of-hours\">Out of hours</h3>\n\n<p>Press office out of hours number: 07623 514 628. Only urgent media calls will be attended to.</p>\n\n<h3 id=\"textphone-users\">Textphone users</h3>\n\n<p>Textphone: 07860 023 039. Start your message with 514 628, followed by a space and then your message up to 120 characters.</p>\n\n<div class=\"call-to-action\">\n  <p>Abuse of Home Office staff will not be tolerated. We reserve the right not to engage with anyone who acts in an abusive manner.</p>\n</div>\n</div>","change_history":[{"note":"Added a link to the Contact the Home Office page to help you find the right part of the Home Office to contact if you are not a member of the media.","public_timestamp":"2025-12-15T12:21:02Z"},{"note":"Added information to emphasise that the press office is unable to take calls from members of the public.","public_timestamp":"2025-03-04T16:49:54Z"},{"note":"A note to say that abuse of Home Office staff will not be tolerated has been added.","public_timestamp":"2024-01-17T11:32:43Z"},{"note":"Updated Home Office news desk closing time to 7pm.","public_timestamp":"2022-03-09T12:29:43Z"},{"note":"Updated chief press officer roles.","public_timestamp":"2020-08-04T15:52:40Z"},{"note":"Updated Home Office news desk number, Head of news, Deputy head of news and Chief press officers for newsdesk, counter-terrorism, and safeguarding and extremism and features and campaigns.","public_timestamp":"2020-01-09T16:16:28Z"},{"note":"Updated list of chief press officers","public_timestamp":"2019-06-07T10:48:48Z"},{"note":"Added new head of news and two new chief press officers for policing and immigration. ","public_timestamp":"2019-01-10T16:43:49Z"},{"note":"Updated contacts list.","public_timestamp":"2018-09-12T15:53:10Z"},{"note":"New press office out of hours number: 07623 514 628.","public_timestamp":"2018-03-21T12:05:21Z"},{"note":"Changes to deputy head of news and chief press officers.","public_timestamp":"2018-03-06T11:44:25Z"},{"note":"Update to contact points for chief press officers.","public_timestamp":"2018-01-04T11:20:17Z"},{"note":"Changes to press office senior management team.","public_timestamp":"2017-11-09T12:30:15Z"},{"note":"Team responsibilities updated. ","public_timestamp":"2017-03-30T10:55:23Z"},{"note":"Press officer information updated.","public_timestamp":"2016-01-07T14:33:02Z"},{"note":"First published.","public_timestamp":"2014-05-22T14:45:29Z"}],"headers":[{"headers":[{"id":"out-of-hours","level":3,"text":"Out of hours"},{"id":"textphone-users","level":3,"text":"Textphone users"}],"id":"home-office-press-office","level":2,"text":"Home Office press office"}],"organisation":"06056197-bc69-4147-aa28-070bca132178","tags":{"browse_pages":[]}},"document_type":"media_enquiries","first_published_at":"2014-05-22T16:45:29+01:00","links":{"available_translations":[{"api_path":"/api/content/government/organisations/home-office/about/media-enquiries","api_url":"https://www.gov.uk/api/content/government/organisations/home-office/about/media-enquiries","base_path":"/government/organisations/home-office/about/media-enquiries","content_id":"5f5cf211-7631-11e4-a3cb-005056011aef","document_type":"media_enquiries","links":{},"locale":"en","public_updated_at":"2025-