a63ea70d/s712_ProjectGigabitEssex_govuk.png","medium_resolution_url":"https://assets.publishing.service.gov.uk/media/6a01cb9881a251700a20b39c/s465_ProjectGigabitEssex_govuk.png","url":"https://assets.publishing.service.gov.uk/media/6a01cb982a6137e93226b989/ProjectGigabitEssex_govuk.png"},"public_updated_at":"2026-05-11T00:01:00.000+01:00","summary":"<div class=\"govspeak\"><p>9,500 more homes and businesses in Essex to receive faster, reliable internet as part of the government’s Project Gigabit roll out.  </p>\n</div>","title":"Digital future of Essex supercharged with 9,500 more homes and businesses getting upgraded broadband"},{"document_type":"Press release","href":"/government/news/new-gigabit-address-checker-launches-as-rural-britain-sees-surge-in-rollout-of-faster-broadband-and-mobile-coverage","image":{"alt_text":"","high_resolution_url":"https://assets.publishing.service.gov.uk/media/69b3ce32912f3f96bf687b66/s712_gigabit-address-checker-tool-govuk.png","medium_resolution_url":"https://assets.publishing.service.gov.uk/media/69b3ce32912f3f96bf687b65/s465_gigabit-address-checker-tool-govuk.png","url":"https://assets.publishing.service.gov.uk/media/69b3ce3297f6fef21f687b70/gigabit-address-checker-tool-govuk.png"},"public_updated_at":"2026-03-13T00:01:04.000+00:00","summary":"<div class=\"govspeak\"><p>People across England and Wales can find out if they are due a government-backed broadband upgrade with new gigabit address checker.</p>\n</div>","title":"New gigabit address checker launches as rural Britain sees surge in rollout of faster broadband and mobile coverage"},{"document_type":"Press release","href":"/government/news/signal-all-the-way-christmas-comes-early-as-over-100-mobile-masts-bring-4g-joy-to-britains-rural-communities","image":{"alt_text":"","high_resolution_url":"https://assets.publishing.service.gov.uk/media/694b2a0f3022cdf03a0eb944/s712_100Masts__1__1.png","medium_resolution_url":"https://assets.publishing.service.gov.uk/media/694b2a0f3022cdf03a0eb943/s465_100Masts__1__1.png","url":"https://assets.publishing.service.gov.uk/media/694b2a0f033693d5d50eb93f/100Masts__1__1.png"},"public_updated_at":"2025-12-23T00:00:00.000+00:00","summary":"<div class=\"govspeak\"><p>Over 100 mobile network masts upgraded to deliver 4G coverage from all major mobile network operators, signalling a major milestone in government’s drive to end total-not-spots</p>\n</div>","title":"Signal all the way! Christmas comes early as over 100 mobile masts bring 4G joy to Britain’s rural communities"},{"document_type":"Press release","href":"/government/news/northumberland-communities-connected-to-lightning-fast-broadband-in-project-gigabit-first","image":{"alt_text":"","high_resolution_url":"https://assets.publishing.service.gov.uk/media/68c3ed61efd87ef102c87649/s712_Northumberland_ProjectGigabit_govuk.png","medium_resolution_url":"https://assets.publishing.service.gov.uk/media/68c3ed617596dbfa052bff08/s465_Northumberland_ProjectGigabit_govuk.png","url":"https://assets.publishing.service.gov.uk/media/68c3ed61eeb238b20672aa50/Northumberland_ProjectGigabit_govuk.png"},"public_updated_at":"2025-09-12T10:30:02.000+01:00","summary":"<div class=\"govspeak\"><p>Over 3,800 homes and businesses across north Northumberland can now access lightning-fast broadband in a major milestone for Project Gigabit.</p>\n</div>","title":"Northumberland communities connected to lightning-fast broadband in Project Gigabit first"},{"document_type":"Press release","href":"/government/news/lesley-cowley-obe-appointed-as-chair-of-building-digital-uk","image":{"alt_text":"","high_resolution_url":"https://assets.publishing.service.gov.uk/media/685272b664cd9d9f5f1ec5d6/s712_BDUK_Chair_LC_govuk.png","medium_resolution_url":"https://assets.publishing.service.gov.uk/media/685272b6cf42a58f50cac9dc/s465_BDUK_Chair_LC_govuk.png","url":"https://assets.publishing.service.gov.uk/media/685272b6f2b86c081cfdb350/BDUK_Chair_LC_govuk.png"},"public_updated_at":"2025-06-18T09:00:04.0