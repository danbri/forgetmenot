emit of the AGO within 20 working days of receipt. However, we are unable to reply to matters that do not fall within the responsibility of the AGO\r\n\r\nCorrespondence that falls within the remit of the AGO will be stored in digital form only. Correspondence which falls outside the remit of the AGO will not be retained. The AGO will not keep hard copies of any material sent to us and we are unable to return them to the sender. Please ensure you only send copy material to us.\r\n","email_addresses":[{"email":"correspondence@attorneygeneral.gov.uk","title":"Attorney General’s Office"}],"phone_numbers":[{"number":"Please note we are not able to provide legal advice to members of the public or businesses.","title":"Telephone - 020 7271 2492"},{"number":"07825853529","title":"Out of hours number"}],"post_addresses":[{"iso2_country_code":"gb","locality":"London","postal_code":"SW1H 9EA","street_address":"102 Petty France","title":"Attorney General’s Office","world_location":"United Kingdom"}],"title":"Correspondence address"},"document_type":"contact","links":{},"locale":"en","public_updated_at":"2023-01-31T12:06:26Z","schema_name":"contact","title":"Correspondence address","withdrawn":false},{"content_id":"57c1b198-69de-4eb5-90a2-2fbe72395de5","details":{"contact_form_links":null,"description":"If you have an urgent media enquiry out of office hours, please contact the duty press officer or email press.office@attorneygeneral.gov.uk. Please note this number does not accept text messages.","email_addresses":[{"email":"press.office@attorneygeneral.gov.uk"}],"phone_numbers":[{"number":"020 7271 2443 / 020 4604 4700 / 020 7271 2479 ","title":"Office hours "},{"number":"07815853529","title":"Out of hours"}],"post_addresses":[{"iso2_country_code":"gb","locality":"London","postal_code":"SW1H 9EA","region":"London","street_address":"102 Petty France","world_location":"United Kingdom"}],"title":"Media enquiries"},"document_type":"contact","links":{},"locale":"en","public_updated_at":"2024-08-15T16:41:21Z","schema_name":"contact","title":"Media enquiries","withdrawn":false},{"content_id":"7fb43a6a-16da-4011-9d27-bc250f49c02c","details":{"contact_form_links":[{"link":"https://submit.forms.service.gov.uk/form/696/apply-to-have-an-unduly-lenient-sentence-reviewed/1808"}],"description":null,"email_addresses":null,"phone_numbers":null,"post_addresses":[],"title":"Refer a Crown Court Sentence"},"document_type":"contact","links":{},"locale":"en","public_updated_at":"2024-03-28T10:45:52Z","schema_name":"contact","title":"Refer a Crown Court Sentence","withdrawn":false},{"content_id":"577c1fde-b238-489b-83bb-0534cfafa5d9","details":{"contact_form_links":null,"description":null,"email_addresses":[{"email":"nominations@attorneygeneral.gov.uk"}],"phone_numbers":null,"post_addresses":[],"title":"Nominations of Counsel"},"document_type":"contact","links":{},"locale":"en","public_updated_at":"2017-11-22T14:20:42Z","schema_name":"contact","title":"Nominations of Counsel","withdrawn":false},{"content_id":"00c2435d-c187-49d9-87fe-4361e90cdec4","details":{"contact_form_links":null,"description":null,"email_addresses":[{"email":"Contempt.SharedMailbox@attorneygeneral.gov.uk "}],"phone_numbers":null,"post_addresses":[],"title":"Report Contempt of Court"},"document_type":"contact","links":{},"locale":"en","public_updated_at":"2018-06-01T14:04:48Z","schema_name":"contact","title":"Report Contempt of Court","withdrawn":false},{"content_id":"bd27615e-f6a8-437b-b38a-115b70260e5b","details":{"contact_form_links":null,"description":null,"email_addresses":[{"email":"informationrights@attorneygeneral.gov.uk"}],"phone_numbers":null,"post_addresses":[],"title":"Freedom of Information requests"},"document_type":"contact","links":{},"locale":"en","public_updated_at":"2026-05-05T13:36:56Z","schema_name":"contact","title":"Freedom of Information requests","withdrawn":false}],"ordered_ministers":[{"api_path":"/api/content/government/people/richard-hermer","api_url":"https://www.gov.uk/api/content/government/people/richard-hermer","base_path":"/government/people/richard-hermer","content_id":"35188c07-5c67-4433-950c-636b27e044aa","details":{"image":{"alt_text":"The Rt Hon Lord Hermer KC","url":"https://assets.publishing.service.gov.uk/media/66884381ab5fc5929851ba97/s465_richard-hermer.jpg"},"privy_counsellor":true},"document_type":"person","links":{"role_appointments":[{"content_id":"b0f6658c-4984-44df-bd59-4b32b80cd38e","details":{"current":true,"ended_on":null,"person_appointment_order":1,"started_on":"2024-07-05T00:00:00+01:00"},"document_type":"role_appointment","links":{"role":[{"api_path":"/api/content/government/ministers/attorney-general","api_url":"https://www.gov.uk/api/content/government/ministers/attorney-general","base_path":"/government/ministers/attorney-general","content_id":"845e6aa7-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Attorney General is chief legal adviser to the Crown and has a number of independent public interest functions, as well as overseeing the Law Officers’ departments.</p>\n\n<p>Responsibilities include:</p>\n\n<ul>\n  <li>Overall responsibility for the work of the Attorney General’s Office and superintended departments (the Government Legal Department, the Crown Prosecution Service, the Serious Fraud Office and HM Crown Prosecution Service Inspectorate)</li>\n  <li>Specific statutory duty to superintend the discharge of duties by the Director of Public Prosecutions (who heads the Crown Prosecution Service) and the Director of the Serious Fraud Office</li>\n  <li>Non-statutory general oversight of the Government Legal Department, the Services Prosecuting Authority, and government prosecuting departments</li>\n  <li>Government’s principal legal adviser dealing with (amongst others) questions of public law, international law, human rights and devolution</li>\n  <li>Public interest functions, for example, reference of unduly lenient sentences to the Court of Appeal, bringing proceedings for contempt of court and intervention in certain proceedings to protect charities</li>\n  <li>Questions of law arising on Bills and with issues of legal policy</li>\n  <li>Oversight of all major international and domestic litigation involving the Government</li>\n  <li>Promoting the rule of law at home and internationally</li>\n</ul>\n\n<p>The Attorney General also holds the separate office of Advocate General for Northern Ireland. The Advocate General for Scotland has specific responsibility for Scottish law matters.</p>\n","role_payment_type":null,"seniority":3,"whip_organisation":{}},"document_type":"ministerial_role","links":{},"locale":"en","public_updated_at":"2024-07-31T14:08:40Z","schema_name":"role","title":"Attorney General","web_url":"https://www.gov.uk/government/ministers/attorney-general","withdrawn":false}]},"locale":"en","public_updated_at":"2024-07-05T19:04:21Z","schema_name":"role_appointment","title":"Richard Hermer KC - Attorney General","withdrawn":false}]},"locale":"en","public_updated_at":"2024-08-02T12:30:58Z","schema_name":"person","title":"The Rt Hon Lord Hermer KC","web_url":"https://www.gov.uk/government/people/richard-hermer","withdrawn":false},{"api_path":"/api/content/government/people/ellie-reeves","api_url":"https://www.gov.uk/api/content/government/people/ellie-reeves","base_path":"/government/people/ellie-reeves","content_id":"8a5e71e0-9918-471a-af46-bf024ef1231c","details":{"image":{"url":"https://assets.publishing.service.gov.uk/media/66912920a3c2a28abb50ce85/s465_Untitled.jpg"},"privy_counsellor":true},"document_type":"person","links":{"role_appointments":[{"content_id":"c3f5b05e-817d-4004-9f40-92b51499661d","details":{"current":true,"ended_on":null,"person_appointment_order":2,"started_on":"2025-09-06T00:00:00+01:00"},"document_type":"role_appointment","links":{"role":[{"api_path":"/api/content/government/ministers/solicitor-general","api_url":"https://www.gov.uk/api/content/government/ministers/solicitor-general","base_path":"/government/ministers/solicitor-general","content_id":"845e6af3-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Solicitor General supports the Attorney across a range of responsibilities. This includes:</p>\n\n<ul>\n  <li>Responsibility for matters delegated by the Attorney General, including deputising for the Attorney at the Parliamentary Business and Legislation Cabinet Committee</li>\n  <li>Providing support to the Attorney General in his superintendence of the Government Legal Department, the Crown Prosecution Service, HM Crown Prosecution Service Inspectorate and the Serious Fraud Office</li>\n  <li>Supporting the Attorney General in his public interest functions</li>\n  <li>Promoting the rule of law at home and internationally</li>\n</ul>\n","role_payment_type":null,"seniority":8,"whip_organisation":{}},"document_type":"ministerial_role","links":{},"locale":"en","public_updated_at":"2025-01-21T12:06:44Z","schema_name":"role","title":"Solicitor General","web_url":"https://www.gov.uk/government/ministers/solicitor-general","withdrawn":false}]},"locale":"en","public_updated_at":"2025-09-06T16:08:42Z","schema_name":"role_appointment","title":"The Rt Hon Ellie Reeves MP - Solicitor General","withdrawn":false},{"content_id":"39e3035a-713a-468f-8016-f982e99f710f","details":{"current":false,"ended_on":"2025-09-06T00:00:00+01:00","person_appointment_order":1,"started_on":"2024-07-06T00:00:00+01:00"},"document_type":"role_appointment","links":{"role":[{"api_path":"/api/content/government/ministers/minister-without-portfolio--11","api_url":"https://www.gov.uk/api/content/government/ministers/minister-without-portfolio--11","base_path":"/government/ministers/minister-without-portfolio--11","content_id":"b27d59d5-a7c3-4db4-a365-75cf58cd74d4","details":{"body":"<p>She is responsible for:</p>\n\n<ul>\n  <li>Missions - supporting delivery of Government’s priorities</li>\n  <li>GREAT campaign</li>\n</ul>\n","role_payment_type":"Unpaid","seniority":5,"whip_organisation":{}},"document_type":"ministerial_role","links":{},"locale":"en","public_updated_at":"2024-12-02T12:41:06Z","schema_name":"role","title":"Minister without Portfolio","web_url":"https://www.gov.uk/government/ministers/minister-without-portfolio--11","withdrawn":false}]},"locale":"en","public_updated_at":"2025-09-06T16:01:18Z","schema_name":"role_appointment","title":"The Rt Hon Ellie Reeves MP - Minister without Portfolio","withdrawn":false}]},"locale":"en","public_updated_at":"2026-03-02T10:33:29Z","schema_name":"person","title":"The Rt Hon Ellie Reeves KC MP","web_url":"https://www.gov.uk/government/people/ellie-reeves","withdrawn":false}],"ordered_roles":[{"api_path":"/api/content/government/ministers/attorney-general","api_url":"https://www.gov.uk/api/content/government/ministers/attorney-general","base_path":"/government/ministers/attorney-general","content_id":"845e6aa7-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Attorney General is chief legal adviser to the Crown and has a number of independent public interest functions, as well as overseeing the Law Officers’ departments.</p>\n\n<p>Responsibilities include:</p>\n\n<ul>\n  <li>Overall responsibility for the work of the Attorney General’s Office and superintended departments (the Government Legal Department, the Crown Prosecution Service, the Serious Fraud Office and HM Crown Prosecution Service Inspectorate)</li>\n  <li>Specific statutory duty to superintend the discharge of duties by the Director of Public Prosecutions (who heads the Crown Prosecution Service) and the Director of the Serious Fraud Office</li>\n  <li>Non-statutory general oversight of the Government Legal Department, the Services Prosecuting Authority, and government prosecuting departments</li>\n  <li>Government’s principal legal adviser dealing with (amongst others) questions of public law, international law, human rights and devolution</li>\n  <li>Public interest functions, for example, reference of unduly lenient sentences to the Court of Appeal, bringing proceedings for contempt of court and intervention in certain proceedings to protect charities</li>\n  <li>Questions of law arising on Bills and with issues of legal policy</li>\n  <li>Oversight of all major international and domestic litigation involving the Government</li>\n  <li>Promoting the rule of law at home and internationally</li>\n</ul>\n\n<p>The Attorney General also holds the separate office of Advocate General for Northern Ireland. The Advocate General for Scotland has specific responsibility for Scottish law matters.</p>\n","role_payment_type":null,"seniority":3,"whip_organisation":{}},"document_type":"ministerial_role","links":{},"locale":"en","public_updated_at":"2024-07-31T14:08:40Z","schema_name":"role","title":"Attorney General","web_url":"https://www.gov.uk/government/ministers/attorney-general","withdrawn":false},{"api_path":"/api/content/government/ministers/solicitor-general","api_url":"https://www.gov.uk/api/content/government/ministers/solicitor-general","base_path":"/government/ministers/solicitor-general","content_id":"845e6af3-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Solicitor General supports the Attorney across a range of responsibilities. This includes:</p>\n\n<ul>\n  <li>Responsibility for matters delegated by the Attorney General, including deputising for the Attorney at the Parliamentary Business and Legislation Cabinet Committee</li>\n  <li>Providing support to the Attorney General in his superintendence of the Government Legal Department, the Crown Prosecution Service, HM Crown Prosecution Service Inspectorate and the Serious Fraud Office</li>\n  <li>Supporting the Attorney General in his public interest functions</li>\n  <li>Promoting the rule of law at home and internationally</li>\n</ul>\n","role_payment_type":null,"seniority":8,"whip_organisation":{}},"document_type":"ministerial_role","links":{},"locale":"en","public_updated_at":"2025-01-21T12:06:44Z","schema_name":"role","title":"Solicitor General","web_url":"https://www.gov.uk/government/ministers/solicitor-general","withdrawn":false},{"content_id":"84619579-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Acting Director General of the Attorney General’s Office (AGO) heads a team of 55-60 legal, policy and corporate professionals, who support the Attorney General and Solicitor General across the range of their functions.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2026-04-23T13:18:13Z","schema_name":"role","title":"Acting Director General of the Attorney General's Office (AGO)","withdrawn":false},{"content_id":"8461ad63-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Director General of the Attorney General’s Office (<abbr title=\"Attorney General's Office\">AGO</abbr>) heads a team of 55-60 legal, policy and corporate professionals, who support the Attorney General and Solicitor General across the range of their functionss.</p>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2022-07-11T19:16:32Z","schema_name":"role","title":"Director General of the Attorney General's Office (AGO)","withdrawn":false},{"api_path":"/api/content/government/ministers/minister-on-leave-attorney-general","api_url":"https://www.gov.uk/api/content/government/ministers/minister-on-leave-attorney-general","base_path":"/government/ministers/minister-on-leave-attorney-general","content_id":"b523ef4f-05d3-45f4-8854-1553ae9041ff","details":{"body":"\n","role_payment_type":null,"seniority":36,"whip_organisation":{}},"document_type":"ministerial_role","links":{},"locale":"en","public_updated_at":"2021-03-03T12:00:51Z","schema_name":"role","title":"Minister on Leave (Attorney General)","web_url":"https://www.gov.uk/government/ministers/minister-on-leave-attorney-general","withdrawn":false}],"organisations":[{"analytics_identifier":"D1","api_path":"/api/content/government/organisations