"postal_code":"E14 4PU","street_address":"MHRA10 South Colonnade","title":"News centre","world_location":"United Kingdom"}],"title":"Media enquiries"},"document_type":"contact","links":{},"locale":"en","public_updated_at":"2024-10-22T14:51:57Z","schema_name":"contact","title":"Media enquiries","withdrawn":false}],"ordered_foi_contacts":[{"content_id":"1fe06edf-6cb9-40ff-859a-075903610096","details":{"contact_form_links":[{"link":"https://www.gov.uk/government/collections/mhra-freedom-of-information-foi-disclosure-log"}],"description":null,"email_addresses":[{"email":"foi.request@mhra.gov.uk","title":"MHRA Freedom of Information Team"}],"phone_numbers":null,"post_addresses":[{"iso2_country_code":"gb","locality":"London","postal_code":"E14 4PU","street_address":"10 South Colonnade","title":"MHRA Freedom of Information Team","world_location":"United Kingdom"}],"title":"Freedom of Information"},"document_type":"contact","links":{},"locale":"en","public_updated_at":"2024-11-11T14:08:38Z","schema_name":"contact","title":"Freedom of Information","withdrawn":false}],"ordered_parent_organisations":[{"analytics_identifier":"D12","api_path":"/api/content/government/organisations/department-of-health-and-social-care","api_url":"https://www.gov.uk/api/content/government/organisations/department-of-health-and-social-care","base_path":"/government/organisations/department-of-health-and-social-care","content_id":"7cd6bf12-bbe9-4118-8523-f927b0442156","details":{"acronym":"DHSC","brand":"department-of-health","default_news_image":{"high_resolution_url":"https://assets.publishing.service.gov.uk/media/627508178fa8f520738d5474/s960_DHSC_plaque.jpg","url":"https://assets.publishing.service.gov.uk/media/62750817e90e070dbf5acad5/s300_DHSC_plaque.jpg"},"logo":{"crest":"single-identity","formatted_title":"Department<br/>of Health &amp;<br/>Social Care"},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"Department of Health and Social Care","web_url":"https://www.gov.uk/government/organisations/department-of-health-and-social-care","withdrawn":false}],"ordered_roles":[{"content_id":"8477a734-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Director of Vigilance and Risk Management of Medicines has responsibility for:</p>\n\n<ul>\n  <li>variations</li>\n  <li>renewals</li>\n  <li>change of legal status</li>\n  <li>patient information</li>\n  <li>advertising</li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2019-10-22T13:57:44Z","schema_name":"role","title":"Director of Vigilance and Risk Management of Medicines","withdrawn":false},{"content_id":"8477aade-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The communications director makes sure that all of the organisation’s internal and external communications are clear and accurate, and that people have the information they need.</p>\n\n<p>The communications division runs a telephone enquiry line and a 24-hour press office to provide information to patients, the public and others who have an interest in the Medicines and Healthcare Products Regulatory Agency’s (<abbr title=\"Medicines and Healthcare Products Regulatory Agency\">MHRA</abbr>) work.</p>\n\n<p>They also run conferences and events to explain <abbr title=\"Medicines and Healthcare Products Regulatory Agency\">MHRA</abbr>’s work to stakeholders, co-ordinate the agency’s work with partner organisations, and carry out market research to understand stakeholders’ needs.</p>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2014-12-04T15:07:14Z","schema_name":"role","title":"Director of Communications","withdrawn":false},{"content_id":"84782311-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The chair is appointed by the Secretary of State for the Department of Health and Social Care and has particular responsibility for providing effective strategic leadership of the agency.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2023-07-20T13:26:33Z","schema_name":"role","title":"Interim co-chair","withdrawn":false},{"content_id":"847823bf-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The chief executive chairs the Executive Committee, which is the highest decision-making body in the agency.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2021-12-31T18:55:30Z","schema_name":"role","title":"Chief Executive","withdrawn":false},{"content_id":"84782464-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The policy division works to make sure the our regulatory and public health mandate and external policy is aligned. This includes:</p>\n\n<ul>\n  <li>working to get the best balance between regulation and new advances</li>\n  <li>coordinating international and EU business</li>\n  <li>corporate strategy</li>\n  <li>corporate governance</li>\n</ul>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2021-11-17T11:31:24Z","schema_name":"role","title":"Director","withdrawn":false},{"content_id":"84782506-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Director of Devices leads the division in the Agency that is responsible for the operation of the regulatory framework that ensures the safety and performance of medical devices on the UK market. This includes:</p>\n\n<ul>\n  <li>investigating reports of problems involving medical devices and taking action in response to these, such as advising healthcare professionals on the safe use of devices, working with manufacturers to improve device safety and, where needed, taking enforcement action;</li>\n  <li>reviewing proposals to undertake clinical investigations using medical devices on patients in the UK;</li>\n  <li>overseeing the UK notified bodies for medical devices, which are responsible for the pre-market assessment of higher-risk products; and</li>\n  <li>ensuring the smooth operation of the regulatory framework, including the provision of regulatory advice.</li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2019-11-27T10:52:07Z","schema_name":"role","title":"Director of Devices","withdrawn":false},{"content_id":"847825b1-c0f1-11e4-8223-005056011aef","details":{"body":"<p>CPRD is a government research service, supported by the Medicines and Healthcare products Regulatory Agency (MHRA) and the National Institute for Health Research (NIHR).</p>\n\n<p>CPRD has been collecting anonymised patient data from GP practices across the UK for over 30 years, and making it available for public health research, leading to improvements in drug safety, best practice and clinical guidelines.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2018-04-12T08:23:21Z","schema_name":"role","title":"Director of Clinical Practice Research Datalink (CPRD)","withdrawn":false},{"content_id":"84782656-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Chief Healthcare Quality and Access Officer leads the work of the agency in improving the safe access to medicines, vaccines and medical devices.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2023-12-19T13:02:30Z","schema_name":"role","title":"Chief Healthcare Quality & Access Officer","withdrawn":false},{"content_id":"847826fc-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The National Institute for Biological Standards and Control is a world leader in product testing to assure the quality of biological medicines. They develop standards and reference materials and carrying out applied research.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2021-01-18T16:15:30Z","schema_name":"role","title":"Interim Chief Scientific Officer","withdrawn":false},{"content_id":"847827a7-c0f1-11e4-8223-005056011aef","details":{"body":"<p>Our HR division works with <abbr title=\"Medicines and Healthcare Products Regulatory Agency\">MHRA</abbr> managers and staff to provide professional and efficient HR services including continuous learning and development. This is achieved by:</p>\n\n<ul>\n  <li>ensuring that all <abbr title=\"Medicines and Healthcare Products Regulatory Agency\">MHRA</abbr> staff are provided with an HR policy framework that is clear, up to date and accessible</li>\n  <li>providing accurate, consistent advice and support on HR policies and procedures within reasonable time</li>\n  <li>enabling effective leadership and improving the overall performance of the organisation</li>\n  <li>developing people to be committed and skilled to achieve the agency’s objectives and enjoy shared success</li>\n</ul>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2015-01-05T09:10:59Z","schema_name":"role","title":"Director of Human Resources (interim)","withdrawn":false},{"content_id":"84782848-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Chief Operating Officer, MHRA is responsible for overseeing the <a rel=\"external\" href=\"http://www.cprd.com/intro.asp\">CPRD</a>, information management, HR and finance and procurement.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2023-12-19T13:02:37Z","schema_name":"role","title":"Chief Operating Officer","withdrawn":false},{"content_id":"8478298e-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The licensing division is responsible for assessing and approving applications for marketing authorisations for new medicines and medical products. The division is also responsible for authorising clinical trials. We cover national and European licensing, for the wider activities of the European Medicines Agency (EMA).</p>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2014-12-05T09:33:31Z","schema_name":"role","title":"Director of Licensing","withdrawn":false},{"content_id":"84782a33-c0f1-11e4-8223-005056011aef","details":{"body":"\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2021-11-17T11:28:29Z","schema_name":"role","title":"Director","withdrawn":false},{"content_id":"84783a73-c0f1-11e4-8223-005056011aef","details":{"body":"<p>Our HR division works with <abbr title=\"Medicines and Healthcare Products Regulatory Agency\">MHRA</abbr> managers and staff to provide professional and efficient HR services including continuous learning and development. This is achieved by:</p>\n\n<ul>\n  <li>ensuring that all <abbr title=\"Medicines and Healthcare Products Regulatory Agency\">MHRA</abbr> staff are provided with an HR policy framework that is clear, up to date and accessible</li>\n  <li>providing accurate, consistent advice and support on HR policies and procedures within reasonable time</li>\n  <li>enabling effective leadership and improving the overall performance of the organisation</li>\n  <li>developing people to be committed and skilled to achieve the agency’s objectives and enjoy shared success</li>\n</ul>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2015-01-30T17:23:10Z","schema_name":"role","title":"Director of Human Resources","withdrawn":false},{"content_id":"f5ac931a-7986-4995-81a6-43911b740cb4","details":{"body":"<p>The Chief Safety Officer leads the work of the agency to ensure the safety of medicines and devices that reach the UK public and health service</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"lo