rl":"https://assets.publishing.service.gov.uk/media/61a9e0128fa8f5038358c120/A46_Kier_Warwick_960_640_1.jpg"},"public_updated_at":"2021-11-17T06:15:00.000+00:00","summary":"<div class=\"govspeak\"><p>By recycling materials from the old road, contractors cut carbon footprint by 23%</p>\n</div>","title":"Why National Highways’ A46 road scheme stands out a green mile in drive for net zero carbon"}],"ordered_featured_links":[],"ordered_promotional_features":[],"organisation_featuring_priority":"news","organisation_govuk_status":{"status":"exempt","updated_at":null,"url":"http://www.nationalhighways.co.uk/"},"organisation_political":false,"organisation_type":"executive_ndpb","secondary_corporate_information_pages":"","social_media_links":[]},"document_type":"organisation","first_published_at":"2021-11-30T10:44:00+00:00","links":{"available_translations":[{"analytics_identifier":"OT1346","api_path":"/api/content/government/organisations/national-highways","api_url":"https://www.gov.uk/api/content/government/organisations/national-highways","base_path":"/government/organisations/national-highways","content_id":"adb19d22-1374-4470-a202-db6e30a1afa4","document_type":"organisation","links":{},"locale":"en","public_updated_at":"2026-04-30T12:57:30Z","schema_name":"organisation","title":"National Highways","web_url":"https://www.gov.uk/government/organisations/national-highways","withdrawn":false}],"ordered_board_members":[{"api_path":"/api/content/government/people/gareth-rhys-williams","api_url":"https://www.gov.uk/api/content/government/people/gareth-rhys-williams","base_path":"/government/people/gareth-rhys-williams","content_id":"87e6c2f2-16d1-46de-8a0e-6188495a9619","details":{"image":{"alt_text":"Gareth Rhys Williams","url":"https://assets.publishing.service.gov.uk/media/5a4f6e7540f0b648ca1d30ad/s465_Gareth_Rhys_Williams_.jpg"},"privy_counsellor":false},"document_type":"person","links":{"role_appointments":[{"content_id":"e07ba9a2-0dbb-4f7f-9ec8-16bb1fc0ddad","details":{"current":false,"ended_on":"2024-07-01T00:00:00+01:00","person_appointment_order":1,"started_on":"2016-03-14T00:00:00+00:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"8461ba35-c0f1-11e4-8223-005056011aef","details":{"body":"<p>Reporting to the Chief Executive of the Civil Service, the Government Chief Commercial Officer shapes and leads the programme of commercial reform across government.</p>\n\n<p>The Government Chief Commercial Officer’s priorities include:</p>\n\n<ul>\n  <li>Leading the Government Commercial Function and Governments Grants Management Functions (GCF and GGMF)</li>\n  <li>To steer the cross-government commercial and grants communities in delivering the Plan for Change</li>\n  <li>Delivering efficiencies and savings through the use of digital, data and AI</li>\n  <li>Lead the Functional Strategy</li>\n  <li>Leads the relationship with HMG Strategic Suppliers</li>\n  <li>Improving contract delivery and contract management</li>\n  <li>Advancing the capability of the GCF and GGMF</li>\n  <li>Head of Profession, building a commercial and grants community across the UK</li>\n</ul>\n\n<p>The Government Chief Commercial Officer works closely with departmental ministers, the Cabinet Secretary, departmental permanent secretaries and other senior officials, and senior leaders of government suppliers. The Government Chief Commercial Officer gives evidence to Parliamentary Select Committees, including the Public Accounts Committee, on commercial matters.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2025-03-06T10:23:08Z","schema_name":"role","title":"Government Chief Commercial Officer","withdrawn":false}]},"locale":"en","public_updated_at":"2024-12-31T08:22:01Z","schema_name":"role_appointment","title":"Gareth Rhys Williams - Government Chief Commercial Officer","withdrawn":false},{"content_id":"03714be3-bee4-4b6b-bf09-7236a131b421","details":{"current":false,"ended