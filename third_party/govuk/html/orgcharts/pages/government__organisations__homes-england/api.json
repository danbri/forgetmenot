ngle-identity","formatted_title":"Ministry of Housing,<br/>Communities &amp; <br/>Local Government"},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"Ministry of Housing, Communities and Local Government","web_url":"https://www.gov.uk/government/organisations/ministry-of-housing-communities-local-government","withdrawn":false}],"ordered_roles":[{"content_id":"8477d003-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The chair is appointed by the Secretary of State for Housing, Communities and Local Government and has particular responsibility for providing effective strategic leadership of the agency.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2026-03-29T17:13:16Z","schema_name":"role","title":"Chair, Homes England","withdrawn":false},{"content_id":"d1205154-9ccc-4cd8-8025-bed26fc1d3bb","details":{"body":"<p>The Chief Executive of Homes England provides strategic leadership to the Agency, overseeing the delivery of programmes and ensuring alignment with performance targets set by government. They are responsible for the effective operation of core systems that underpin the agency’s mission.</p>\n\n<p>As Homes England’s designated Accounting Officer, the Chief Executive is accountable to Parliament and other stakeholders for the agency’s performance, ensuring its functions are carried out with efficiency, transparency, and value for public money.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2026-05-05T11:07:22Z","schema_name":"role","title":"Chief Executive Officer, Homes England","withdrawn":false},{"content_id":"8477d1ef-c0f1-11e4-8223-005056011aef","details":{"body":"\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2021-03-16T13:12:53Z","schema_name":"role","title":"Interim Director for Transformation","withdrawn":false},{"content_id":"b0a4bd0c-88cc-48bc-969b-740436555c00","details":{"body":"<p>The Chief Risk Officer leads the Risk Directorate and is accountable for the 2nd Line risk oversight of the agency in line with HMT Orange Book requirements and prudent risk management standards.</p>\n\n<p>They are responsible for setting the overall tone of the risk culture within the agency and ensuring that business activities receive appropriate levels of independent challenge and oversight.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2026-03-30T07:12:04Z","schema_name":"role","title":"Chief Risk Officer","withdrawn":false},{"content_id":"4e631bd0-462e-4e15-a349-fe13fccda766","details":{"body":"<p>The Chief Investment Officer is responsible for leading the development and execution of long term strategy of the Investment directorate with a view to delivering government strategy in respect of housing supply. This is enacted through:</p>\n\n<ul>\n  <li>a portfolio of financial instruments (including equity, debt and guarantees)</li>\n  <li>developing relationships and structuring opportunities for increased private sector investment in increasing supply of new homes</li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2025-09-05T09:05:21Z","schema_name":"role","title":"Chief Investment Officer","withdrawn":false},{"content_id":"4292d3bc-9938-4e54-bdf1-5425cecdca1a","details":{"body":"\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2017-10-13T11:29:57Z","schema_name":"role","title":"Deputy Chief Executive Officer and Executive Director of Strategy","withdrawn":false},{"content_id":"ea2d6a74-4a83-4de2-bc48-bd2ce7978382","details":{"body":"<p>This key and newly created pivotal role is central to shaping and directing, the organisation’s transition from the Homes and Communities Agency to Homes England.</p>\n\n<p>As well as overseeing the Homes and England Development Programme Bayo is also the director of:</p>\n\n<ul>\n  <li>HR</li>\n  <li>digital</li>\n  <li>accommodation</li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2018-11-08T16:12:58Z","schema_name":"role","title":"Executive Director - Homes England Development Programme","withdrawn":false},{"content_id":"ce8e1314-4807-43db-a0d4-d4d5d5137398","details":{"body":"<p>The Chief of Staff’s responsibilities include leading the Chief Executive’s Office, communications, corporate governance and government relations.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2017-11-02T11:29:58Z","schema_name":"role","title":"Chief of Staff","withdrawn":false},{"content_id":"defe5382-ad78-4e54-a87f-c80b2296b5a6","details":{"body":"\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2019-08-14T08:40:45Z","schema_name":"role","title":"Chief Land and Development Officer ","withdrawn":false},{"content_id":"f652048a-30b3-47ba-ab66-e49f50886118","details":{"body":"<p>The Chief Finance Officer at Homes England leads the financial strategy, operations, and stewardship for the national housing agency.</p>\n\n<p>The role focuses on supporting accelerated housing delivery, strengthening regional models, and providing financial insight for long-term investment and value for money.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2026-03-30T07:11:16Z","schema_name":"role","title":"Chief Finance Officer","withdrawn":false},{"content_id":"ec046878-fc8c-4f06-9916-eb9ecd959347","details":{"body":"\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","publ