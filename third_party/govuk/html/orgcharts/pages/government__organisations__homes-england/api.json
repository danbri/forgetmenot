type":"person","links":{"role_appointments":[{"content_id":"15368a13-9f8a-4875-b168-95d8ad2ad03a","details":{"current":true,"ended_on":null,"person_appointment_order":1,"started_on":"2026-03-01T00:00:00+00:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"b0a4bd0c-88cc-48bc-969b-740436555c00","details":{"body":"<p>The Chief Risk Officer leads the Risk Directorate and is accountable for the 2nd Line risk oversight of the agency in line with HMT Orange Book requirements and prudent risk management standards.</p>\n\n<p>They are responsible for setting the overall tone of the risk culture within the agency and ensuring that business activities receive appropriate levels of independent challenge and oversight.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2026-03-30T07:12:04Z","schema_name":"role","title":"Chief Risk Officer","withdrawn":false}]},"locale":"en","public_updated_at":"2026-03-30T09:36:33Z","schema_name":"role_appointment","title":"Paul Murphy - Chief Risk Officer","withdrawn":false}]},"locale":"en","public_updated_at":"2026-03-30T07:12:37Z","schema_name":"person","title":"Paul Murphy","web_url":"https://www.gov.uk/government/people/paul-murphy","withdrawn":false},{"api_path":"/api/content/government/people/alison-crofton","api_url":"https://www.gov.uk/api/content/government/people/alison-crofton","base_path":"/government/people/alison-crofton","content_id":"2a4db792-0ecf-4c54-9094-e732969517d5","details":{"image":{"url":"https://assets.publishing.service.gov.uk/media/69ca43c594c191d28596ec73/s465_Alison_Crofton_4_GOV.UK.jpg"},"privy_counsellor":false},"document_type":"person","links":{"role_appointments":[{"content_id":"c1ebe587-b24e-47c8-bea4-2d780de35e62","details":{"current":true,"ended_on":null,"person_appointment_order":1,"started_on":"2026-03-01T00:00:00+00:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"7c4546a4-fb4a-4ad9-b614-31018ae83206","details":{"body":"<p>The Chief Regional Delivery Officer leads the Regional Delivery Directorate, ensuring the effective delivery of housing, regeneration and place‑making activity across five regions and a national Technical, Capacity and Co‑ordination Hub.</p>\n\n<p>As a member of the Executive Leadership Team, the postholder provides strategic leadership to support the government’s ambition to build 1.5 million homes and drive local growth.</p>\n\n<p>This is delivered through:</p>\n\n<ul>\n  <li>\n    <p>leading regional delivery activity to maximise new, affordable and regenerated places</p>\n  </li>\n  <li>\n    <p>strengthening partnerships with local authorities and stakeholders to unlock and accelerate development</p>\n  </li>\n  <li>\n    <p>ensuring high‑quality, consistent technical and coordination support across all regions</p>\n  </li>\n</ul>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2026-03-30T09:45:16Z","schema_name":"role","title":"Chief Regional Delivery Officer","withdrawn":false}]},"locale":"en","public_updated_at":"2026-03-30T09:37:14Z","schema_name":"role_appointment","title":"Alison Crofton - Chief Regional Delivery Officer","withdrawn":false}]},"locale":"en","public_updated_at":"2026-03-30T06:46:25Z","schema_name":"person","title":"Alison Crofton","web_url":"https://www.gov.uk/government/people/alison-crofton","withdrawn":false},{"api_path":"/api/content/government/people/simon-century","api_url":"https://www.gov.uk/api/content/government/people/simon-century","base_path":"/government/people/simon-century","content_id":"705ac2c8-d5bf-411c-86d3-557ce4b1c344","details":{"image":{"url":"https://assets.publishing.service.gov.uk/media/69aed9f8917847c0a4c899e4/s465_Simon_Century_GOVUK.jpg"},"privy_counsellor":false},"document_type":"person","links":{"role_appointments":[{"content_id":"1a9f9380-4c84-4aed-a871-f9c4cbc9b07f","details":{"current":false,"ended_on":"2026-03-31T00: