{"analytics_identifier":"PB1232","api_path":"/api/content/government/organisations/homes-england","api_url":"https://www.gov.uk/api/content/government/organisations/homes-england","base_path":"/government/organisations/homes-england","content_id":"ad6f059a-f36c-48eb-a07f-4a6856f08f7f","details":{"acronym":"Homes England","brand":"ministry-of-housing-communities-local-government","default_news_image":{"high_resolution_url":"https://assets.publishing.service.gov.uk/media/69bbc98d4b1db2e4ba9b6444/s960_Homes_England_Logo_Transparent_GOVUK.png","url":"https://assets.publishing.service.gov.uk/media/69bbc98d4c478213a823cdf6/s300_Homes_England_Logo_Transparent_GOVUK.png"},"logo":{"crest":"single-identity","formatted_title":"Homes England"},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"Homes England","web_url":"https://www.gov.uk/government/organisations/homes-england","withdrawn":false}]},"locale":"en","public_updated_at":"2026-03-17T08:36:00Z","schema_name":"document_collection","title":"Homes England — publications","web_url":"https://www.gov.uk/government/collections/homes-england-publications","withdrawn":false}],"ordered_board_members":[{"api_path":"/api/content/government/people/pat-ritchie","api_url":"https://www.gov.uk/api/content/government/people/pat-ritchie","base_path":"/government/people/pat-ritchie","content_id":"46e563f7-6c89-4d9e-bb05-065cba82b54c","details":{"image":{"alt_text":"Pat Ritchie CBE","url":"https://assets.publishing.service.gov.uk/media/62875ec0e90e071f5c9b1398/s465_Pat-Ritchie_Gov.uk.jpg"},"privy_counsellor":false},"document_type":"person","links":{"role_appointments":[{"content_id":"1b79024f-b62b-4bfc-ac52-099ab752aaa7","details":{"current":false,"ended_on":"2025-05-01T00:00:00+01:00","person_appointment_order":1,"started_on":"2020-01-01T00:00:00+00:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"f1a84585-835d-434b-841c-4a79c99e566f","details":{"body":"<p>The Government Property Agency (GPA) delivers property and workplace solutions across government by managing central government property as a strategic asset. It is an executive agency, sponsored by the <a href=\"https://www.gov.uk/government/organisations/cabinet-office\">Cabinet Office</a>.</p>\n\n<p>The role of Chair oversees the work of the Agency by heading up the Board who set strategic direction and by providing expert property advice.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2022-03-11T10:39:41Z","schema_name":"role","title":"Chair, Government Property Agency","withdrawn":false}]},"locale":"en","public_updated_at":"2025-06-02T11:30:57Z","schema_name":"role_appointment","title":"Pat Ritchie CBE - Chair, Government Property Agency","withdrawn":false},{"content_id":"a3c8b63b-8b63-461d-aa4d-bb196ebd30a2","details":{"current":true,"ended_on":null,"person_appointment_order":2,"started_on":"2025-05-01T00:00:00+01:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"8477d003-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The chair is appointed by the Secretary of State for Housing, Communities and Local Government and has particular responsibility for providing effective strategic leadership of the agency.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2026-03-29T17:13:16Z","schema_name":"role","title":"Chair, Homes England","withdrawn":false}]},"locale":"en","public_updated_at":"2025-05-01T14:49:05Z","schema_name":"role_appointment","title":"Pat Ritchie CBE - Chair","withdrawn":false}]},"locale":"en","public_updated_at":"2025-06-02T13:19:19Z","schema_name":"person","title":"Pat Ritchie CBE","web_url":"https://www.gov.uk/government/people/pat-ritchie","withdrawn":false},{"api_path":"/api/content/government/people/amy-rees","api_url":"https://www.gov.uk/api/content/government/people/amy-rees","base_path":"/government/people/amy-rees","content_id":"29cdd325-131b-46f2-a0a0-54c92bf64d95","details":{"image":{"url":"https://assets.publishing.service.gov.uk/media/69ce7621826d774e7b263dd7/s465_Amy.jpg"},"privy_counsellor":false},"document_type":"person","links":{"role_appointments":[{"content_id":"ddcf0162-442d-469c-bac2-d6c64d6a45f7","details":{"current":true,"ended_on":null,"person_appointment_order":4,"started_on":"2026-03-31T00:00:00+01:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"396eac9d-7cfe-4f68-add5-914a44acffd2","details":{"body":"<p>A non-executive director (NED) is an independent member of the National Housing Bank board. They provide strategic oversight and independent challenge to executive decisions, drawing on external expertise and experience to support effective governance of the organisation.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2026-05-05T11:15:13Z","schema_name":"role","title":"Non-Executive Director, National Housing Bank","withdrawn":false}]},"locale":"en","public_updated_at":"2026-03-31T10:43:43Z","schema_name":"role_appointment","title":"Amy Rees CB - Non-Executive Director","withdrawn":false},{"content_id":"e56d7600-f58b-4ee2-b32a-8c3568ee0af8","details":{"current":true,"ended_on":null,"person_appointment_order":3,"started_on":"2025-09-08T00:00:00+01:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"d1205154-9ccc-4cd8-8025-bed26fc1d3bb","details":{"body":"<p>The Chief Executive of Homes England provides strategic leadership to the Agency, overseeing the delivery of programmes and ensuring alignment with performance targets set by government. They are responsible for the effective operation of core systems that underpin the agency’s mission.</p>\n\n<p>As Homes England’s designated Accounting Officer, the Chief Executive is accountable to Parliament and other stakeholders for the agency’s performance, ensuring its functions are carried out with efficiency, transparency, and value for public money.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2026-05-05T11:07:22Z","schema_name":"role","title":"Chief Executive Officer, Homes England","withdrawn":false}]},"locale":"en","public_updated_at":"2025-09-08T10:40:33Z","schema_name":"role_appointment","title":"Amy Rees - Chief Executive Officer","withdrawn":false},{"content_id":"48e73fdb-7018-42b9-a6bc-2dbc26eacf70","details":{"current":false,"ended_on":"2025-04-07T00:00:00+01:00","person_appointment_order":2,"started_on":"2022-08-31T00:00:00+01:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"dcd0c6c7-014c-45df-bc4c-168394abc4ac","details":{"body":"\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2025-10-14T08:33:18Z","schema_name":"role","title":"Director General Chief Executive Officer HMPPS","withdrawn":false}]},"locale":"en","public_updated_at":"2025-04-24T14:21:30Z","schema_name":"role_appointment","title":"Amy Rees - Director General Chief Executive HMPPS","withdrawn":false},{"content_id":"65070adf-f609-43ee-88cb-858901f190ae","details":{"current":false,"ended_on":"2022-08-31T00:00:00+01:00","person_appointment_order":4601,"started_on":"2017-07-01T00:00:00+01:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"8472a579-c0f1-11e4-8223-005056011aef","details":{"body":"<p>Her responsibilities include:</p>\n\n<ul>\n  <li>\n    <p>Leadership of the Probation Service including oversight of effective delivery of Probation Services including advice to court, community sentences, post-release supervision of offenders, provision of approved premises, victim liaison.</p>\n  </li>\n  <li>\n    <p>Strategic leadership and oversight of the Youth Custody Service and the delivery of its core objectives.</p>\n  </li>\n  <li>\n    <p>Leading for the HMPPS on Public Protection (including Multi Agency Public Protection arrangements to manage high risk offenders), sentence liaison, and work to support the Parole Board process.</p>\n  </li>\n  <li>\n    <p>All HMPPS operations in Wales, including public and private prisons, the probation system and the Ministry’s relationship with the Welsh Government.</p>\n  </li>\n</ul>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2021-09-15T14:21:07Z","schema_name":"role","title":"Director General of Probation, Wales and Youth, HMPPS","withdrawn":false}]},"locale":"en","public_updated_at":"2022-08-31T13:35:49Z","schema_name":"role_appointment","title":"Amy Rees - Director General of Probation, Wales and Youth, HMPPS","withdrawn":false}]},"locale":"en","public_updated_at":"2025-09-22T16:13:13Z","schema_name":"person","title":"Amy Rees CB","web_url":"https://www.gov.uk/government/people/amy-rees","withdrawn":false},{"api_path":"/api/content/government/people/kirsty-shaw","api_url":"https://www.gov.uk/api/content/government/people/kirsty-shaw","base_path":"/government/people/kirsty-shaw","content_id":"85408344-c0f1-11e4-8223-005056011aef","details":{"image":{"alt_text":"Kirsty Shaw","url":"https://assets.publishing.service.gov.uk/media/650b00fcfbd7bc0013cb5225/s465_GOVUK_Kirsty_Shaw.jpg"},"privy_counsellor":false},"document_type":"person","links":{"role_appointments":[{"content_id":"b090dea4-c01f-469d-b29c-7174b3171b95","details":{"current":true,"ended_on":null,"person_appointment_order":1,"started_on":"2022-09-01T00:00:00+01:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"73687102-4fd9-4a3d-b6e9-e2f4c892064c","details":{"body":"\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2023-09-20T14:09:57Z","schema_name":"role","title":"Chief Operating Officer","withdrawn":false}]},"locale":"en","public_updated_at"