p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2024-08-21T14:21:04Z","schema_name":"role","title":"Non-executive Committee Member","withdrawn":false}]},"locale":"en","public_updated_at":"2025-07-16T09:35:43Z","schema_name":"role_appointment","title":"Helen Gillett - Non-executive Committee Member","withdrawn":false}]},"locale":"en","public_updated_at":"2025-11-04T09:57:13Z","schema_name":"person","title":"Helen Gillett","web_url":"https://www.gov.uk/government/people/helen-gillett","withdrawn":false},{"api_path":"/api/content/government/people/mark-bourgeois","api_url":"https://www.gov.uk/api/content/government/people/mark-bourgeois","base_path":"/government/people/mark-bourgeois","content_id":"ddc18acb-14c4-48d9-a150-ef78f5a52abf","details":{"image":{"alt_text":"Mark Bourgeois","url":"https://assets.publishing.service.gov.uk/media/656a16111104cf0013fa73c8/s465_Mark_Bourgeois__Interim_CEO-Landscape_960x640.jpg"},"privy_counsellor":false},"document_type":"person","links":{"role_appointments":[{"content_id":"ed43fa49-c9b3-42d1-93b6-dc33b8dd65d7","details":{"current":true,"ended_on":null,"person_appointment_order":1,"started_on":"2023-11-27T00:00:00+00:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"7e1dc709-397d-4f96-8ce1-089183d24194","details":{"body":"<p>The Chief Executive (CEO) is accountable to the Chair and the GPA Board for the strategic direction and performance of the GPA and to the Permanent Secretary of the Cabinet Office in respect of their Accounting Officer responsibilities.</p>\n\n<p>The CEO is responsible for the day-to-day management of the GPA, the efficient running, financial management, corporate governance and compliance, overall performance and strategic planning of the organisation.</p>\n\n<p>As Accounting Officer for GPA, the CEO is personally responsible for safeguarding the public funds for which they have charge.</p>\n","role_payment_type":null},"docu