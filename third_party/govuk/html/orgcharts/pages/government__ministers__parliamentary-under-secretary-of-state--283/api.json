mittee.</p>\n\n<h3 id=\"education\">Education</h3>\n\n<p>Seema was educated at schools in Hounslow and studied Politics and Philosophy at the University of Warwick.</p>\n\n<p>She took a postgraduate degree in Business and Information Studies at Aston University.</p>\n","image":{"alt_text":"Seema Malhotra MP","url":"https://assets.publishing.service.gov.uk/media/68d689864e830dd22fa1cec6/s465_AR109377.jpg"}},"document_type":"person","links":{},"locale":"en","public_updated_at":"2025-09-07T08:41:00Z","schema_name":"person","title":"Seema Malhotra MP","web_url":"https://www.gov.uk/government/people/seema-malhotra","withdrawn":false}],"role":[{"api_path":"/api/content/government/ministers/parliamentary-under-secretary-of-state--283","api_url":"https://www.gov.uk/api/content/government/ministers/parliamentary-under-secretary-of-state--283","base_path":"/government/ministers/parliamentary-under-secretary-of-state--283","content_id":"4b727a0e-2461-438c-af4b-841397d6b8d3","details":{"body":"<ul>\n  <li>Indo-Pacific</li>\n  <li>growth</li>\n  <li>global tech and artificial intelligence</li>\n  <li>departmental operations (including Legal)</li>\n</ul>\n","role_payment_type":null,"seniority":100,"whip_organisation":{}},"document_type":"ministerial_role","links":{"ordered_parent_organisations":[{"analytics_identifier":"D1315","api_path":"/api/content/government/organisations/foreign-commonwealth-development-office","api_url":"https://www.gov.uk/api/content/government/organisations/foreign-commonwealth-development-office","base_path":"/government/organisations/foreign-commonwealth-development-office","content_id":"f9fcf3fe-2751-4dca-97ca-becaeceb4b26","details":{"acronym":"FCDO","brand":"foreign-commonwealth-development-office","default_news_image":{"high_resolution_url":"https://assets.publishing.service.gov.uk/media/621e4de4e90e0710be0354d7/s960_fcdo-main-building.jpg","url":"https://assets.publishing.service.gov.uk/media/621e4de48fa8f5490aff83b4/s300_fcdo-main-building.jpg"},"