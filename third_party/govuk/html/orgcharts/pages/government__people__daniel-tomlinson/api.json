{"analytics_identifier":null,"base_path":"/government/people/daniel-tomlinson","content_id":"b01f1536-a74a-48f3-ab35-510837afb1b0","description":"Daniel Tomlinson MP was appointed as a Parliamentary Secretary (Exchequer Secretary to the Treasury) in His Majesty’s Treasury on 1 September 2025.","details":{"body":"<p>Daniel Tomlinson MP was appointed as a Parliamentary Secretary (Exchequer Secretary to the Treasury) in His Majesty’s Treasury on 1 September 2025.</p>\n","full_name":"Daniel Tomlinson MP","image":{"url":"https://assets.publishing.service.gov.uk/media/69ef74ad08ecdb5c6f34afea/s465_XST_GOV.UK.jpg"},"privy_counsellor":false},"document_type":"person","first_published_at":"2025-09-01T09:36:04+01:00","links":{"available_translations":[{"api_path":"/api/content/government/people/daniel-tomlinson","api_url":"https://www.gov.uk/api/content/government/people/daniel-tomlinson","base_path":"/government/people/daniel-tomlinson","content_id":"b01f1536-a74a-48f3-ab35-510837afb1b0","document_type":"person","links":{},"locale":"en","public_updated_at":"2025-09-01T08:47:57Z","schema_name":"person","title":"Daniel Tomlinson MP","web_url":"https://www.gov.uk/government/people/daniel-tomlinson","withdrawn":false}],"role_appointments":[{"content_id":"a4f0df58-9c4f-4584-bc81-ad92cc378598","details":{"current":true,"ended_on":null,"person_appointment_order":1,"started_on":"2025-09-01T00:00:00+01:00"},"document_type":"role_appointment","links":{"person":[{"api_path":"/api/content/government/people/daniel-tomlinson","api_url":"https://www.gov.uk/api/content/government/people/daniel-tomlinson","base_path":"/government/people/daniel-tomlinson","content_id":"b01f1536-a74a-48f3-ab35-510837afb1b0","details":{"body":"<p>Daniel Tomlinson MP was appointed as a Parliamentary Secretary (Exchequer Secretary to the Treasury) in His Majesty’s Treasury on 1 September 2025.</p>\n","image":{"url":"https://assets.publishing.service.gov.uk/media/69ef74ad08ecdb5c6f34afea/s465_XST_GOV.UK.jpg"}},"document_type":"person","links":{},"locale":"en","public_updated_at":"2025-09-01T08:47:57Z","schema_name":"person","title":"Daniel Tomlinson MP","web_url":"https://www.gov.uk/government/people/daniel-tomlinson","withdrawn":false}],"role":[{"api_path":"/api/content/government/ministers/exchequer-secretary-to-the-treasury","api_url":"https://www.gov.uk/api/content/government/ministers/exchequer-secretary-to-the-treasury","base_path":"/government/ministers/exchequer-secretary-to-the-treasury","content_id":"845e88c6-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The <strong>Exchequer Secretary to the Treasury (XST)</strong> is responsible for:</p>\n\n<ul>\n  <li>The UK tax system including:\n    <ul>\n      <li>Direct, indirect, business, property, and personal taxation (except for taxes covered by EST)</li>\n      <li>European and other international tax issues</li>\n      <li>Customs and VAT at the border</li>\n      <li>The Finance Bill and the National Insurance Bill</li>\n      <li>Indirect taxes, including stakeholder engagement on excise duties and excise fraud and law enforcement.</li>\n    </ul>\n  </li>\n  <li>Tax administration policy</li>\n  <li>Input to Investment Zones and Freeports focussing on tax and customs elements</li>\n  <li>Taxation of charities, the voluntary sector and gift aid</li>\n  <li>Energy, environment and climate taxes (including transport taxes)</li>\n  <li>Energy profits Levy</li>\n</ul>\n\n<p>The Exchequer Secretary to the Treasury is the departmental Minister for HM Revenue and Customs (HMRC), the Valuation Office Agency, and the Government’s Actuary’s Department.</p>\n","role_payment_type":null,"seniority":100,"whip_organisation":{}},"document_type":"ministerial_role","links":{"ordered_parent_organisations":[{"analytics_identifier":"D15","api_path":"/api/content/government/organisations/hm-treasury","api_url":"https://www.gov.uk/api/content/government/organisations/hm-treasury","base_path":"/government/organisations/hm-treasury","co