ment/people/lynne-henderson","content_id":"c6cd889a-6ad9-4a97-9f70-6bff87b3c83a","details":{"image":{"alt_text":"Lynne Henderson","url":"https://assets.publishing.service.gov.uk/media/6908cd76823bdda9488b25e4/s465_LH_ub_for_web.jpeg"},"privy_counsellor":false},"document_type":"person","links":{"role_appointments":[{"content_id":"30714b17-12fa-4061-acc3-ee409739f942","details":{"current":false,"ended_on":"2025-10-31T00:00:00+00:00","person_appointment_order":2,"started_on":"2024-01-03T00:00:00+00:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"1a26d213-1a8f-4aae-8494-6f89846136de","details":{"body":"<p>The Deputy Chief Executive, CICA is responsible for the agency’s operational teams and business support services.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2024-07-30T12:59:16Z","schema_name":"role","title":"Deputy Chief Executive, CICA ","withdrawn":false}]},"locale":"en","public_updated_at":"2025-11-03T13:19:02Z","schema_name":"role_appointment","title":"Lynne Henderson - Deputy Chief Executive, CICA ","withdrawn":false},{"content_id":"620dea97-bbb1-43ed-8dfa-d3a30010c3cf","details":{"current":true,"ended_on":null,"person_appointment_order":2,"started_on":"2025-11-01T00:00:00+00:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"8470850f-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Chief Executive, CICA makes sure the agency as a whole provides a fair service to victims of violent crime.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2014-03-04T16:27:33Z","schema_name":"role","title":"Chief Executive, CICA","withdrawn":false}]},"locale":"en","public_updated_at":"2025-11-03T13:17:24Z","schema_name":"role_appointment","title":"Lynne Henderson - Chief Executive, CICA","withdrawn":false}]},"locale":"en","public_updated_at":"2025-11-03T13:42:29Z","schema_name":"person","title":"Lynne Henderson","web_url":"https://www.gov.uk/government/people/lynne-henderson","withdrawn":false}],"ordered_contacts":[{"content_id":"dbf56e4a-fdf3-487b-aed8-a25a909b8a57","details":{"contact_form_links":[{"link":"https://contact-the-cica.form.service.justice.gov.uk"}],"description":"Opening times:\r\n8.30am to 3pm Monday to Friday.\r\n\r\nUse the contact form at the link above if you need to update information for an ongoing claim.\r\n\r\nTo send documents for an ongoing claim email info@cica.gov.uk\r\nFor data security, we need the:\r\n* Applicant’s name\r\n* Applicant's date of birth \r\n* CICA reference number \r\n* Applicant's address\r\nand either the:\r\n* date of the incident; or \r\n* name of the applicant's GP surgery.\r\n\r\nWe can only accept documents in these file formats:\r\n* PDF\r\n* .Doc\r\n* Docx\r\n* JPEG or JPG\r\n\r\nIf you cannot send documents in the above file format(s) post them to the address above or by Document Exchange to DX: GW379 Glasgow.\r\n\r\nIf you email us we will send an automated reply to acknowledge receipt. This is limited to one reply per day. We aim to act on emails within 10 working days.\r\n\r\nDue to the demand on our service we cannot reply to requests for updates. \r\n\r\nWe will not always send an acknowledgement if you write to us or send us documents. \r\n\r\nWe’ll contact you if we need your help to progress your claim or when we’ve made a decision.\r\n\r\nOur office is not open to the public.\r\n","email_addresses":null,"phone_numbers":[{"number":"0300 003 3601","title":"Phone:"},{"number":"+44 (0)203 684 2517  ","title":"Phone from outside the UK:"},{"number":"18001 0300 003 3601 ","title":"Relay UK (if you cannot hear or speak on the phone):"}],"post_addresses":[{"iso2_country_code":"gb","locality":"Glasgow","postal_code":"G5 8AQ","street_address":"Buchanan Wharf","title":"10 Clyde Place","world_location":"United Kingdom"}],"title":"Criminal Injuries Compensation Authority"},"document_type":"contact","links":{},"locale":"en","public_updated_at":"2025-08-22T14:29:38Z","schema_name":"contact","title":"Criminal Injuries Compensation Authority","withdrawn":false},{"content_id":"14eacdc2-c989-4269-b5c1-1162d892ad5c","details":{"contact_form_links":[{"link":"https://complain-to-the-cica.form.service.justice.gov.uk/"}],"description":"Use this form if you are dissatisfied with an aspect of the CICA or how we have handled your claim and wish to submit a complaint. Our complaints procedure explains what is considered grounds for submitting a formal complaint.","email_addresses":null,"phone_numbers":null,"post_addresses":[{"iso2_country_code":"gb","locality":"Buchanan Wharf","postal_code":"G5 8AQ","region":"Glasgow","street_address":"10 Clyde Place","title":"Customer Resolution Team","world_location":"United Kingdom"}],"title":"Complaints"},"document_type":"contact","links":{},"locale":"en","public_updated_at":"2025-09-17T10:05:29Z","schema_name":"contact","title":"Complaints","withdrawn":false},{"content_id":"c7c7b8db-df92-43e9-8198-b8c55ffc8949","details":{"contact_form_links":null,"description":null,"email_addresses":null,"phone_numbers":[{"number":"0203 334 3536","title":"Telephone (journalists only)"}],"post_addresses":[],"title":"Ministry of Justice press office"},"document_type":"contact","links":{},"locale":"en","public_updated_at":"2022-03-24T17:23:28Z","schema_name":"contact","title":"Ministry of Justice press office","withdrawn":false},{"content_id":"5e73f42c-36ea-47d8-b41a-6d4a0039a685","details":{"contact_form_links":null,"description":"CICA is committed to preventing and tackling fraud to protect public funds intended for victims of violent crime. If you suspect someone has made a fraudulent claim for criminal injuries compensation, you can let us know in strict confidence by emailing us on fraud@cica.gov.uk.","email_addresses":null,"phone_numbers":null,"post_addresses":[],"title":"Reporting fraud"},"document_type":"contact","links":{},"locale":"en","public_updated_at