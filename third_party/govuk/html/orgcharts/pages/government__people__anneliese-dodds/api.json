 opportunity</li>\n  <li>race and ethnicity policy</li>\n  <li>Employment Rights Bill (Department for Business and Trade lead)</li>\n</ul>\n","role_payment_type":null,"seniority":5,"whip_organisation":{}},"document_type":"ministerial_role","links":{"ordered_parent_organisations":[{"analytics_identifier":"OT1426","api_path":"/api/content/government/organisations/office-for-equality-and-opportunity","api_url":"https://www.gov.uk/api/content/government/organisations/office-for-equality-and-opportunity","base_path":"/government/organisations/office-for-equality-and-opportunity","content_id":"398859b6-695e-42dd-ad68-826f06db871d","details":{"acronym":"OEO","brand":"cabinet-office","default_news_image":null,"logo":{"crest":"single-identity","formatted_title":"Office for Equality<br/>and Opportunity"},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"Office for Equality and Opportunity","web_url":"https://www.gov.uk/government/organisations/office-for-equality-and-opportunity","withdrawn":false},{"analytics_identifier":"OT1427","api_path":"/api/content/government/organisations/race-equality-unit","api_url":"https://www.gov.uk/api/content/government/organisations/race-equality-unit","base_path":"/government/organisations/race-equality-unit","content_id":"35616375-9be7-498b-a707-5b62391aa700","details":{"acronym":"REU","brand":"cabinet-office","default_news_image":null,"logo":{"crest":"single-identity","formatted_title":"Race<br/>Equality<br/>Unit"},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"Race Equality Unit","web_url":"https://www.gov.uk/government/organisations/race-equality-unit","withdrawn":false},{"analytics_identifier":"OT1428","api_path":"/api/content/government/organisations/women-and-equalities-unit","api_url":"https://ww