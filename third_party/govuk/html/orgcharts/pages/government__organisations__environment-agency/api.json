nt/organisations/department-for-environment-food-rural-affairs","withdrawn":false}],"ordered_roles":[{"content_id":"8472a8b9-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Executive Director of Operations, is responsible for all of the Environment Agency’s operational activities. These include the organisation’s strategy, communicating with customers and stakeholders to ensure a safe and productive workplace for employees.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2015-08-11T09:36:47Z","schema_name":"role","title":"Executive Director of Operations","withdrawn":false},{"content_id":"8472a90e-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Executive Director:</p>\n\n<ul>\n  <li>sets the direction for flood and coastal risk management in England</li>\n  <li>manages key stakeholder relationships</li>\n  <li>gives expert advice to government</li>\n  <li>helps develop and implement flood and coastal erosion risk management policies</li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2020-12-20T10:48:36Z","schema_name":"role","title":"Interim Executive Director of Flood and Coastal Risk Management","withdrawn":false},{"content_id":"8472a964-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Executive Director is responsible for the Environment Agency’s approach to water quality, water resources, industry regulation, land management, climate change adaptation and sustainable development.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2019-10-31T10:25:38Z","schema_name":"role","title":"Executive Director of Environment and Business","withdrawn":false},{"content_id":"8472a9b5-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Executive Director of Resources and Legal Services is responsible for providing the following services to the Environment Agency:</p>\n\n<ul>\n  <li>human resources</li>\n  <li>property</li>\n  <li>fleet</li>\n  <li>health and safety advice</li>\n  <li>legal services</li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2014-10-15T12:53:48Z","schema_name":"role","title":"Executive Director of Resources and Legal Services","withdrawn":false},{"content_id":"8472aa09-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Chair of the Environment Agency is responsible for leading the organisation and making sure that it fulfils all of its goals.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2016-09-21T09:16:18Z","schema_name":"role","title":"Chair","withdrawn":false},{"content_id":"8472aa5a-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Executive Director of Finance at the EA is responsible for financial planning, record-keeping, reporting and the management of financial risks.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2014-03-25T15:19:23Z","schema_name":"role","title":"Executive Director of Finance","withdrawn":false},{"content_id":"8472aaab-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Executive Director is responsible for producing evidence to underpin decision making. This includes natural and social science, data, mapping, modelling and information, synthesis of information, and economics. They also lead the development of tools and techniques for monitoring the environment.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2015-06-25T12:29:03Z","schema_name":"role","title":"Executive Director of Evidence","withdrawn":false},{"content_id":"8472aafc-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Chief Executive is the leader of the EA and is responsible for the day to day management of the organisation.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2015-11-30T16:52:16Z","schema_name":"role","title":"Chief Executive","withdrawn":false},{"content_id":"9bfe47e8-3671-400e-945f-afe4aab1498a","details":{"body":"<p>The Deputy Chief Executive supports the Chief Executive of the Environment Agency in the day to day management of the organisation.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2017-03-31T14:44:04Z","schema_name":"role","title":"Deputy Chief Executive","withdrawn":false},{"content_id":"195be56e-aff6-4f26-ac32-6d54e7462f81","details":{"body":"\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2017-03-31T14:44:10Z","schema_name":"role","title":"Chief of Staff","withdrawn":false},{"content_id":"a139fcd7-0338-42bf-a56d-c1d9755a9d8f","details":{"body":"<p>The Chief Operating Officer (COO) is responsible for:</p>\n\n<ul>\n  <li>overseeing operational activity that is delivered nationally once</li>\n  <li>internal services that support the whole of the Environment Agency</li>\n</ul>\n\n<p>The COO also leads on the relationships with Defra Group Corporate Services.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2020-12-17T16:34:04Z","schema_name":"role","title":"Chief Operating Officer","withdrawn":false},{"content_id":"b237a9ab-134a-4162-87fd-645ebb05eb87","details":{"body":"<p>The Executive Director of Local Operations is responsible for the Environment Agency’s front line operational activities and national incident management services.</p>\n\n<p>These include:</p>\n\n<ul>\n  <li>the performance of the organisation’s area teams</li>\n  <li>communicating with customers and stakeholders</li>\n  <li>ensuring a safe and productive workplace for employees</li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2020-12-17T16:44:53Z","schema_name":"role","title":"Executive Director for Local Operations","withdrawn":false},{"content_id":"193916cc-191c-4902-b7dc-638300a0e7f8","details":{"body":"<p>The Executive Director:</p>\n\n<ul>\n  <li>sets the direction for flood and coastal risk management in England</li>\n  <li>manages key stakeholder relationships</li>\n  <li>gives expert advice to government</li>\n  <li>helps develop and implement flood and coastal erosion risk management policies</li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2021-02-12T09:22:04Z","schema_name":"role","title":"Executive Director of Flood and Coastal Risk Management","withdrawn":false},{"content_id":"8c9d5d45-cf0f-4a01-910a-168ce241f7bb","details":{"body":"<p>The Executive Director for Strategy, Transformation and Assurance (STA) is responsible for:</p>\n\n<ul>\n  <li>overseeing operational activity that is delivered nationally once</li>\n  <li>internal services that support the whole of the Environment Agency</li>\n</ul>\n\n<p>They also lead on the relationships with Defra Group Corporate Services.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2024-03-11T16:37:16Z","schema_name":"role","title":"Executive Director for Strategy, Transformation and Assurance","withdrawn":false}],"organisations":[{"analytics_identifier":"EA199","api_path":"/api/content/government/organisations/environment-agency","api_url":"https://www.gov.uk/api/content/government/organisations/environment-agency","base_path":"/government/organisations/environment-agency","content_id":"16628142-57b2-4611-bc03-5912785acee3","details":{"acronym":"","brand":"department-for-environment-food-rural-affairs","default_news_image":{"high_resolution_url":"https://assets.publishing.service.gov.uk/media/62c56ed9e90e077483