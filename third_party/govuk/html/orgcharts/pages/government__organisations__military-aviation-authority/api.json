nce\">MOD</abbr> link with Industry for design, manufacturing, maintenance, modification and certification standards and Contractor Accountable Manager organisations</li>\n</ul>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2025-07-11T07:54:52Z","schema_name":"role","title":"Director Military Aviation Authority","withdrawn":false}],"organisations":[{"analytics_identifier":"OT1071","api_path":"/api/content/government/organisations/military-aviation-authority","api_url":"https://www.gov.uk/api/content/government/organisations/military-aviation-authority","base_path":"/government/organisations/military-aviation-authority","content_id":"b9f31e72-291a-4cfd-927e-667a46279465","details":{"acronym":"MAA","brand":"ministry-of-defence","default_news_image":null,"logo":{"crest":"custom","formatted_title":"Military<br/>Aviation<br/>Authority","image":{"alt_text":"Military Aviation Authority","url":"https://assets.publishing.service.gov.uk/media/59fa00e640f0b62eeb2ec8e5/unnamed.jpg"}},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"Military Aviation Authority","web_url":"https://www.gov.uk/government/organisations/military-aviation-authority","withdrawn":false}],"primary_publishing_organisation":[{"analytics_identifier":"OT1071","api_path":"/api/content/government/organisations/military-aviation-authority","api_url":"https://www.gov.uk/api/content/government/organisations/military-aviation-authority","base_path":"/government/organisations/military-aviation-authority","content_id":"b9f31e72-291a-4cfd-927e-667a46279465","details":{"acronym":"MAA","brand":"ministry-of-defence","default_news_image":null,"logo":{"crest":"custom","formatted_title":"Military<br/>Aviation<br/>Authority","image":{"alt_text":"Military Aviation Authority","url":"https://assets.publishing.service.gov.uk/media/59fa00e640f0