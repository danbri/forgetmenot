rd, Banking Code Standards Board, Notting Hill Housing, and the Money Advice Service; Deputy Chair and Acting Chair of the British Council; a trustee of London University and Dartington Hall Trust, an Audit Commissioner, a Civil Service Commissioner and a non-executive director of the Crown Prosecution Service.</p>\n","image":{"alt_text":"Lord Lemos CMG CBE","url":"https://assets.publishing.service.gov.uk/media/61bb1a07e90e070441bcf9e5/s465_gerrard-lemos.jpg"}},"document_type":"person","links":{},"locale":"en","public_updated_at":"2025-08-04T12:04:55Z","schema_name":"person","title":"Lord Lemos CMG CBE","web_url":"https://www.gov.uk/government/people/gerrard-lemos","withdrawn":false}],"role":[{"api_path":"/api/content/government/ministers/lord-in-waiting-government-whip--11","api_url":"https://www.gov.uk/api/content/government/ministers/lord-in-waiting-government-whip--11","base_path":"/government/ministers/lord-in-waiting-government-whip--11","content_id":"98c79b4f-21cd-4159-a120-ca1e522687a5","details":{"body":"\n","role_payment_type":"Unpaid","seniority":100,"whip_organisation":{"label":"Baronesses and Lords in Waiting","sort_order":5}},"document_type":"ministerial_role","links":{},"locale":"en","public_updated_at":"2025-02-12T13:47:34Z","schema_name":"role","title":"Lord in Waiting (Government Whip)","web_url":"https://www.gov.uk/government/ministers/lord-in-waiting-government-whip--11","withdrawn":false}]},"locale":"en","public_updated_at":"2025-07-22T15:05:27Z","schema_name":"role_appointment","title":"Lord Lemos CMG CBE - Lord in Waiting (Government Whip)","withdrawn":false}]},"locale":"en","phase":"live","public_updated_at":"2025-02-12T13:47:34+00:00","publishing_app":"whitehall","publishing_request_id":"21-1753196727.216-10.13.22.130-2913","publishing_scheduled_at":null,"rendering_app":"collections","scheduled_publishing_delay_seconds":null,"schema_name":"role","title":"Lord in Waiting (Government Whip)","updated_at":"2025-08-04T13:04:56+01:00","withdrawn_n