content/government/organisations/united-kingdom-security-vetting","api_url":"https://www.gov.uk/api/content/government/organisations/united-kingdom-security-vetting","base_path":"/government/organisations/united-kingdom-security-vetting","content_id":"471796ac-7421-4425-9cc6-a27ad81e850a","document_type":"organisation","links":{},"locale":"en","public_updated_at":"2024-11-22T16:13:49Z","schema_name":"organisation","title":"United Kingdom Security Vetting","web_url":"https://www.gov.uk/government/organisations/united-kingdom-security-vetting","withdrawn":false}],"ordered_contacts":[{"content_id":"f41931c5-dbc0-4eb8-9685-46caa32d3ca5","details":{"contact_form_links":null,"description":"When contacting us sponsors are required to identify themselves by their sponsor ID. ASI/VSI information can only be discussed with registered sponsors that have NSVS sponsor accounts.\r\n\r\nIf you have forgotten your sponsor ID or you have registered for an account but not received your sponsor ID yet, please contact our Helpdesk. You will be asked a number of questions to establish your identity. Once your identity has been confirmed we will inform you of your sponsor ID.\r\n\r\nIf you have not registered for an account please contact your authorising body or DSO. If you are MOD, a list of authorising bodies can be found on the Defence Net / UKSV Team site / Departmental Security Authorities link. Other government department sponsors should contact their DSO.\r\n\r\nIf you are an applicant of security vetting, you will be required to provide us with your full name and date of birth from which we will be able to locate you on our system and you will then be asked further security questions. Failure to pass the security questions will result in your request being refused.\r\n\r\n","email_addresses":[{"email":"uksv-helpdesk@cabinetoffice.gov.uk","title":"United Kingdom Security Vetting"}],"phone_numbers":null,"post_addresses":[{"iso2_country_code":"gb","locality":"York","postal_code":"Y