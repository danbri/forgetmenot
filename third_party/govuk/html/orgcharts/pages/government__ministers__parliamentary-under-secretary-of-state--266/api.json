42abe1/s960_dft-gmh-960.jpg","url":"https://assets.publishing.service.gov.uk/media/654bbccfe70413000dfc4a51/s300_dft-gmh-960.jpg"},"logo":{"crest":"single-identity","formatted_title":"Department<br/>for Transport"},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"Department for Transport","web_url":"https://www.gov.uk/government/organisations/department-for-transport","withdrawn":false}],"role_appointments":[{"content_id":"b6e816ab-6c6d-4481-9100-e7e169235d75","details":{"current":true,"ended_on":null,"person_appointment_order":1,"started_on":"2024-07-09T00:00:00+01:00"},"document_type":"role_appointment","links":{"person":[{"api_path":"/api/content/government/people/simon-lightwood","api_url":"https://www.gov.uk/api/content/government/people/simon-lightwood","base_path":"/government/people/simon-lightwood","content_id":"8387f99d-c9cf-4af8-abe5-a12df14d3f8f","details":{"body":"<p>Simon Lightwood was appointed Parliamentary Under-Secretary of State for Local Transport in the Department for Transport on 9 July 2024. Simon was reappointed Parliamentary Under-Secretary of State in the Department for Transport in September 2025 with a new portfolio, Minister for Roads and Buses.</p>\n\n<p>Previously Simon was Shadow Transport Minister, appointed first in October 2022 and re-appointed in September 2023 with an expanded portfolio.</p>\n\n<p>Simon was first elected as <abbr title=\"Member of Parliament\">MP</abbr> for Wakefield in a by-election in June 2022 and was re-elected as <abbr title=\"Member of Parliament\">MP</abbr> for Wakefield and Rothwell in July 2024.</p>\n\n<p>Prior to being elected, Simon was a proud NHS worker, a Labour councillor and cabinet member for public health. He studied theatre acting at Bretton Hall College in Wakefield after moving to the city in the late 90s.</p>\n\n<p>His wider interests involve spending time with his husband and two young children and supporting his local Rugby League team, Wakefield Trinity.</p>\n\n","image":{"alt_text":"Simon Lightwood MP","url":"https://assets.publishing.service.gov.uk/media/68da63b8750fcf90fa6ffb59/s465_sl-photo-960.jpg"}},"document_type":"person","links":{},"locale":"en","public_updated_at":"2025-09-29T10:47:19Z","schema_name":"person","title":"Simon Lightwood MP","web_url":"https://www.gov.uk/government/people/simon-lightwood","withdrawn":false}],"role":[{"api_path":"/api/content/government/ministers/parliamentary-under-secretary-of-state--266","api_url":"https://www.gov.uk/api/content/government/ministers/parliamentary-under-secretary-of-state--266","base_path":"/government/ministers/parliamentary-under-secretary-of-state--266","content_id":"27756bf7-5f73-44d3-9d7b-bc3762037434","details":{"body":"<p>The Minister for Roads and Buses is responsible for:   </p>\n\n<ul>\n  <li>roads </li>\n  <li>buses </li>\n  <li>accessibility </li>\n  <li>automated vehicles (AVs) </li>\n  <li>motoring agencies</li>\n  <li>micromobility</li>\n</ul>\n","role_payment_type":null,"seniority":100,"whip_organisation":{}},"document_type":"ministerial_role","links":{"ordered_parent_organisations":[{"analytics_identifier":"D9","api_path":"/api/content/government/organisations/department-for-transport","api_url":"https://www.gov.uk/api/content/government/organisations/department-for-transport","base_path":"/government/organisations/department-for-transport","content_id":"4c717efc-f47b-478e-a76d-ce1ae0af1946","details":{"acronym":"DfT","brand":"department-for-transport","default_news_image":{"high_resolution_url":"https://assets.publishing.service.gov.uk/media/654bbccfe2e16a000d42abe1/s960_dft-gmh-960.jpg","url":"https://assets.publishing.service.gov.uk/media/654bbccfe70413000dfc4a51/s300_dft-gmh-960.jpg"},"logo":{"crest":"single-identity","formatted_title":"Department<br/>for Transport"},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_t