{"analytics_identifier":"PB178","base_path":"/government/organisations/national-museums-liverpool","content_id":"8819799d-d7cd-4b1f-8dcc-d8db9670c707","description":"National Museums Liverpool (NML) is a diverse group of museums and galleries. Its collections are among the most important and varied in Europe, and contain everything from Impressionist paintings and rare beetles to a lifejacket from the Titanic and artefacts from ancient Egypt. NML is an executive non-departmental public body, sponsored by the Department for Culture, Media and Sport .","details":{"acronym":"NML","alternative_format_contact_email":"","body":"<div class=\"govspeak\"><p>National Museums Liverpool (NML) is a diverse group of museums and galleries. Its collections are among the most important and varied in Europe, and contain everything from Impressionist paintings and rare beetles to a lifejacket from the Titanic and artefacts from ancient Egypt.</p>\n\n<p><abbr title=\"National Museums Liverpool\">NML</abbr> is an executive non-departmental public body, sponsored by the <a class=\"brand__color\" href=\"/government/organisations/department-for-culture-media-and-sport\">Department for Culture, Media and Sport</a>.</p>\n</div>","brand":"department-for-culture-media-sport","foi_exempt":false,"logo":{"crest":"no-identity","formatted_title":"National Museums Liverpool"},"ordered_corporate_information_pages":[],"ordered_featured_documents":[],"ordered_featured_links":[],"ordered_promotional_features":[],"organisation_featuring_priority":"news","organisation_govuk_status":{"status":"exempt","updated_at":null,"url":"http://www.liverpoolmuseums.org.uk/"},"organisation_political":false,"organisation_type":"executive_ndpb","secondary_corporate_information_pages":"","social_media_links":[]},"document_type":"organisation","first_published_at":"2012-02-08T16:33:56+00:00","links":{"available_translations":[{"analytics_identifier":"PB178","api_path":"/api/content/government/organisations/national-museums