{"analytics_identifier":"EA1474","base_path":"/government/organisations/government-commercial-agency","content_id":"9e7b181f-0183-49ed-9f20-17d50b1da113","description":"We are the UK’s largest public procurement agency, helping the public sector maximise value for the nation when buying common goods and services. GCA is an executive agency, sponsored by the Cabinet Office .","details":{"acronym":"GCA","alternative_format_contact_email":"info@gca.gov.uk","body":"<div class=\"govspeak\"><p>We are the UK’s largest public procurement agency, helping the public sector maximise value for the nation when buying common goods and services.</p>\n\n<p><abbr title=\"Government Commercial Agency\">GCA</abbr> is an executive agency, sponsored by the <a class=\"brand__color\" href=\"/government/organisations/cabinet-office\">Cabinet Office</a>.</p>\n</div>","brand":"cabinet-office","foi_exempt":false,"logo":{"crest":"single-identity","formatted_title":"Government <br/>Commercial<br/>Agency"},"ordered_corporate_information_pages":[],"ordered_featured_documents":[],"ordered_featured_links":[{"href":"https://www.gca.gov.uk/about-gca","title":"About Government Commercial Agency"},{"href":"https://www.gca.gov.uk/how-to-buy","title":"Buy through Government Commercial Agency"},{"href":"https://www.gca.gov.uk/how-to-supply","title":"Sell through Government Commercial Agency"},{"href":"https://www.gca.gov.uk/news","title":"Explore our latest news"},{"href":"https://www.gca.gov.uk/careers-with-gca","title":"Work for Government Commercial Agency"}],"ordered_promotional_features":[],"organisation_featuring_priority":"service","organisation_govuk_status":{"status":"live","updated_at":null,"url":null},"organisation_political":false,"organisation_type":"executive_agency","secondary_corporate_information_pages":"","social_media_links":[{"href":"https://www.linkedin.com/company/Government-Commercial-Agency","service_type":"linkedin","title":"LinkedIn"},{"href":"https://www.youtube.com/@GovernmentCommercialAgency","service_type":"youtube","title":"YouTube"}]},"document_type":"organisation","first_published_at":"2026-03-23T11:10:32+00:00","links":{"available_translations":[{"analytics_identifier":"EA1474","api_path":"/api/content/government/organisations/government-commercial-agency","api_url":"https://www.gov.uk/api/content/government/organisations/government-commercial-agency","base_path":"/government/organisations/government-commercial-agency","content_id":"9e7b181f-0183-49ed-9f20-17d50b1da113","document_type":"organisation","links":{},"locale":"en","public_updated_at":"2026-04-02T10:00:55Z","schema_name":"organisation","title":"Government Commercial Agency","web_url":"https://www.gov.uk/government/organisations/government-commercial-agency","withdrawn":false}],"ordered_board_members":[{"api_path":"/api/content/government/people/andrew-forzani","api_url":"https://www.gov.uk/api/content/government/people/andrew-forzani","base_path":"/government/people/andrew-forzani","content_id":"2248ccef-fec2-4f08-bad3-2b2b57ecb3e8","details":{"image":{"alt_text":"Andrew Forzani","url":"https://assets.publishing.service.gov.uk/media/61bb53c0d3bf7f054e76960b/s465_20211216-ForzaniA_960x640.jpg"},"privy_counsellor":false},"document_type":"person","links":{"role_appointments":[{"content_id":"ec1aac85-1294-4a53-90d7-a1c400ad4837","details":{"current":true,"ended_on":null,"person_appointment_order":3,"started_on":"2026-04-01T00:00:00+01:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"df8a5ee7-bb09-4d05-b689-6f0ecc01bf05","details":{"body":"<p>The Chair is responsible for  setting the strategic direction and aims of GCA, and supporting the CEO in making decisions that enable the organisation to achieve those aims.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2026-04-01T10:44:20Z","schema_name":"role","title":"Non-Executive Chair, Government Commercial Agency","withdrawn":false}]},"locale":"en","public_updated_at":"2026-04-01T10:44:44Z","schema_name":"role_appointment","title":"Andrew Forzani - Non-Executive Chair, Government Commercial Agency","withdrawn":false},{"content_id":"2f5d817c-5b3c-458f-9a4b-71f9ca6bcbd1","details":{"current":true,"ended_on":null,"person_appointment_order":2,"started_on":"2025-02-24T00:00:00+00:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"8461ba35-c0f1-11e4-8223-005056011aef","details":{"body":"<p>Reporting to the Chief Executive of the Civil Service, the Government Chief Commercial Officer shapes and leads the programme of commercial reform across government.</p>\n\n<p>The Government Chief Commercial Officer’s priorities include:</p>\n\n<ul>\n  <li>Leading the Government Commercial Function and Governments Grants Management Functions (GCF and GGMF)</li>\n  <li>To steer the cross-government commercial and grants communities in delivering the Plan for Change</li>\n  <li>Delivering efficiencies and savings through the use of digital, data and AI</li>\n  <li>Lead the Functional Strategy</li>\n  <li>Leads the relationship with HMG Strategic Suppliers</li>\n  <li>Improving contract delivery and contract management</li>\n  <li>Advancing the capability of the GCF and GGMF</li>\n  <li>Head of Profession, building a commercial and grants community across the UK</li>\n</ul>\n\n<p>The Government Chief Commercial Officer works closely with departmental ministers, the Cabinet Secretary, departmental permanent secretaries and other senior officials, and senior leaders of government suppliers. The Government Chief Commercial Officer gives evidence to Parliamentary Select Committees, including the Public Accounts Committee, on commercial matters.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2025-03-06T10:23:08Z","schema_name":"role","title":"Government Chief Commercial Officer","withdrawn":false}]},"locale":"en","public_updated_at":"2025-03-06T10:58:47Z","schema_name":"role_appointment","title":"Andrew Forzani - Government Chief Commercial Officer","withdrawn":false},{"content_id":"86616622-6fec-40d6-89f5-9131614130b0","details":{"current":false,"ended_on":"2025-01-31T00:00:00+00:00","person_appointment_order":1,"started_on":"2021-07-26T00:00:00+01:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"c8e4ead6-5b5d-482e-8cf3-611568f78224","details":{"body":"<p>The Director General Commercial role encompasses the whole of Commercial across Defence and DE&amp;S, and has accountability for the largest commercial workforce in the Government Commercial Function.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2021-12-09T13:40:00Z","schema_name":"role","title":"Director General Commercial","withdrawn":false}]},"locale":"en","public_updated_at":"2025-03-06T10:26:44Z","schema_name":"role_appointment","title":"Andrew Forzani - Director General Commercial","withdrawn":false}]},"locale":"en","public_updated_at":"2025-03-11T12:14:56Z","schema_name":"person","title":"Andrew Forzani","web_url":"https://www.gov.uk/government/people/andrew-forzani","withdrawn":false},{"api_path":"/api/content/government/people/sam-ulyatt","api_url":"https://www.gov.uk/api/content/government/people/sam-ulyatt","base_path":"/government/people/sam-ulyatt","content_id":"74ba065b-c40e-457d-b95f-eb8a73e3127c","details":{"image":{"url":"https://assets.publishing.service.gov.uk/media/66e8149924c4f1826d81bb54/s465_Sam_Ulyatt_-_960x640.jpg"},"privy_counsellor":false},"document_type":"person","links":{"role_appointments":[{"content_id":"a522c007-0785-4594-92c6-7c89acfdcc70","details":{"current":false,"ended_on":"2026-03-31T00:00:00+01:00","person_appointment_order":1,"started_on":"2024-07-08T00:00:00+01:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"84754792-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Chief Executive is responsi