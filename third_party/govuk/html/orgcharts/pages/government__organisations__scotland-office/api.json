pdated_at":"2026-03-13T17:58:21Z","schema_name":"role","title":"Parliamentary Under-Secretary of State","web_url":"https://www.gov.uk/government/ministers/parliamentary-under-secretary-of-state--273","withdrawn":false},{"content_id":"84619be1-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Director is responsible for overseeing the delivery of our objectives as set out in the business plan.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2025-09-11T09:37:48Z","schema_name":"role","title":"Director of the Scotland Office","withdrawn":false},{"content_id":"8461b15c-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Principal Private Secretary has responsibility for managing the Secretary of State’s Private Office.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2013-01-29T15:25:30Z","schema_name":"role","title":"Principal Private Secretary to the Secretary of State","withdrawn":false},{"content_id":"846de6b8-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Deputy Director, Policy Delivery and Relationship Management is responsible for:</p>\n\n<ul>\n  <li>Leading the Policy Division which works flexibly on policy priorities across sectors including defence, international trade, digital connectivity, broadcasting, asylum and immigration, City Deals and higher education;</li>\n  <li>Working across the UK and Scottish Governments and with external stakeholders to ensure that the UK Government understands Scottish interests;</li>\n  <li>Supporting ministers on reserved and key devolved subjects;</li>\n  <li>Working with the Cabinet Office on improving UK Government devolution capability and engagement in Scotland.</li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2025-05-09T10:55:41Z","schema_name":"role","title":"Deputy Director, Policy","withdrawn":fa