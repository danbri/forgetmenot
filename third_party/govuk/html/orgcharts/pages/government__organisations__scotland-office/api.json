ended_on":"2025-09-05T00:00:00+01:00","person_appointment_order":2,"started_on":"2025-02-10T00:00:00+00:00"},"document_type":"role_appointment","links":{"role":[{"api_path":"/api/content/government/ministers/minister-of-state--185","api_url":"https://www.gov.uk/api/content/government/ministers/minister-of-state--185","base_path":"/government/ministers/minister-of-state--185","content_id":"531e4937-3c29-497a-9894-5821286d7564","details":{"body":"<p>Responsibilities include:</p>\n\n<ul>\n  <li>Supporting the Chancellor of the Duchy of Lancaster on Intergovernmental Relations</li>\n</ul>\n","role_payment_type":null,"seniority":100,"whip_organisation":{}},"document_type":"ministerial_role","links":{},"locale":"en","public_updated_at":"2025-02-11T14:29:47Z","schema_name":"role","title":"Minister of State at the Cabinet Office ","web_url":"https://www.gov.uk/government/ministers/minister-of-state--185","withdrawn":false}]},"locale":"en","public_updated_at":"2025-09-05T19:01:26Z","schema_name":"role_appointment","title":"The Rt Hon Douglas Alexander MP - Minister of State at the Cabinet Office ","withdrawn":false},{"content_id":"550a7479-d8f2-44bf-86ef-17140e9fc36a","details":{"current":false,"ended_on":"2025-09-05T00:00:00+01:00","person_appointment_order":1,"started_on":"2024-07-06T00:00:00+01:00"},"document_type":"role_appointment","links":{"role":[{"api_path":"/api/content/government/ministers/minister-of-state--172","api_url":"https://www.gov.uk/api/content/government/ministers/minister-of-state--172","base_path":"/government/ministers/minister-of-state--172","content_id":"f5a76846-d414-441b-a76c-7836c151bd26","details":{"body":"<p>Responsibilities include:</p>\n\n<ul>\n  <li>trade strategy </li>\n  <li>free trade agreement (FTA) negotiations</li>\n  <li>UK-EU Trade and Cooperation Agreement (TCA) Implementation</li>\n  <li>Digital Trade Agreements</li>\n  <li>UK Conformity Assessment (UKCA)</li>\n  <li>Mutual Recognition Agreements</li>\n  <li>Windsor Framework</li>\n  <li>investor treaties and disputes</li>\n  <li>investor screening</li>\n  <li>UK Internal Market </li>\n  <li>trade defence</li>\n  <li>bilateral trade relations</li>\n  <li>World Trade Organization (WTO), G7, G20, Organisation for Economic Co-operation and Development (OECD) and Commonwealth</li>\n  <li>trade remedies</li>\n  <li>tariffs and disputes </li>\n  <li>global supply chains</li>\n  <li>economic security</li>\n  <li>Export Control Joint Unit</li>\n  <li>sanctions</li>\n</ul>\n\n<p>The Minister of State is responsible for the following public bodies:</p>\n\n<ul>\n  <li>Trade Remedies Authority</li>\n</ul>\n","role_payment_type":null,"seniority":100,"whip_organisation":{}},"document_type":"ministerial_role","links":{},"locale":"en","public_updated_at":"2025-02-11T14:31:10Z","schema_name":"role","title":"Minister of State (Minister for Trade Policy and Economic Security) at the Department for Business and Trade","web_url":"https://www.gov.uk/government/ministers/minister-of-state--172","withdrawn":false}]},"locale":"en","public_updated_at":"2025-09-05T19:01:15Z","schema_name":"role_appointment","title":"The Rt Hon Douglas Alexander MP - Minister of State (Minister for Trade Policy and Economic Security) at the Department for Business and Trade","withdrawn":false},{"content_id":"fdde0ac9-cd0a-4e4e-99c9-217a6e6f6f5d","details":{"current":true,"ended_on":null,"person_appointment_order":3,"started_on":"2025-09-05T00:00:00+01:00"},"document_type":"role_appointment","links":{"role":[{"api_path":"/api/content/government/ministers/secretary-of-state-for-scotland","api_url":"https://www.gov.uk/api/content/government/ministers/secretary-of-state-for-scotland","base_path":"/government/ministers/secretary-of-state-for-scotland","content_id":"845e65ce-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Secretary of State for Scotland is the UK Government Cabinet Minister representing Scotland. They act as the custodian of the Scottish devolution settlement, represent Scottish interests within the UK Government, and advocate for the UK Government’s policies in Scotland. </p>\n\n<p>They also promote partnership between the UK Government and the Scottish Government, as well as relations between the UK and Scottish Parliaments.</p>\n\n<p>Responsibilities include:</p>\n\n<ul>\n  <li>Industrial strategy delivery</li>\n  <li>Investment</li>\n  <li>Defence</li>\n  <li>Energy and North Sea Policy</li>\n  <li>Child Poverty</li>\n  <li>Oversight of Brand Scotland programme</li>\n  <li>FTAs and market access</li>\n  <li>Constitutional policy</li>\n  <li>Local Growth</li>\n</ul>\n","role_payment_type":null,"seniority":25,"whip_organisation":{}},"document_type":"ministerial_role","links":{},"locale":"en","public_updated_at":"2026-03-13T17:56:19Z","schema_name":"role","title":"Secretary of State for Scotland","web_url":"https://www.gov.uk/government/ministers/secretary-of-state-for-scotland","withdrawn":false}]},"locale":"en","public_updated_at":"2025-09-05T17:02:06Z","schema_name":"role_appointment","title":"The Rt Hon Douglas Alexander MP - Secretary of State for Scotland","withdrawn":false}]},"locale":"en","public_updated_at":"2025-09-05T19:03:52Z","schema_name":"person","title":"The Rt Hon Douglas Alexander MP","web_url":"https://www.gov.uk/government/people/douglas-alexander","withdrawn":false},{"api_path":"/api/content/government/people/kirsty-mcneill","api_url":"https://www.gov.uk/api/content/government/people/kirsty-mcneill","base_path":"/government/people/kirsty-mcneill","content_id":"2d7e7e3b-3133-40b4-99b7-7b7cac0d489b","details":{"image":{"url":"https://assets.publishing.service.gov.uk/media/668eae82a3c2a28abb50cd62/s465_Untitled_design__1_.png"},"privy_counsellor":false},"document_type":"person","links":{"role_appointments":[{"content_id":"ee352d8a-e988-42eb-ac61-45a712015546","details":{"current":true,"ended_on":null,"person_appointment_order":1,"started_on":"2024-07-09T00:00:00+01:00"},"document_type":"role_appointment","links