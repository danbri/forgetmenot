{"analytics_identifier":"OT1041","base_path":"/government/organisations/civil-service-government-statistical-service","content_id":"c665dfa6-0a82-4aaf-b84e-0ea78ccd0e8e","description":"Government Statistical Service is part of the Civil Service .","details":{"acronym":"","alternative_format_contact_email":"","body":"<div class=\"govspeak\">\n<p>Government Statistical Service is part of the <a class=\"brand__color\" href=\"/government/organisations/civil-service\">Civil Service</a>.</p>\n</div>","brand":"cabinet-office","foi_exempt":false,"logo":{"crest":"single-identity","formatted_title":"Government Statistical Service"},"ordered_corporate_information_pages":[],"ordered_featured_documents":[],"ordered_featured_links":[],"ordered_promotional_features":[],"organisation_featuring_priority":"news","organisation_govuk_status":{"status":"exempt","updated_at":null,"url":"https://gss.civilservice.gov.uk/"},"organisation_political":false,"organisation_type":"sub_organisation","secondary_corporate_information_pages":"","social_media_links":[{"href":"https://twitter.com/ukgss","service_type":"twitter","title":"GSS Twitter"}]},"document_type":"organisation","first_published_at":"2014-04-23T15:31:15+01:00","links":{"available_translations":[{"analytics_identifier":"OT1041","api_path":"/api/content/government/organisations/civil-service-government-statistical-service","api_url":"https://www.gov.uk/api/content/government/organisations/civil-service-government-statistical-service","base_path":"/government/organisations/civil-service-government-statistical-service","content_id":"c665dfa6-0a82-4aaf-b84e-0ea78ccd0e8e","document_type":"organisation","links":{},"locale":"en","public_updated_at":"2021-04-15T09:03:33Z","schema_name":"organisation","title":"Government Statistical Service","web_url":"https://www.gov.uk/government/organisations/civil-service-government-statistical-service","withdrawn":false}],"ordered_contacts":[{"content_id":"0fadbfe6-ccd7-4d2d-9a57-c13d09089e36","details":{"contact_form_links":null,"description":null,"email_addresses":[{"email":"gsshelp@statistics.gov.uk"}],"phone_numbers":null,"post_addresses":[],"title":"General enquiries"},"document_type":"contact","links":{},"locale":"en","public_updated_at":"2020-02-05T14:03:13Z","schema_name":"contact","title":"General enquiries","withdrawn":false}],"ordered_parent_organisations":[{"analytics_identifier":"CS1028","api_path":"/api/content/government/organisations/civil-service","api_url":"https://www.gov.uk/api/content/government/organisations/civil-service","base_path":"/government/organisations/civil-service","content_id":"73d2631c-a5ee-443b-940b-af67f42735eb","details":{"acronym":"","brand":"civil-service","default_news_image":null,"logo":{"crest":"single-identity","formatted_title":"Civil Service"},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"Civil Service","web_url":"https://www.gov.uk/government/organisations/civil-service","withdrawn":false}],"ordered_roles":[{"content_id":"d623354d-bccd-4e6d-b8be-e71e778880b8","details":{"body":"<h2 id=\"roles\">Roles</h2>\n\n<p>The National Statistician is the principal adviser on official statistics to the <a rel=\"external\" href=\"https://uksa.statisticsauthority.gov.uk/\">UK Statistics Authority</a> and the Government.</p>\n\n<p>The National Statistician is Head of the <a rel=\"external\" href=\"https://gss.civilservice.gov.uk/\">Government Statistical Service</a> and the <a href=\"https://www.gov.uk/government/organisations/government-analysis-function\">Government Analysis Function</a>.</p>\n\n<p>The National Statistician is also a member of the <a rel=\"external\" href=\"https://uksa.statisticsauthority.gov.uk/about-the-authority/the-authority-board/\">UK Statistics Authority Board</a> as Chief Executive and Permanent Secretary.</p>\n\n<h2 id=\"main-responsibilities\">Main responsibilities</h2>\n\n<ul>\n  <li>Planning of the development of statistics across government.</li>\n  <li>Supporting statisticians and other officials to comply with the UK Statistics Authority’s Code of Practice for Statistics.</li>\n  <li>Advising ministers, the Cabinet Secretary and other senior officials on the production, dissemination and use of statistics across government.</li>\n  <li>Professional leadership for all statisticians producing official statistics, as Head of the Government Statistical Service.</li>\n  <li>Strategic oversight of the Office of National Statistics.</li>\n  <li>Maintain strong relationships with devolved administrations; respecting their specific needs for devolved and other statistics while ensuring as far as possible harmonisation, coherence and consistency in UK statistics.</li>\n  <li>Act as head of the UK’s National Statistical Institute, promoting UK interests as well as contributing to higher standards in statistics across the world.</li>\n</ul>\n\n<h2 id=\"contacting-the-national-statistician\">Contacting the National Statistician</h2>\n\n<p>Email: <a href=\"mailto:national.statistician@statistics.gov.uk\">national.statistician@statistics.gov.uk</a></p>\n\n<p>Address:</p>\n\n<p>National Statistician\nUK Statistics Authority\nStatistics House\nCardiff Road\nNewport\nSouth Wales\nNP10 8XG</p>\n","role_payment_type":null},"document_type":"chief_scientific_advisor_role","links":{},"locale":"en","public_updated_at":"2020-07-15T12:02:19Z","schema_name":"role","title":"UK National Statistician","withdrawn":false}],"organisations":[{"analytics_identifier":"OT1041","api_path":"/api/content/government/organisations/civil-service-government-statistical-service","api_url":"https://www.gov.uk/api/content/government/organisations/civil-service-government-statistical-service","base_path":"/government/organisations/civil-service-government-statistical-service","content_id":"c665dfa6-0a82-4aaf-b84e-0ea78ccd0e8e","details":{"acronym":"","brand":"cabinet-office","default_