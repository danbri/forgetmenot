{"analytics_identifier":"D20","base_path":"/government/organisations/office-of-the-advocate-general-for-scotland","content_id":"93f52ac4-7eb5-47bf-acfe-c11d1c8e8d76","description":"The Office of the Advocate General (OAG) is the UK government’s Scottish legal team.","details":{"acronym":"OAG","alternative_format_contact_email":"enquiries@advocategeneral.gov.uk","body":"<div class=\"govspeak\"><p>The Office of the Advocate General (OAG) is the UK government’s Scottish legal team.</p>\n</div>","brand":"office-of-the-advocate-general-for-scotland","default_news_image":{"high_resolution_url":"https://assets.publishing.service.gov.uk/media/66d9c9e4608fb761b6811153/s960_HEADSHOTS-74__1_.jpg","url":"https://assets.publishing.service.gov.uk/media/66d9c9e4561701fa1c214e9d/s300_HEADSHOTS-74__1_.jpg"},"foi_exempt":false,"logo":{"crest":"so","formatted_title":"Office of the<br/>Advocate General<br/>for Scotland"},"ordered_corporate_information_pages":[{"href":"/government/organisations/office-of-the-advocate-general-for-scotland/about/complaints-procedure","title":"Complaints procedure"},{"href":"/government/organisations/office-of-the-advocate-general-for-scotland/about/our-governance","title":"Our governance"},{"href":"/government/organisations/office-of-the-advocate-general-for-scotland/about/procurement","title":"Procurement at OAG"},{"href":"/government/organisations/office-of-the-advocate-general-for-scotland/about/recruitment","title":"Working for OAG"}],"ordered_featured_documents":[{"document_type":"Press release","href":"/government/news/catherine-smith-kc-appointed-as-advocate-general-for-scotland","image":{"alt_text":"Catherine Smith KC","high_resolution_url":"https://assets.publishing.service.gov.uk/media/66d9cb492bc43c72b082650b/s712_HEADSHOTS-74__1_.jpg","medium_resolution_url":"https://assets.publishing.service.gov.uk/media/66d9cb49fb86ba5a1f214e9f/s465_HEADSHOTS-74__1_.jpg","url":"https://assets.publishing.service.gov.uk/media/66d9cb49561701fa1c214ea0/HEADSHOTS