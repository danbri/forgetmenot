:"en","public_updated_at":"2020-09-16T20:14:50Z","schema_name":"contact","title":"Freedom of Information requests","withdrawn":false},{"content_id":"dfecd4c5-5d2b-4d39-8aca-75b70516a5c4","details":{"contact_form_links":null,"description":"Please serve documents by email wherever possible. ","email_addresses":[{"email":"oaglitigationmailbox@advocategeneral.gov.uk","title":"Office of the Advocate General"}],"phone_numbers":null,"post_addresses":[{"iso2_country_code":"gb","locality":"Edinburgh","postal_code":"EH8 8FT","street_address":"Queen Elizabeth House","title":"Office of the Advocate General","world_location":"United Kingdom"}],"title":"Service of Legal Documents"},"document_type":"contact","links":{},"locale":"en","public_updated_at":"2026-04-09T15:20:55Z","schema_name":"contact","title":"Service of Legal Documents","withdrawn":false}],"ordered_ministers":[{"api_path":"/api/content/government/people/catherine-smith","api_url":"https://www.gov.uk/api/content/government/people/catherine-smith","base_path":"/government/people/catherine-smith","content_id":"03e706f4-2d29-483f-a6bc-728f526920c3","details":{"image":{"url":"https://assets.publishing.service.gov.uk/media/66d9a1f9e87ad2f1218264e4/s465_HEADSHOTS-74__1_.jpg"},"privy_counsellor":false},"document_type":"person","links":{"role_appointments":[{"content_id":"140bbc56-9f70-4096-8b94-3c36675d6613","details":{"current":true,"ended_on":null,"person_appointment_order":1,"started_on":"2024-08-29T00:00:00+01:00"},"document_type":"role_appointment","links":{"role":[{"api_path":"/api/content/government/ministers/hm-advocate-general-for-scotland","api_url":"https://www.gov.uk/api/content/government/ministers/hm-advocate-general-for-scotland","base_path":"/government/ministers/hm-advocate-general-for-scotland","content_id":"845e8426-c0f1-11e4-8223-005056011aef","details":{"body":"<h3 id=\"advocate-general-for-scotland\">Advocate General for Scotland</h3>\n<p>The Advocate General for Scotland is one of the Law Officers of the Crown, who advise the government on Scots law.</p>\n\n<p>Responsibilities include:</p>\n\n<ul>\n  <li>Oversight of Schedule 6 to the Scotland Act 1998 relating to ‘devolution issues’ raised before\ncourts or tribunals in Scotland</li>\n  <li>The Advocate General can choose to intervene, on behalf of the UK government, in\nproceedings in which devolution issues have been raised if they so decide</li>\n  <li>The Office of the Advocate General considers all Scottish Parliament Bills as they progress, in\nconsultation with interested UK government departments, to assess their legislative\ncompetency. Under section 33 of the Scotland Act, the Advocate General has the power to\nrefer Scottish Parliament Bills to the Supreme Court for decisions on their legislative\ncompetence</li>\n</ul>\n\n","role_payment_type":null,"seniority":9,"whip_organisation":{}},"document_type":"ministerial_role","links":{},"locale":"en","public_updated_at":"2025-03-24T15:36:01Z","schema_name":"role","title":"HM Advocate General for Scotland ","web_url":"https://www.gov.uk/government/ministers/hm-advocate-general-for-scotland","withdrawn":false}]},"locale":"en","public_updated_at":"2024-08-29T13:20:09Z","schema_name":"role_appointment","title":"Catherine Smith KC - HM Advocate General for Scotland ","withdrawn":false}]},"locale":"en","public_updated_at":"2026-03-09T11:18:23Z","schema_name":"person","title":"Baroness Smith of Cluny KC","web_url":"https://www.gov.uk/government/people/catherine-smith","withdrawn":false}],"ordered_roles":[{"api_path":"/api/content/government/ministers/hm-advocate-general-for-scotland","api_url":"https://www.gov.uk/api/content/government/ministers/hm-advocate-general-for-scotland","base_path":"/government/ministers/hm-advocate-general-for-scotland","content_id":"845e8426-c0f1-11e4-8223-005056011aef","details":{"body":"<h3 id=\"advocate-general-for-scotland\">Advocate General for Scotland</h3>\n<p>The Advocate General for Scotland is one of the Law Officers of the Crown, who advise the government on Scots law.</p>\n\n<p>Responsibilities include:</p>\n\n<ul>\n  <li>Oversight of Schedule 6 to the Scotland Act 1998 relating to ‘devolution issues’ raised before\ncourts or tribunals in Scotland</li>\n  <li>The Advocate General can choose to intervene, on behalf of the UK government, in\nproceedings in which devolution issues have been raised if they so decide</li>\n  <li>The Office of the Advocate General considers all Scottish Parliament Bills as they progress, in\nconsultation with interested UK government departments, to assess their legislative\ncompetency. Under section 33 of the Scotland Act, the Advocate General has the power to\nrefer Scottish Parliament Bills to the Supreme Court for decisions on their legislative\ncompetence</li>\n</ul>\n\n","role_payment_type":null,"seniority":9,"whip_organisation":{}},"document_type":"ministerial_role","links":{},"locale":"en","public_updated_at":"2025-03-24T15:36:01Z","schema_name":"role","title":"HM Advocate General for Scotland ","web_url":"https://www.gov.uk/government/ministers/hm-advocate-general-for-scotland","withdrawn":false},{"content_id":"8461c3df-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Legal Secretary is responsible for supporting the Advocate General in his various roles, including in his capacity as one of the UK Government’s Law Officers, as a UK Government Minister, and as the UK Government’s representative in the House of Lords. The Legal Secretary also leads a legal team in the Legal Secretariat to the Advocate General, leads the Advocate General’s Private Office team, and undertakes responsibilities as a member of the Office of the Advocate General’s Senior Leadership Team.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2021-07-06T16:12:20Z","schema_name":"role","title":"Legal Secretary to the Advocate General","withdrawn":false},{"content_id":"8461ca29-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Director of OAG is responsible for overseeing all legal services provided by OAG to the UK government, and for overseeing delivery of OAG’s objectives as set out in its Business Plan.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2013-02-26T14:46:04Z","schema_name":"role","title":"Director and Solicitor to the Advocate General","withdrawn":false},{"content_id":"8461cd1d-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Head of Litigation Division is responsible for supporting the Advocate General in relation to his devolution issue functions under the Scotland Act 1998 and for securing effective representation of UK Government interests in Scottish litigation.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2013-02-27T13:03:42Z","schema_name":"role","title":"Head of Litigation Division","withdrawn":false},{"content_id":"8461cd73-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Head of Advisory and Legislation Division is responsible for the team that provides legal advice and legislative services to UK Government departments, and in particular advice on Scots law and the Scottish devolution settlement.  The team also assesses the impact of Scottish Government legislation going through the Scottish Parliament in support of the Advocate General’s statutory functions under section 33 of the Scotland Act 1998.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2013-05-29T09:39:57Z","schema_name":"role","title":"Head of Advisory and Legislation Division","withdrawn":false},{"content_id":"8461ca79-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Head of HMRC Division is responsible for managing the team that provides legal advice to, and representation in litigation for, His Majesty’s Revenue and Customs in Scotland.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2025-05-06T10:01:17Z","schema_name":"role","title":"Head of HMRC Division","withdrawn":false}],"organisations":[{"analytics_identifier":"D20","api_path":"/api/content/government/organisations/office-of-the-advocate-general-for-scotland","api_url":"https://www.gov.uk/api/content/government/organisations/office-of-the-advocate-general-for-scotland","base_path":"/government/organisations/office-of-the-advocate-general-for-scotland","content_id":"93f52ac4-7eb5-47bf-acfe-c11d1c8e8d76","details":{"acronym":"OAG","brand":"office-of-the-advocate-general-for-scotland","default_news_image":{"high_resolution_url":"https://assets.publishing.service.gov.uk/media/66d9c9e4608fb761b6811153/s960_HEADSHOTS-74__1_.jpg","url":"https://assets.publishing.service.gov.uk/media/66d9c9e4561701fa1c214e9d/s300_HEADSHOTS-74__1_.jpg"},"logo":{"crest":"so","formatted_title":"Office of the<br/>Advocate General<br/>for Scotland"},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"Office of the Advocate General for Scotland","web_url":"https://www.gov.uk/government/organisations/office-of-the-advocate-general-for-scotland","withdrawn":false}],"primary_publishing_organisation":[{"analytics_identifier":"D20","api_path":"/api/content/government/organisations/office-of-the-advocate-general-for-scotland","api_url":"https://www.gov.uk/api/content/government/organisations/office-of-the-advocate-general-for-scotland","base_path":"/government/organisations/office-of-the-advocate-general-for-scotland","content_id":"93f52ac4-7eb5-47bf-acfe-c11d1c8e8d76","details":{"acronym":"OAG","brand":"office-of-the-advocate-general-for-scotland","default_news_image":{"high_resolution_url":"https://assets.publishing.service.gov.uk/media/66d9c9e4608fb761b6811153/s960_HEADSHOTS-74__1_.jpg","url":"https://assets.pub