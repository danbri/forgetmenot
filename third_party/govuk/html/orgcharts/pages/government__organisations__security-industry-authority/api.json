or of IME is responsible for:</p>\n\n<ul>\n  <li>investigations: the commission’s most serious and high risk cases</li>\n  <li>monitoring: proactively identifying potential non-compliance, carrying out compliance inspections and regulatory visits</li>\n  <li>intelligence: providing intelligence and overseeing our relationships with other public authorities</li>\n  <li>accountancy: providing accountancy support on cases and undertaking proactive scrutiny of accounts</li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2015-03-02T14:15:49Z","schema_name":"role","title":"Director of Investigations, Monitoring and Enforcement","withdrawn":false}]},"locale":"en","public_updated_at":"2019-12-31T15:02:15Z","schema_name":"role_appointment","title":"Michelle Russell - Director of Investigations, Monitoring and Enforcement","withdrawn":false}]},"locale":"en","public_updated_at":"2026-02-02T15:31:11Z","schema_name":"person","title":"Michelle Russell","web_url":"https://www.gov.uk/government/people/michelle-russell","withdrawn":false},{"api_path":"/api/content/government/people/tim-archer","api_url":"https://www.gov.uk/api/content/government/people/tim-archer","base_path":"/government/people/tim-archer","content_id":"7466778c-0708-4071-a008-be7126824120","details":{"image":{"alt_text":"Tim Archer","url":"https://assets.publishing.service.gov.uk/media/66703979891714c0d01401d8/s465_tim-archer.jpg"},"privy_counsellor":false},"document_type":"person","links":{"role_appointments":[{"content_id":"fd4c7354-cda6-44b9-8518-c012af926244","details":{"current":true,"ended_on":null,"person_appointment_order":1,"started_on":"2024-06-03T00:00:00+01:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"11c5e635-86e7-4c6a-9ae4-7f62717a80fb","details":{"body":"\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2026-02-02T15:25:43Z","schema_name":"ro