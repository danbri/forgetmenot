e":"LinkedIn"},{"href":"http://www.youtube.com/ukhomeoffice","service_type":"youtube","title":"YouTube"},{"href":"https://homeofficemedia.blog.gov.uk/","service_type":"blog","title":"Home Office in the Media blog"}]},"document_type":"organisation","first_published_at":"2014-07-01T16:26:40+01:00","links":{"available_translations":[{"analytics_identifier":"OT1069","api_path":"/api/content/government/organisations/immigration-enforcement","api_url":"https://www.gov.uk/api/content/government/organisations/immigration-enforcement","base_path":"/government/organisations/immigration-enforcement","content_id":"9981b813-468f-414a-a468-28f5438811f4","document_type":"organisation","links":{},"locale":"en","public_updated_at":"2024-08-30T09:56:46Z","schema_name":"organisation","title":"Immigration Enforcement","web_url":"https://www.gov.uk/government/organisations/immigration-enforcement","withdrawn":false}],"ordered_board_members":[{"api_path":"/api/content/government/people/bas-javid","api_url":"https://www.gov.uk/api/content/government/people/bas-javid","base_path":"/government/people/bas-javid","content_id":"eceaaead-6c11-408e-99ba-3a795d23d0a9","details":{"image":{"url":"https://assets.publishing.service.gov.uk/media/6572e93d049516000f49be91/s465_Bas_headshot_2.jpg"},"privy_counsellor":false},"document_type":"person","links":{"role_appointments":[{"content_id":"a498dd3c-b510-4b8d-80a3-f0e610ec99cf","details":{"current":true,"ended_on":null,"person_appointment_order":1,"started_on":"2023-11-03T00:00:00+00:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"846da94e-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Director General for Immigration Enforcement is responsible for:</p>\n\n<ul>\n  <li>\n    <p>leading a workforce of approximately 7,200 staff, including a uniformed frontline enforcement capability, and managing an annual budget of around £1.2 billion</p>\n  </li>\n  <li>\n    <p>developing and delivering complex operational programmes to disrupt the criminal gangs that facilitate illegal immigration and exploit vulnerable people</p>\n  </li>\n  <li>\n    <p>tackling illegal migration, removing those with no right to remain in the UK and protecting vulnerable individuals</p>\n  </li>\n  <li>\n    <p>leading teams of immigration officers, criminal investigators and financial investigators, working to tackle organised immigration crime, illegal working and the sale of smuggled goods</p>\n  </li>\n  <li>\n    <p>ensuring the operational effectiveness of casework teams responsible for removing individuals with no right to remain in the UK, including the deportation of foreign national offenders</p>\n  </li>\n  <li>\n    <p>overseeing the immigration detention estate and the escorting contracts delivered through commercial partners</p>\n  </li>\n  <li>\n    <p>delivering the compliant environment, a range of measures designed to prevent those without lawful status from accessing work, benefits and services</p>\n  </li>\n  <li>\n    <p>contributing to cross-departmental governance as Chair of the Home Office People Committee and as a member of the Home Office Executive Committee (ExCo) and other senior governance forums</p>\n  </li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2026-03-06T14:45:43Z","schema_name":"role","title":"Director General, Immigration Enforcement","withdrawn":false}]},"locale":"en","public_updated_at":"2023-11-10T11:11:47Z","schema_name":"role_appointment","title":"Bas Javid - Director General of Immigration Enforcement","withdrawn":false}]},"locale":"en","public_updated_at":"2026-03-06T14:38:00Z","schema_name":"person","title":"Bas Javid","web_url":"https://www.gov.uk/government/people/bas-javid","withdrawn":false}],"ordered_contacts":[{"content_id":"1ebb7b4f-3caa-4c8e-904e-c8c8d13c9df9","details":{"contact_form_links":null,"description":null,"email_addresses":null,"phone_numbers":null,"post_addresses":[{"iso2_