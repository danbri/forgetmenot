{"analytics_identifier":"OT1191","base_path":"/government/organisations/defence-safety-authority","content_id":"9b412fdd-ca63-4aee-8530-afd2d893e331","description":"The Defence Safety Authority is established by a Charter issued by the Secretary of State (SofS) empowering it as an independent Regulator and Investigator for Health, Safety and Environmental Protection (HS&EP) in Defence. DSA is part of the Ministry of Defence .","details":{"acronym":"DSA","alternative_format_contact_email":"","body":"<div class=\"govspeak\"><p>The Defence Safety Authority is established by a Charter issued by the Secretary of State (SofS) empowering it as an independent Regulator and Investigator for Health, Safety and Environmental Protection (HS&amp;EP) in Defence.</p>\n\n<p><abbr title=\"Defence Safety Authority\">DSA</abbr> is part of the <a class=\"brand__color\" href=\"/government/organisations/ministry-of-defence\">Ministry of Defence</a>.</p>\n</div>","brand":"ministry-of-defence","foi_exempt":false,"logo":{"crest":"mod","formatted_title":"Defence<br/>Safety Authority"},"ordered_corporate_information_pages":[],"ordered_featured_documents":[],"ordered_featured_links":[{"href":"https://www.gov.uk/government/collections/dsa-annual-assurance-reports","title":"Annual assurance reports"},{"href":"https://www.gov.uk/government/organisations/defence-safety-authority/about#service-inquiries","title":"Service inquiries"}],"ordered_promotional_features":[],"organisation_featuring_priority":"news","organisation_govuk_status":{"status":"live","updated_at":null,"url":null},"organisation_political":false,"organisation_type":"sub_organisation","secondary_corporate_information_pages":"","social_media_links":[]},"document_type":"organisation","first_published_at":"2016-04-18T17:20:02+01:00","links":{"available_translations":[{"analytics_identifier":"OT1191","api_path":"/api/content/government/organisations/defence-safety-authority","api_url":"https://www.gov.uk/api/content/government/organisations/defence-safety-authority","base_path":"/government/organisations/defence-safety-authority","content_id":"9b412fdd-ca63-4aee-8530-afd2d893e331","document_type":"organisation","links":{},"locale":"en","public_updated_at":"2024-07-10T13:03:20Z","schema_name":"organisation","title":"Defence Safety Authority","web_url":"https://www.gov.uk/government/organisations/defence-safety-authority","withdrawn":false}],"document_collections":[{"api_path":"/api/content/government/collections/defence-safety-authority-dsa-publications","api_url":"https://www.gov.uk/api/content/government/collections/defence-safety-authority-dsa-publications","base_path":"/government/collections/defence-safety-authority-dsa-publications","content_id":"bc538ed2-6890-4b9c-87ce-8e59a22d9b8b","document_type":"document_collection","links":{"documents":[{"analytics_identifier":"OT1191","api_path":"/api/content/government/organisations/defence-safety-authority","api_url":"https://www.gov.uk/api/content/government/organisations/defence-safety-authority","base_path":"/government/organisations/defence-safety-authority","content_id":"9b412fdd-ca63-4aee-8530-afd2d893e331","details":{"acronym":"DSA","brand":"ministry-of-defence","default_news_image":null,"logo":{"crest":"mod","formatted_title":"Defence<br/>Safety Authority"},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"Defence Safety Authority","web_url":"https://www.gov.uk/government/organisations/defence-safety-authority","withdrawn":false}]},"locale":"en","public_updated_at":"2025-08-21T14:41:44Z","schema_name":"document_collection","title":"Defence Safety Authority (DSA) publications","web_url":"https://www.gov.uk/government/collections/defence-safety-authority-dsa-publications","withdrawn":false}],"ordered_board_members":[{"api_path":"/api/content/government/people/alan-gillespie","api_url":"https://www.gov.uk/api/content/government/people/alan-gillespie","base_path":"/government/people/alan-gillespie","content_id":"30c9e687-c088-4258-8444-c4f965bc7881","details":{"image":{"alt_text":"Air Marshal Alan Gillespie CBE MA BSc RAF","url":"https://assets.publishing.service.gov.uk/media/61d551e0d3bf7f1f76d00b7c/s465_Alan_Gillespie_960x640.jpg"},"privy_counsellor":false},"document_type":"person","links":{"role_appointments":[{"content_id":"e888ca1b-ead3-44f5-bf22-6ac9233f4ade","details":{"current":true,"ended_on":null,"person_appointment_order":2,"started_on":"2024-11-29T00:00:00+00:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"1276e25c-f7a3-40d8-bfd0-4a73dbcb4559","details":{"body":"<ul>\n  <li>is empowered, by the Secretary of State for Defence, to lead the DSA in its roles as the independent regulator, investigator and assurer for Health, Safety and Environmental Protection (HS&amp;EP) within defence</li>\n  <li>provides independent assurance to the Secretary of State and the department that the Secretary of State’s policy on HS&amp;EP in defence is being implemented in the conduct of defence activities</li>\n  <li>prepares an annual assurance report including a summary of HS&amp;EP compliance and risk for consideration by the Second Permanent Secretary, the Defence Board and the Secretary of State</li>\n  <li>is the primary convening authority for HS&amp;EP-related Service Inquiries (SI)</li>\n  <li>ensures all HS&amp;EP-related fatalities, serious injuries, significant environmental incidents and major capability loss are appropriately investigated to identify lessons, make recommendations, promote continuous improvement and minimise the risk of reoccurrence</li>\n</ul>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2024-11-29T09:20:47Z","schema_name":"role","title":"Director General Defence Safety Authority","withdrawn":false}]},"locale":"en","public_updated_at":"2024-11-29T09:28:16Z","schema_name":"role_appointment","title":"Air Marshal Alan Gillespie CBE MA BSc RAF - Director General Defence Safety Authority","withdrawn":false},{"content_id":"c902d8c9-6ceb-44f9-8437-fd929215594d","details":{"current":false,"ended_on":"2024-11-28T00:00:00+00:00","person_appointment_order":1,"started_on":"2021-12-10T00:00:00+00:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"132a7ba8-30ff-43ba-9fc7-c4c32abd6776","details":{"body":"<p>Director <abbr title=\"Military Aviation Authority\">MAA</abbr> responsibilities include:</p>\n\n<ul>\n  <li>Responsible for regulating all Defence aviation activity, with a mission to enhance operational capability through modern, innovative air safety regulations and practices</li>\n  <li>Setting regulations and providing air safety assurance to DG Defence Safety Authority</li>\n  <li>Senior Operating Subject Matter Expert for the Military Aviation Authority across all divisions</li>\n  <li>Leading and directing <abbr title=\"Military Aviation Authority\">MAA</abbr> strategy, delivery and development</li>\n  <li>\n<abbr title=\"Ministry of Defence\">MOD</abbr> link with the Civil Aviation Authority (CAA) and European Aviation Safety Agency (EASA) for aviation regulatory matters</li>\n  <li>\n<abbr title=\"Ministry of Defence\">MOD</abbr> link with Industry for design, manufacturing, maintenance, modification and certification standards and Contractor Accountable Manager organisations</li>\n</ul>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2025-07-11T07:54:52Z","schema_name":"role","title":"Director Military Aviation Authority","withdrawn":false}]},"locale":"en","public_updated_at":"2024-11-29T09:26:40Z","schema_name":"role_appointment","title":"Air Marshal Alan Gillespie CBE MA BSc RAF - Director Military Aviation Authority","withdrawn":false}]},"locale":"en","public_updated_at":"2024-11-29T09:30:06Z","schema_name":"person","title":"Air Marshal Alan Gillespie CBE MA BSc RAF","web_url":"https://www.gov.uk/government/people/alan-gillespie","withdrawn":false},{"api_path":"/api/content/government/people/mark-hunt","api_url":"https://www.gov.uk/api/content/government/people/mark-hunt","base_path":"/government/people/mark-hunt","content_id":"db15e808-c009-43f1-81e0-e182dafd5dca","details":{"image":{"alt_text":"Air Vice-Marshal Mark Hunt OBE BEng(Hons) MSc MA MBA FCMI CEng FRAeS FIMechE RAF","url":"https://assets.publishing.service.gov.uk/media/678f433fea48a571517acfcc/s465_Mark_Hunt_960x640.jpg"},"privy_counsellor":false},"document_type":"person","links":{"role_appointments":[{"content_id":"25fc2d11-86ff-4b29-b61c-b297327904b0","details":{"current":true,"ended_on":null,"person_appointment_order":1,"started_on":"2024-12-18T00:00:00+00:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"8477a691-c0f1-11e4-8223-005056011aef","details":{"body":"<p>Responsibilities include:</p>\n\n<ul>\n  <li>As Deputy Director General, lead DSA’s strategy development and governance, representing the Director General as interlocutor across Defence for independent safety and environmental regulation, assurance, enforcement and investigation.</li>\n  <li>As Technical Director, cohere the Defence Regulators across Aviation, Maritime, Land, Nuclear, Ordnance, Munitions and Explosives, Medical Services, Fire and Environmental Protection.</li>\n</ul>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2025-03-24T10:08:53Z","schema_name":"role","title":"Deputy Director General and Technical Director of the DSA","withdrawn":false}]},"locale":"en","public_updated_at":"2025-01-21T09:36:18Z","schema_name":"role_appointment","title":"Air Vice-Marshal Mark Hunt OBE BEng(Hons) MSc MA MBA FCMI CEng FRAeS FIMechE RAF - Deputy Director General for the DSA and Director (Technical) MAA","withdrawn":false}]},"locale":"en","public_updated_at":"2025-03-24T10:11:02Z","schema_name":"person","tit