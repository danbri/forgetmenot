details":{"current":true,"ended_on":null,"person_appointment_order":4,"started_on":"2024-02-01T00:00:00+00:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"8470634b-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Review Body on Senior Salaries provides independent advice to the Prime Minister, the Lord Chancellor, the Secretary of State for Defence, the Secretary of State for Health and the Home Secretary on the pay of: the judiciary; senior civil servants; senior officers of the armed forces; certain senior managers in the NHS; Police and Crime Commissioners; chief police officers; and other such public appointments as may from time to time be specified.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2023-05-15T13:12:12Z","schema_name":"role","title":"SSRB Member","withdrawn":false}]},"locale":"en","public_updated_at":"2024-03-12T11:00:23Z","schema_name":"role_appointment","title":"Zoë Billingham CBE - SSRB Member","withdrawn":false},{"content_id":"467f9d38-1eb3-489c-a704-93aa95720ed9","details":{"current":true,"ended_on":null,"person_appointment_order":7482,"started_on":"2022-01-01T00:00:00+00:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"8477cae7-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The chair of the <abbr title=\"Police Remuneration Review Body\">PRRB</abbr> is responsible for providing independent advice to the government on pay and conditions for police officers at or below the rank of chief superintendent in England, Wales and Northern Ireland.</p>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2023-05-16T09:04:24Z","schema_name":"role","title":"PRRB Chair","withdrawn":false}]},"locale":"en","public_updated_at":"2022-01-20T15:12:50Z","schema_name":"role_appointment","title":"Zoë Billingham - Chair","withdrawn":false},{"content_id":"a03fd09c-4207-4020-9964-db9f3eb0faac","details":{"current":true,"ended_on":null,"person_appointment_order":7481,"started_on":"2022-01-01T00:00:00+00:00"},"document_type":"role_appointment","links":{"role":[{"content_id":"84707032-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Chair of the National Crime Agency Remuneration Review Body is responsible for:</p>\n\n<ul>\n  <li>making recommendations on the pay and allowances of National Crime Agency (<abbr title=\"National Crime Agency\">NCA</abbr>) officers designated with operational powers</li>\n  <li>considering written evidence from the Home Office, the <abbr title=\"National Crime Agency\">NCA</abbr>, trades unions and other interested parties</li>\n  <li>visiting the <abbr title=\"National Crime Agency\">NCA</abbr> to meet <abbr title=\"National Crime Agency\">NCA</abbr> officers with operational powers and management to gather information and views on pay and related issues</li>\n</ul>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2023-05-16T09:22:57Z","schema_name":"role","title":"NCARRB Chair","withdrawn":false}]},"locale":"en","public_updated_at":"2022-01-20T15:12:09Z","schema_name":"role_appointment","title":"Zoë Billingham - Chair","withdrawn":false}]},"locale":"en","public_updated_at":"2025-03-05T11:14:57Z","schema_name":"person","title":"The Hon Zoë Billingham CBE","web_url":"https://www.gov.uk/government/people/zoe-billingham","withdrawn":false},{"api_path":"/api/content/government/people/andy-bliss","api_url":"https://www.gov.uk/api/content/government/people/andy-bliss","base_path":"/government/people/andy-bliss","content_id":"56deb18f-44a8-47cd-89e2-ccce086070e3","details":{"image":null,"privy_counsellor":false},"document_type":"person","links":{"role_appointments":[{"content_id":"65d5e169-2136-4b78-af16-e5f3740a1112","details":{"current":true,"ended_on":null,"person_appointment_order":7480,"started_on":"2018-12-02T00:00:00+00:00"},"document_type":"role_ap