"public_updated_at":"2025-09-11T06:19:56Z","schema_name":"special_route","title":"History of the UK government","web_url":"https://www.gov.uk/government/history","withdrawn":false}],"person":[{"api_path":"/api/content/government/people/george-canning","api_url":"https://www.gov.uk/api/content/government/people/george-canning","base_path":"/government/people/george-canning","content_id":"85373c3a-c0f1-11e4-8223-005056011aef","details":{"body":"<p>George Canning served as Prime Minister between 1827 to 1827. Read more about the life and achievements of George Canning in our <a href=\"/government/history/past-prime-ministers/george-canning\">past Prime Ministers</a> section.</p>\n","image":{"alt_text":"George Canning","url":"https://assets.publishing.service.gov.uk/media/5dc42bd5ed915d3955db7875/s465_George-Canning.jpg"}},"document_type":"person","links":{},"locale":"en","public_updated_at":"2019-11-07T14:29:31Z","schema_name":"person","title":"George Canning","web_url":"https://www.gov.uk/government/people/george-canning","withdrawn":false}]},"locale":"en","phase":"live","public_updated_at":"2023-01-19T17:38:33+00:00","publishing_app":"whitehall","publishing_request_id":"21-1700065146.824-10.13.24.179-698","publishing_scheduled_at":null,"rendering_app":"collections","scheduled_publishing_delay_seconds":null,"schema_name":"historic_appointment","title":"George Canning","updated_at":"2026-01-07T18:57:09+00:00","withdrawn_notice":{}}