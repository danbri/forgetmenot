,"formatted_title":"British Cattle Movement Service"},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"British Cattle Movement Service","web_url":"https://www.gov.uk/government/organisations/british-cattle-movement-service","withdrawn":false}],"ordered_parent_organisations":[{"analytics_identifier":"D7","api_path":"/api/content/government/organisations/department-for-environment-food-rural-affairs","api_url":"https://www.gov.uk/api/content/government/organisations/department-for-environment-food-rural-affairs","base_path":"/government/organisations/department-for-environment-food-rural-affairs","content_id":"de4e9dc6-cca4-43af-a594-682023b84d6c","details":{"acronym":"Defra","brand":"department-for-environment-food-rural-affairs","default_news_image":{"high_resolution_url":"https://assets.publishing.service.gov.uk/media/5a37dad140f0b649cceb1813/s960_defra-sign-grey.jpg","url":"https://assets.publishing.service.gov.uk/media/5a37dad1ed915d5a62fdc6d6/s300_defra-sign-grey.jpg"},"logo":{"crest":"single-identity","formatted_title":"Department<br/>for Environment,<br/>Food &amp; Rural Affairs"},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"Department for Environment, Food & Rural Affairs","web_url":"https://www.gov.uk/government/organisations/department-for-environment-food-rural-affairs","withdrawn":false}],"ordered_roles":[{"content_id":"8472b017-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The <abbr title=\"Rural Payments Agency\">RPA</abbr>’s Chief Executive is appointed by Defra as the agency’s Accounting Officer and is responsible for overall leadership of <abbr title=\"Rural Payments Agency\">RPA</abbr>.</p>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2026-02-16T15:45:56Z","schema_name":"role","title":"Chief Executive, RPA","withdrawn":false},{"content_id":"8472b067-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The <abbr title=\"Rural Payments Agency\">RPA</abbr>’s Chief Executive is appointed by <abbr title=\"Department for Environment, Food and Rural Affairs\">Defra</abbr> as the Agency’s Accounting Officer and is responsible for overall leadership of the <abbr title=\"Rural Payments Agency\">RPA</abbr>.</p>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2025-07-02T15:31:49Z","schema_name":"role","title":"Interim Chief Executive, RPA","withdrawn":false},{"content_id":"8472b420-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Business Transformation Director has overall responsibility for leading change and business transformation programmes and initiatives on behalf of the Agency. This includes the development and delivery of organisational, process, system and digital change, design of training and internal guidance and business process change products. In addition the director is responsible for initiating and acting on insight and feedback from customers, stakeholders and other Defra partners. The role holder is also the Senior Information Risk Owner on behalf of the Agency.</p>\n\n<p>The overall objective of the role is to assure the Agency, on behalf of Defra, can embrace and implement change, be more efficient and recognise and realise the requirements of its customer base to create a high performance organisation that is recognised for its excellence in customer service and value for money.</p>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2020-04-09T12:22:53Z","schema_name":"role","title":"Business Transformation Director","withdrawn":false},{"content_id":"8477a901-c0f1-11e4-8223-005056011aef","details":{"body":"<p>The Strategy Policy and Business Services Director has overall responsibility for the agency’s strategy and policy development, corporate governance and legal requirements, stakeholder engagement and delivering internal business services that support the day to day management of the agency.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2018-10-23T08:19:54Z","schema_name":"role","title":"Strategy Policy and Business Services Director","withdrawn":false},{"content_id":"46d4b171-a975-4d07-a286-45d278ee2781","details":{"body":"<p>The EU Reporting and Compliance Director has overall responsibility for assuring EU Regulatory requirements are met by the organisation and Defra Corporate Service functions to protect the paying agency status, and moving forwards working with Defra policy leads to identify the impacts of EU exit and development of future regulatory requirements driven by policy change. The EU Reporting and Compliance Director is expected to make risk based assessments and decisions, taking account of the balance of disallowance and delivery.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2018-02-07T15:31:15Z","schema_name":"role","title":"EU Reporting and Compliance Director","withdrawn":false},{"content_id":"217b5801-687a-42e7-89a4-9d702198d950","details":{"body":"<p>Susan is currently responsible for the operational delivery of the Basic Payment Scheme, Countryside Stewardship and Environmental Stewardship.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2020-04-27T14:30:55Z","schema_name":"role","title":"Environmental Stewardship Operations Director","withdrawn":false},{"content_id":"e947856c-3866-44f2-837d-b01341cdaec4","details":{"body":"<p>Andy currently leads RPA’s Land Management, Productivity and Grants directorate after successfully leading customer operations, stakeholder and reputation management, communications and guidance as well as the British Cattle Movement Service (BCMS), Rural Development Programme and Trader Operations.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2020-05-18T14:24:45Z","schema_name":"role","title":"Operations Delivery Director","withdrawn":false},{"content_id":"6dbff65b-0665-4285-8418-2cfcff2bcfdb","details":{"body":"<p>Responsibilities to follow.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2019-04-24T10:57:06Z","schema_name":"role","title":"Interim BPS and Countryside Stewardship Operations Director","withdrawn":false},{"content_id":"e0329cf9-5ed4-44e9-893b-a7325598c0b9","details":{"body":"<p>Responsible for processing the four land-based Schemes; Environmental Stewardship, Basic Payment Scheme, Countryside Stewardship and Sustainable Farming incentive; and the Animal Health and Welfare Schemes – Annual Health &amp; Welfare Review and Endemics.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2025-05-15T10:04:38Z","schema_name":"role","title":"Customer Delivery Director","withdrawn":false},{"content_id":"7ccb42b3-7c5a-4557-8a01-ff9f6523574a","details":{"body":"<p>The Data, Insight and Outcomes Director has responsibility for some of the agency’s most critical functions. These include the data and analysis function, regulatory advice and guidance and the agency’s mapping and remote monitoring capability.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2025-01-27T14:36:32Z","schema_name":"role","title":"Data, Insight and Outcomes Director ","withdrawn":false},{"content_id":"5281de08-65c1-4a8f-b5e0-e206eaaae155","details":{"body":"<p>The RPA makes payments and provides a wide range services supporting agricultural and rural communities.  The Grants Functional Standard Director role is to assure that is done though good governance and that accounting officer principals are met in whilst making sure that a culture of compliance sits comfortably alongside the effective delivery of public services.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2025-05-15T09:39:17Z","schema_name":"role","title":"Grants Functional Standard Director","withdrawn":false},{"content_id":"fd90bb01-dca8-4b4a-ba26-0abf142b3e88","details":{"body":"<p>Jake currently leads RPA’s Strategy and Leadership Directorate where he is responsible for corporate governance, strategic workforce reform, organisational capability, learning and development, Equality, Diversity and Inclusion and employee experience. Jake is also Defra group’s apprenticeship champion and was appointed a Chartered Institute of Management Chartered Companion in March 2022 and is a Fellow of the Royal Society for Arts, Manufacturers and Commerce (RSA).</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2022-04-29T08:08:02Z","schema_name":"role","title":"Organisational Capability Director","withdrawn":false},{"content_id":"724b0e9f-e658-4de6-8d3c-9e392054b32c","details":{"body":"<p>Responsible for ensuring RPA has the right people with the right skills working in an inclusive and supportive environment that results in excellent customer service and people outcomes within RPA and working with partners and stakeholders in and outside of DEFRA Group.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2025-01-07T10:42:52Z","schema_name":"role","title":"Planning and Capability Director","withdrawn":false},{"content_id":"6fd0bd9a-26e3-4d4c-9552-50585b602b22","details":{"body":"<p>The Business Transformation Director has overall responsibility for overseeing finances, relationships with key enabling Corporate Services, such as IT and for leading change and business transformation programmes and initiatives on behalf of the Agency. The latter includes the development and delivery of organisational, process, system and digital change, design of training and internal guidance and business process change products. In addition the director is responsible for initiating and acting on insight and feedback from customers, stakeholders and other Defra partners. The role holder is also the Senior Information Risk Owner on behalf of the Agency.</p>\n\n<p>The overall objective of the role is to assure the Agency, on behalf of Defra, can embrace and implement change, be more efficient and recognise and realise the requirements of its customer base to create a high performance organisation that is recognised for its excellence in customer service and value for money.</p>\n\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2025-01-07T11:13:16Z","schema_name":"role","title":"Business Transformation Director","withdrawn":false},{"content_id":"ad37a833-82f5-47b6-a4a7-c9f8e7d9b2b5","details":{"body":"<p>Our customers and their communities are at the heart of our actions as we strive to keep being the best, providing excellent delivery and outcomes that are in the public interest. The Customer Director is a key strategic and operational leadership role responsible for developing culture, process, and performance improvements to deliver excellent service and outcomes for our customers.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2023-04-17T11:22:40Z","schema_name":"role","title":"Customer Director","withdrawn":false},{"content_id":"aa3c60f8-ab74-410c-b18c-12666580ff6f","details":{"body":"<p>The Business Strategic Management Director oversees:</p>\n\n<ul>\n  <li>strategic management</li>\n  <li>regulatory compliance</li>\n  <li>operational policy</li>\n  <li>financial governance, including Managing Public Money</li>\n</ul>\n\n<p>They manage relationships with Defra Corporate Services to make sure there is alignment and accountability across the group.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2026-02-16T16:03:49Z","schema_name":"role","title":"Business Strategic Management Director","withdrawn":false},{"content_id":"2eba099a-9a46-4351-9c88-c41665585216","details":{"body":"<p>The Data and Innovation Director has responsibility for some of the agency’s most important capabilities, including:</p>\n\n<ul>\n  <li>the Data Analysis Team (DAT)</li>\n  <li>geospatial services</li>\n  <li>data protection</li>\n  <li>AI and robotics</li>\n  <li>knowledge and information management</li>\n</ul>\n\n<p>They work closely with colleagues across RPA, Defra’s Farming and Countryside Programme, and other Defra delivery bodies to make sure these functions support high‑quality delivery and informed decision‑making.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2026-02-16T16:08:33Z","schema_name":"role","title":"Data and Innovation Director","withdrawn":false},{"content_id":"e90d9fed-bdf2-449a-acb7-df74c57aba73","details":{"body":"<p>The Service Delivery Director is responsible for the operational management of:</p>\n\n<ul>\n  <li>Annual Health and Welfare Review (AHWR)</li>\n  <li>Capital Grants</li>\n  <li>Annual Grants</li>\n  <li>Countryside Stewardship Mid-Tier (CSMT)</li>\n  <li>Countryside Stewardship Higher-Tier (HT)</li>\n  <li>Customer Payments and Accounting Team (CPAT)</li>\n  <li>Customer Service Centre (CSC)</li>\n  <li>Environmental Stewardship (ES)</li>\n  <li>Livestock Services</li>\n  <li>Sustainable Farming Incentive (SFI)</li>\n  <li>Trader</li>\n</ul>\n\n<p>The Service Delivery business area is RPA’s largest business area, made up of all the agency’s operational teams.</p>\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2026-02-16T16:12:35Z","schema_name":"role","title":"Service Delivery Director","withdrawn":false},{"content_id":"cc95fc48-5cc8-4f96-9576-c195bec7eece","details":{"body":"\n","role_payment_type":null},"document_type":"board_member_role","links":{},"locale":"en","public_updated_at":"2026-02-16T16:17:29Z","schema_name":"role","title":"Grants Service Owner Director","withdrawn":false}],"organisations":[{"analytics_identifier":"EA58","api_path":"/api/content/government/organisations/rural-payments-agency","api_url":"https://www.gov.uk/api/content/government/organisations/rural-payments-agency","base_path":"/government/organisations/rural-payments-agency","content_id":"e8fae147-6232-4163-a3f1-1c15b755a8a4","details":{"acronym":"RPA","brand":"department-for-environment-food-rural-affairs","default_news_image":null,"logo":{"crest":"single-identity","formatted_title":"Rural Payments <br/>Agency"},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"Rural Payments Agency","web_url":"https://www.gov.uk/government/organisations/rural-payments-agency","withdrawn":false}],"primary_publishing_organisation":[{"analytics_identifier":"EA58","api_path":"/api/content/government/organisations/rural-payments-agency","api_url":"https://www.gov.uk/api/content/government/organisations/rural-payments-agency","base_path":"/government/organisations/rural-payments-agency","content_id":"e8fae147-6232-4163-a3f1-1c15b755a8a4","details":{"acronym":"RPA","brand":"department-for-environment-food-rural-affairs","default_news_image":null,"logo":{"crest":"single-identity","formatted_title":"Rural Payments <br/>Agency"},"organisation_govuk_status":{"status":"live","updated_at":null,"url":null}},"document_type":"organisation","links":{},"locale":"en","schema_name":"organisation","title":"Rural Payments Agency","web_url":"https://www.gov.uk/government/organisations/rural-payments-agency","withdrawn":false}]},"locale":"en","phase":"live","public_updated_at":"2025-04-24T10:56:46+01:00","publishing_app":"whitehall","publishing_request_id":"21-1778839858.523-10.13.22.58-2373","publishing_scheduled_at":null,"rendering_app":"collections","scheduled_publishing_delay_seconds":null,"schema_name":"organisation","title":"Rural Payments Agency","updated_at":"2026-05-15T11:10:59+01:00","withdrawn_notice":{}}