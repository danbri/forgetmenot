# Per-record detail HTML fragments and the run log are bulky and
# re-creatable from records/*.json (which carry document_url).
html/
crawl.log

# Per-treaty Turtle is the per-record output of the RDF lift. It's
# strictly redundant with extractors/factoids/all.nq (every triple is
# in the rollup, named by the treaty URI). The rollup is committed
# in gzipped form (all.nq.gz fits under GitHub's 100 MB limit while
# the raw all.nq does not).
extractors/factoids/*.ttl
!extractors/factoids/parliament-bridge.ttl
!extractors/factoids/fcdo-vocab.ttl
!extractors/factoids/_dataset.ttl
extractors/factoids/all.nq
extractors/factoids/_provenance.nq
