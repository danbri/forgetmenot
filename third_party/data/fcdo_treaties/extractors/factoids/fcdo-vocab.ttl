# Vocabulary for the FCDO UK Treaties Online lift.
#
# Declares the `fcdo:` classes and properties emitted by
# `scripts/fcdo_treaties_extract.py` and used in
# `third_party/data/fcdo_treaties/extractors/factoids/all.nq.gz`.
#
# This file is hand-curated, not regenerated from the script; the
# script's emitted terms and this file's declared terms should match,
# and tests/test_endpoints.sh (or a future schema-conformance check)
# can compare them. New terms emitted by the script MUST be declared
# here in the same commit.
#
# The `fcdo:` namespace is local to this repository
# (`https://forgetmenot.local/fcdo#`) and is intentionally not a
# resolvable URL — we don't operate a vocabulary server. If a
# downstream consumer wants a stable persistent IRI, this file is
# the authoritative declaration.

@prefix fcdo:   <https://forgetmenot.local/fcdo#> .
@prefix fcdo-s: <https://forgetmenot.local/fcdo/subject/> .
@prefix fcdo-a: <https://forgetmenot.local/fcdo/action/> .
@prefix fcdo-c: <https://forgetmenot.local/fcdo/country/> .

@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix schema: <http://schema.org/> .
@prefix dct:    <http://purl.org/dc/terms/> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:   <http://www.w3.org/ns/prov#> .
@prefix void:   <http://rdfs.org/ns/void#> .

# ---- Vocabulary metadata --------------------------------------------

<https://forgetmenot.local/fcdo>
    a               owl:Ontology ;
    rdfs:label      "FCDO UK Treaties Online vocabulary"@en ;
    rdfs:comment    "Terms used by the forgetmenot lift of treaties.fcdo.gov.uk catalogue records to RDF."@en ;
    dct:creator     "forgetmenot project"@en ;
    dct:license     <http://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/> ;
    owl:versionInfo "1.0.0" .

# ---- Classes --------------------------------------------------------

fcdo:Treaty
    a            rdfs:Class, owl:Class ;
    rdfs:label   "Treaty"@en ;
    rdfs:comment "A treaty or international agreement as catalogued in FCDO's UK Treaties Online (UKTO). Each instance is identified by the UKTO record URL (https://treaties.fcdo.gov.uk/awweb/awfp/recno/<id>) which doubles as the IRI of the per-record named graph that holds its triples."@en ;
    rdfs:subClassOf schema:CreativeWork .

fcdo:Country
    a            rdfs:Class, owl:Class ;
    rdfs:label   "Country (treaty party)"@en ;
    rdfs:comment "A state, territory, organisation or other entity that is, was, or could be a party to a UK treaty. Identified by a locally-minted URI under fcdo:country/ that normalises FCDO's label casing; cross-referenced to a Wikidata QID via owl:sameAs where the curated PARTY_TO_QID map covers it."@en .

fcdo:Reference
    a            rdfs:Class, owl:Class ;
    rdfs:label   "Treaty reference"@en ;
    rdfs:comment "A citation attached to a treaty record — typically a Treaty Series number, Command Paper number, UN Registration number, TNA archival reference, or similar bibliographic pointer. Emitted as a blank-node resource with the raw and parsed forms as properties."@en .

fcdo:TreatyAction
    a            rdfs:Class, owl:Class ;
    rdfs:label   "Treaty action event"@en ;
    rdfs:comment "A single act performed by a country with respect to a treaty: Signature, Ratification, Accession, Extension, Acceptance, Declaration, Reservation, Denunciation, etc. Each row of FCDO's parties_detail table becomes one TreatyAction blank-node, attached to both the treaty (via fcdo:partyAction) and the country (via fcdo:country)."@en .

# ---- Object properties ----------------------------------------------

fcdo:party
    a            rdf:Property, owl:ObjectProperty ;
    rdfs:label   "treaty party"@en ;
    rdfs:comment "A country that is, or was, a party to this treaty. Derived from FCDO's parties[] list and parties_detail[].country (with deduplication)."@en ;
    rdfs:domain  fcdo:Treaty ;
    rdfs:range   fcdo:Country .

fcdo:partyAction
    a            rdf:Property, owl:ObjectProperty ;
    rdfs:label   "party action"@en ;
    rdfs:comment "Links a treaty to one of the per-party events on it (signature, ratification, accession, etc.). One link per parties_detail[] row."@en ;
    rdfs:domain  fcdo:Treaty ;
    rdfs:range   fcdo:TreatyAction .

fcdo:country
    a            rdf:Property, owl:ObjectProperty ;
    rdfs:label   "country"@en ;
    rdfs:comment "The country performing the action on a TreatyAction event."@en ;
    rdfs:domain  fcdo:TreatyAction ;
    rdfs:range   fcdo:Country .

fcdo:action
    a            rdf:Property, owl:ObjectProperty ;
    rdfs:label   "action type"@en ;
    rdfs:comment "The kind of treaty action: Signature, Ratification, Accession, Extension, Acceptance, Declaration, Reservation, Notification, Statement, Bound, Communication, Objection, Confirmation, Definitive Signature, Application, Provisional Application, Succession, Adoption, Approval, Adherence, Withdrawal (and variants), Denunciation, Termination, Suspension, Derogation, and others. Emitted as a SKOS Concept under fcdo:action/."@en ;
    rdfs:domain  fcdo:TreatyAction ;
    rdfs:range   skos:Concept .

fcdo:subject
    a            rdf:Property, owl:ObjectProperty ;
    rdfs:label   "subject"@en ;
    rdfs:comment "FCDO's subject classification for the treaty — POLLUTION, TRADE, AVIATION, DEFENCE, etc. Emitted as a SKOS Concept under fcdo:subject/."@en ;
    rdfs:subPropertyOf dct:subject ;
    rdfs:domain  fcdo:Treaty ;
    rdfs:range   skos:Concept .

fcdo:reference
    a            rdf:Property, owl:ObjectProperty ;
    rdfs:label   "reference"@en ;
    rdfs:comment "A citation attached to the treaty — Treaty Series number, Command Paper, TNA archival reference, etc."@en ;
    rdfs:domain  fcdo:Treaty ;
    rdfs:range   fcdo:Reference .

# ---- Datatype properties (treaty) -----------------------------------

fcdo:uktoId
    a            rdf:Property, owl:DatatypeProperty ;
    rdfs:label   "UKTO record id"@en ;
    rdfs:comment "FCDO UKTO numeric record id (the integer suffix of the document URL)."@en ;
    rdfs:domain  fcdo:Treaty ;
    rdfs:range   xsd:string .

fcdo:uktoUuid
    a            rdf:Property, owl:DatatypeProperty ;
    rdfs:label   "UKTO record uuid"@en ;
    rdfs:comment "UUIDv4 assigned by the upstream Knowvation backend; included for round-tripping but not used as a stable identifier here."@en ;
    rdfs:domain  fcdo:Treaty ;
    rdfs:range   xsd:string .

fcdo:kind
    a            rdf:Property, owl:DatatypeProperty ;
    rdfs:label   "kind"@en ;
    rdfs:comment "Human-readable form: 'bilateral' or 'multilateral'. Absent when FCDO does not state."@en ;
    rdfs:domain  fcdo:Treaty ;
    rdfs:range   xsd:string .

fcdo:isBilateral
    a            rdf:Property, owl:DatatypeProperty ;
    rdfs:label   "is bilateral"@en ;
    rdfs:comment "Boolean shortcut for kind. true = bilateral, false = multilateral. Absent when FCDO does not state."@en ;
    rdfs:domain  fcdo:Treaty ;
    rdfs:range   xsd:boolean .

fcdo:signedDate
    a            rdf:Property, owl:DatatypeProperty ;
    rdfs:label   "signed date"@en ;
    rdfs:comment "ISO date the treaty was opened for signature (or signed, for bilaterals)."@en ;
    rdfs:domain  fcdo:Treaty ;
    rdfs:range   xsd:date .

fcdo:signedDateText
    a            rdf:Property, owl:DatatypeProperty ;
    rdfs:label   "signed date (raw text)"@en ;
    rdfs:comment "FCDO's raw signed-date string, kept verbatim when it cannot be parsed to an xsd:date (e.g. '00/00/1962' year-only stubs)."@en ;
    rdfs:domain  fcdo:Treaty ;
    rdfs:range   xsd:string .

fcdo:signedPlace
    a            rdf:Property, owl:DatatypeProperty ;
    rdfs:label   "signed place"@en ;
    rdfs:comment "Place of signature, as a free-text label (e.g. 'Geneva', 'Rio de Janeiro'). Not yet linked to a geographic resource."@en ;
    rdfs:domain  fcdo:Treaty ;
    rdfs:range   rdf:langString .

fcdo:entryIntoForceDate
    a            rdf:Property, owl:DatatypeProperty ;
    rdfs:label   "entry into force date"@en ;
    rdfs:comment "ISO date the treaty came into force for the UK (FCDO's 'definitive EIF date')."@en ;
    rdfs:domain  fcdo:Treaty ;
    rdfs:range   xsd:date .

fcdo:commandPaper
    a            rdf:Property, owl:DatatypeProperty ;
    rdfs:label   "command paper"@en ;
    rdfs:comment "Command paper number associated with the treaty (Cm / Cmnd / Cmd / CP <NNNN>). Extracted from a reference string. Promoted to a treaty-level property so the parliament-bridge.ttl join (UKTO record ↔ Parliament treaty id) can use it."@en ;
    rdfs:domain  fcdo:Treaty ;
    rdfs:range   xsd:string .

fcdo:referenceText
    a            rdf:Property, owl:DatatypeProperty ;
    rdfs:label   "reference (raw text)"@en ;
    rdfs:comment "Raw form of every reference attached to the treaty, kept for round-trip and for compatibility with the parliament-bridge.ttl file generated from the previous schema."@en ;
    rdfs:domain  fcdo:Treaty ;
    rdfs:range   xsd:string .

fcdo:capturedAt
    a            rdf:Property, owl:DatatypeProperty ;
    rdfs:label   "captured at"@en ;
    rdfs:comment "ISO timestamp when this record was fetched from FCDO by our crawler. The same value also appears on the named graph as prov:generatedAtTime in _provenance.nq."@en ;
    rdfs:domain  fcdo:Treaty ;
    rdfs:range   xsd:dateTime .

# ---- Datatype properties (reference + action) -----------------------

fcdo:series
    a            rdf:Property, owl:DatatypeProperty ;
    rdfs:label   "reference series"@en ;
    rdfs:comment "The bibliographic series the reference belongs to — 'Treaty Series', 'Country Series', 'Miscellaneous Series', 'Command Paper', 'UN Registration', 'PRO (now TNA) FO', 'British State Papers (BSP)', 'League of Nations Treaty Series', etc."@en ;
    rdfs:domain  fcdo:Reference ;
    rdfs:range   xsd:string .

fcdo:countryLabel
    a            rdf:Property, owl:DatatypeProperty ;
    rdfs:label   "country label (verbatim)"@en ;
    rdfs:comment "FCDO's raw country label for this action, kept because case is informative — FCDO upper-cases sovereign states ('UNITED KINGDOM') and mixed-cases UK overseas territories ('Bermuda', 'Isle of Man'). The fcdo:country object property points at a casing-normalised country URI."@en ;
    rdfs:domain  fcdo:TreatyAction ;
    rdfs:range   rdf:langString .

fcdo:actionDate
    a            rdf:Property, owl:DatatypeProperty ;
    rdfs:label   "action date"@en ;
    rdfs:comment "ISO date the country performed this action."@en ;
    rdfs:domain  fcdo:TreatyAction ;
    rdfs:range   xsd:date .

fcdo:effectiveDate
    a            rdf:Property, owl:DatatypeProperty ;
    rdfs:label   "effective date"@en ;
    rdfs:comment "ISO date the action took effect for the country (e.g. when an Extension to an overseas territory came into force)."@en ;
    rdfs:domain  fcdo:TreatyAction ;
    rdfs:range   xsd:date .

# ---- Concept schemes ------------------------------------------------

fcdo-s:
    a            skos:ConceptScheme ;
    rdfs:label   "FCDO treaty subject vocabulary"@en ;
    rdfs:comment "The fixed subject taxonomy FCDO uses to classify treaties — POLLUTION, TRADE, AVIATION, DEFENCE, etc. Concepts are emitted on demand when a treaty cites them; this scheme does not enumerate every term up-front."@en .

fcdo-a:
    a            skos:ConceptScheme ;
    rdfs:label   "FCDO treaty action vocabulary"@en ;
    rdfs:comment "The set of action verbs FCDO uses on parties_detail rows. 59 distinct values observed in the corpus, mapped here to stable URI slugs (signature, ratification, accession, extension, acceptance, declaration, reservation, …). Concepts are emitted on demand; this scheme does not enumerate every term up-front."@en .

# ---- Re-used external terms ----------------------------------------
# We also use these third-party terms; declared here only to give
# readers a single place to see every predicate that appears in
# all.nq:
#
#   rdf:type
#   rdfs:label
#   dct:title          dct:subject     dct:source        dct:hasFormat
#   schema:name        schema:alternateName  schema:url   schema:sameAs
#   skos:prefLabel     skos:inScheme   skos:Concept
#   owl:sameAs
#   prov:generatedAtTime  prov:wasDerivedFrom  prov:Entity   (in _provenance.nq only)
#   void:Dataset       void:triples    void:exampleResource  (in _dataset.ttl only)
